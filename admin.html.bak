<!DOCTYPE html>
<html lang="de">
<head>
    <!-- Google Analytics absichtlich NICHT im Admin-Panel geladen.
         Admin-Aktivitäten sollen nicht in GA-Berichten erscheinen. -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=5.0"/>
    <title>WaveVapes – Admin Panel Pro v2.0</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#0a0a0a">
    <meta name="color-scheme" content="dark">
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-firestore-compat.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="admin.css" />
</head>
<body class="min-h-screen">
<header class="hdr-root">
    <div class="hdr-inner">
        <div class="hdr-logo-area">
            <img src="logo.png" alt="Logo" class="hdr-logo" loading="eager">
            <span class="hdr-brand">ADMIN PRO</span>
        </div>
        <div class="hdr-sep"></div>
        <div class="hdr-breadcrumb">
            <span>WaveVapes</span>
            <i class="fa-solid fa-chevron-right" style="font-size:9px;opacity:.4"></i>
            <span class="hdr-breadcrumb-cur" id="hdr-tab-name">Produkte</span>
        </div>
        <div class="hdr-sep"></div>
        <!-- Global Search -->
        <div class="hdr-search-wrap">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input class="hdr-search-input" id="global-search" placeholder="Produkte, Bestellungen, User suchen..." autocomplete="off"
                   oninput="globalSearchInput()" onfocus="globalSearchFocus()" onblur="setTimeout(globalSearchBlur,200)">
            <div class="hdr-search-dropdown" id="global-search-dd"></div>
        </div>
        <div class="hdr-right">
            <!-- Notification bell -->
            <div class="hdr-notif-btn" onclick="toggleNotifPanel()" title="Benachrichtigungen">
                <i class="fa-solid fa-bell"></i>
                <div class="hdr-notif-dot" id="hdr-notif-dot"></div>
            </div>
            <span class="hdr-email" id="admin-email"></span>
            <div class="hdr-sep"></div>
            <button onclick="logout()" class="hdr-logout">Logout</button>
            <a href="admin-mobile.html" title="Mobile Version" style="display:inline-flex;align-items:center;gap:6px;padding:7px 12px;border-radius:40px;background:rgba(103,232,249,.08);border:1px solid rgba(103,232,249,.2);color:#67e8f9;font-size:11px;font-weight:700;text-decoration:none;transition:all .2s;white-space:nowrap" onmouseover="this.style.background='rgba(103,232,249,.16)'" onmouseout="this.style.background='rgba(103,232,249,.08)'">
                <i class="fa-solid fa-mobile-screen-button"></i> Mobile
            </a>
            <button onclick="toggleSidebar()" class="hdr-notif-btn" style="display:none" id="sidebar-toggle-btn"><i class="fa-solid fa-bars"></i></button>
        </div>
    </div>
</header>

<!-- ═══ NUR-LESEN BANNER ═══ -->
<div id="admin-readonly-banner">
    <i class="fa-solid fa-eye ro-banner-icon"></i>
    <span class="ro-banner-text">Du bist im <strong>Nur-Lesen Modus</strong> — alle Tabs sind sichtbar, aber Änderungen sind gesperrt.</span>
    <span class="ro-banner-badge">👁️ READ ONLY</span>
</div>

<!-- Notification Panel -->
<div class="notif-overlay" id="notif-overlay" onclick="closeNotifPanel()"></div>
<div class="notif-panel" id="notif-panel" style="display:none">
    <div class="notif-hdr">
        <div class="notif-title"><i class="fa-solid fa-bell" style="color:#67e8f9;margin-right:6px"></i>Benachrichtigungen</div>
        <span class="notif-clear" onclick="clearNotifications()">Alle löschen</span>
    </div>
    <div class="notif-list" id="notif-list">
        <div class="notif-empty"><i class="fa-solid fa-bell-slash" style="font-size:24px;display:block;margin-bottom:8px;opacity:.3"></i>Keine Benachrichtigungen</div>
    </div>
</div>

<!-- Product Edit Drawer -->
<div class="ped-overlay" id="ped-overlay" onclick="closePedDrawer()"></div>
<div class="ped-drawer" id="ped-drawer">
    <div class="ped-hdr">
        <div class="ped-title"><i class="fa-solid fa-pen-to-square" style="color:#67e8f9;font-size:14px"></i><span id="ped-title-text">Produkt bearbeiten</span></div>
        <button class="ped-close" onclick="closePedDrawer()">✕</button>
    </div>
    <div class="ped-body">
        <!-- Image column -->
        <div class="ped-img-col">
            <div class="ped-preview" id="ped-preview-wrap">
                <div class="ped-preview-ph"><i class="fa-solid fa-image"></i>Kein Bild</div>
            </div>
            <div class="ped-dropzone" id="ped-dropzone">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                <div class="ped-dropzone-lbl">Neues Bild hochladen</div>
            </div>
            <button class="ped-rm-img" id="ped-rm-img-btn" onclick="pedRemoveImage()" style="display:none">
                <i class="fa-solid fa-trash"></i> Bild entfernen
            </button>
        </div>
        <!-- Form column -->
        <div class="ped-form-col">
            <div class="ped-section">
                <div class="ped-section-title">Stammdaten</div>
                <div class="ped-field" style="margin-bottom:10px">
                    <label class="ped-label">Produktname</label>
                    <input class="ped-input" id="edit-name" placeholder="Produktname">
                </div>
                <div class="ped-grid2">
                    <div class="ped-field">
                        <label class="ped-label">Aktueller Preis (€)</label>
                        <input class="ped-input" id="edit-price" type="number" step="0.01">
                    </div>
                    <div class="ped-field">
                        <label class="ped-label">Alter Preis (€)</label>
                        <input class="ped-input" id="edit-original-price" type="number" step="0.01" placeholder="—">
                    </div>
                    <div class="ped-field">
                        <label class="ped-label" style="color:#fbbf24">Einkaufspreis (€) <span style="color:rgba(251,191,36,.5);font-size:8px;font-weight:400;letter-spacing:0;text-transform:none">nur intern</span></label>
                        <input class="ped-input" id="edit-cost-price" type="number" step="0.01" placeholder="z.B. 3.50" style="border-color:rgba(251,191,36,.18);background:rgba(251,191,36,.03)">
                    </div>
                    <div class="ped-field">
                        <label class="ped-label">Lagerbestand</label>
                        <input class="ped-input" id="edit-stock" type="number">
                    </div>
                    <div class="ped-field" style="grid-column:span 2">
                        <label class="ped-label">Kategorie</label>
                        <select class="ped-input" id="edit-category-select"></select>
                    </div>
                </div>
                <!-- Live-Marge Anzeige -->
                <div id="ped-margin-box" style="display:none;margin-top:10px;padding:10px 14px;border-radius:10px;background:rgba(251,191,36,.05);border:1px solid rgba(251,191,36,.15);font-size:11px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                    <span style="color:rgba(255,255,255,.4)"><i class="fa-solid fa-chart-pie" style="margin-right:4px;color:#fbbf24"></i>Marge:</span>
                    <span id="ped-margin-val" style="font-family:'JetBrains Mono',monospace;font-weight:700;font-size:13px">—</span>
                    <span id="ped-profit-val" style="color:rgba(255,255,255,.35);font-family:'JetBrains Mono',monospace">—</span>
                </div>
            </div>
            <div class="ped-section">
                <div class="ped-section-title">Eigenschaften</div>
                <div class="ped-toggle-row">
                    <span class="ped-toggle-lbl">Neue Sorte</span>
                    <label class="ped-sw lime"><input type="checkbox" id="edit-new"><span class="ped-sw-sl"></span></label>
                </div>
                <div class="ped-toggle-row">
                    <span class="ped-toggle-lbl">Nicht verfügbar</span>
                    <label class="ped-sw red"><input type="checkbox" id="edit-unavailable" onchange="if(this.checked){ const s=document.getElementById('edit-stock'); if(s) s.value=0; }"><span class="ped-sw-sl"></span></label>
                </div>
                <div class="ped-toggle-row">
                    <span class="ped-toggle-lbl">Nikotin enthalten</span>
                    <label class="ped-sw"><input type="checkbox" id="edit-has-nicotine"><span class="ped-sw-sl"></span></label>
                </div>
            </div>
            <div class="ped-section">
                <div class="ped-section-title" style="display:flex;align-items:center;justify-content:space-between">
                    Beschreibung
                    <button type="button" onclick="aiGenerateDescription()" id="ai-desc-btn"
                        style="display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:8px;background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.3);color:#a78bfa;font-size:11px;font-weight:700;cursor:pointer;transition:all .2s"
                        onmouseover="this.style.background='rgba(167,139,250,.22)'" onmouseout="this.style.background='rgba(167,139,250,.12)'">
                        <i class="fa-solid fa-wand-magic-sparkles" style="font-size:11px"></i> KI schreiben
                    </button>
                </div>
                <textarea class="ped-input ped-textarea" id="edit-description" rows="4" placeholder="Produktbeschreibung..."></textarea>
                <div id="ai-desc-result" style="display:none;margin-top:8px;padding:10px 13px;background:rgba(167,139,250,.07);border:1px solid rgba(167,139,250,.2);border-radius:10px;font-size:12px;color:rgba(255,255,255,.7);line-height:1.6"></div>
            </div>
            <div class="ped-section">
                <div class="ped-section-title">Interne Notizen</div>
                <textarea class="ped-input ped-textarea" id="edit-admin-notes" rows="3" placeholder="Nur für Admins sichtbar — z.B. Lieferant, Nachbestellhinweise..."></textarea>
                <div class="ped-notes-hint">Wird nicht im Shop angezeigt</div>
            </div>
        </div>
    </div>
    <div class="ped-footer">
        <button class="ped-save" onclick="saveEdit()"><i class="fa-solid fa-cloud-arrow-up"></i> Speichern</button>
        <button class="bke-cancel" onclick="closePedDrawer()">Abbrechen</button>
    </div>
</div>

<!-- Bulk Edit Bottom Sheet -->
<div class="bke-overlay" id="bke-overlay" onclick="closeBulkModal()"></div>

<!-- Kategorie-Einkaufspreis Modal -->
<div id="catcost-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.82);z-index:99998;backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:16px"></div>
<div id="catcost-modal" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:99999;width:min(500px,94vw);background:#13131f;border:1px solid rgba(251,191,36,.22);border-radius:24px;padding:28px;box-shadow:0 0 60px rgba(251,191,36,.08),0 24px 48px rgba(0,0,0,.6);animation:modalPop .3s cubic-bezier(.34,1.56,.64,1)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
        <div>
            <div style="font-family:'Orbitron',sans-serif;font-size:15px;font-weight:700;color:#fbbf24;display:flex;align-items:center;gap:10px;text-shadow:0 0 16px rgba(251,191,36,.35)">
                <div style="width:36px;height:36px;border-radius:11px;background:rgba(251,191,36,.12);border:1px solid rgba(251,191,36,.25);display:flex;align-items:center;justify-content:center;font-size:15px"><i class="fa-solid fa-tag"></i></div>
                Kategorie-Einkaufspreis
            </div>
            <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:4px;margin-left:46px">Einkaufspreis für alle Produkte einer Kategorie auf einmal setzen</div>
        </div>
        <button onclick="closeCatCostModal()" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:10px;width:32px;height:32px;color:rgba(255,255,255,.4);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.4)'">✕</button>
    </div>

    <!-- Kategorie wählen -->
    <div style="margin-bottom:14px">
        <label style="font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.28);display:block;margin-bottom:6px">Kategorie</label>
        <select id="catcost-category" style="width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:10px 12px;color:#fff;font-size:13px;outline:none;transition:border-color .2s;box-sizing:border-box;color-scheme:dark" onfocus="this.style.borderColor='rgba(251,191,36,.4)'" onblur="this.style.borderColor='rgba(255,255,255,.08)'" onchange="catCostUpdatePreview()">
            <option value="">— Kategorie wählen —</option>
        </select>
    </div>

    <!-- Einkaufspreis -->
    <div style="margin-bottom:14px">
        <label style="font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#fbbf24;display:block;margin-bottom:6px">Einkaufspreis pro Stück (€)</label>
        <input id="catcost-price" type="number" step="0.01" min="0" placeholder="z.B. 3.50"
            style="width:100%;background:rgba(251,191,36,.04);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:11px 14px;color:#fff;font-size:15px;font-family:'JetBrains Mono',monospace;font-weight:700;outline:none;transition:border-color .2s;box-sizing:border-box"
            onfocus="this.style.borderColor='rgba(251,191,36,.5)'" onblur="this.style.borderColor='rgba(251,191,36,.2)'" oninput="catCostUpdatePreview()">
    </div>

    <!-- Preview -->
    <div id="catcost-preview" style="display:none;padding:12px 16px;border-radius:12px;background:rgba(251,191,36,.05);border:1px solid rgba(251,191,36,.12);margin-bottom:16px;font-size:12px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
            <span style="color:rgba(255,255,255,.4)">Betroffene Produkte:</span>
            <span id="catcost-count" style="font-family:'JetBrains Mono',monospace;font-weight:700;color:#67e8f9">0</span>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between">
            <span style="color:rgba(255,255,255,.4)">Ø Verkaufspreis:</span>
            <span id="catcost-avg-price" style="font-family:'JetBrains Mono',monospace;font-weight:700;color:rgba(255,255,255,.7)">—</span>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:6px" id="catcost-margin-row" style="display:none">
            <span style="color:rgba(255,255,255,.4)">Ø Marge:</span>
            <span id="catcost-avg-margin" style="font-family:'JetBrains Mono',monospace;font-weight:700">—</span>
        </div>
    </div>

    <!-- Buttons -->
    <div style="display:flex;gap:10px">
        <button onclick="executeCatCostUpdate()" style="flex:1;padding:13px;background:linear-gradient(135deg,rgba(251,191,36,.18),rgba(251,191,36,.1));border:1px solid rgba(251,191,36,.35);border-radius:13px;color:#fbbf24;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px" onmouseover="this.style.background='linear-gradient(135deg,rgba(251,191,36,.28),rgba(251,191,36,.18))'" onmouseout="this.style.background='linear-gradient(135deg,rgba(251,191,36,.18),rgba(251,191,36,.1))'">
            <i class="fa-solid fa-tag"></i> Einkaufspreis setzen
        </button>
        <button onclick="closeCatCostModal()" style="padding:13px 18px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:13px;color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s;font-size:13px" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.4)'">Abbrechen</button>
    </div>
</div>
<div class="bke-sheet" id="bke-sheet">
    <div class="bke-handle"></div>
    <div class="bke-hdr">
        <div class="bke-title">
            <i class="fa-solid fa-list-check" style="color:#67e8f9"></i>
            Bulk-Edit
            <span class="bke-count" id="bke-count">0 Produkte</span>
        </div>
        <button class="bke-close" onclick="closeBulkModal()">✕</button>
    </div>
    <!-- Info-Banner: zeigt ob Auswahl oder gefilterte Liste -->
    <div id="bke-source-banner" style="margin:0 20px 4px;padding:8px 12px;border-radius:10px;background:rgba(103,232,249,.07);border:1px solid rgba(103,232,249,.15);font-size:11px;color:rgba(255,255,255,.55);display:flex;align-items:center;gap:7px">
        <i class="fa-solid fa-filter" style="color:#67e8f9;font-size:10px"></i>
        <span id="bke-source-text">0 Produkte ausgewählt</span>
    </div>
    <div class="bke-body">
        <div class="bke-field">
            <label class="bke-label">Verkaufspreis (€)</label>
            <input class="bke-input" id="bulk-price" type="number" step="0.01" placeholder="z.B. 7.99">
        </div>
        <div class="bke-field">
            <label class="bke-label">Preis % anpassen</label>
            <div class="bke-pct-wrap">
                <input class="bke-input" id="bulk-price-pct" type="number" step="0.1" placeholder="z.B. +10 oder -5" style="flex:1">
                <span class="bke-pct-sign">%</span>
            </div>
        </div>
        <div class="bke-field">
            <label class="bke-label" style="color:#fbbf24">Einkaufspreis (€) <span style="font-weight:400;opacity:.5;font-size:8px">intern</span></label>
            <input class="bke-input" id="bulk-cost-price" type="number" step="0.01" placeholder="z.B. 3.50" style="border-color:rgba(251,191,36,.2);background:rgba(251,191,36,.03)">
        </div>
        <div class="bke-field">
            <label class="bke-label">Lagerbestand</label>
            <input class="bke-input" id="bulk-stock" type="number" placeholder="z.B. 50">
        </div>
        <div class="bke-field" style="grid-column:span 2">
            <label class="bke-label">Kategorie</label>
            <select class="bke-input" id="bulk-category"></select>
        </div>
        <div class="bke-field" style="grid-column:span 2">
            <label class="bke-label">Eigenschaften</label>
            <div class="bke-toggles">
                <div class="bke-toggle-pill" id="bke-pill-available" onclick="bkePillToggle(this,'available')"><i class="fa-solid fa-circle-check"></i> Verfügbar</div>
                <div class="bke-toggle-pill" id="bke-pill-new" onclick="bkePillToggle(this,'new')"><i class="fa-solid fa-star"></i> Neue Sorte</div>
                <div class="bke-toggle-pill" id="bke-pill-nicotine" onclick="bkePillToggle(this,'nicotine')"><i class="fa-solid fa-droplet"></i> Nikotin</div>
            </div>
        </div>
    </div>
    <div class="bke-footer">
        <button class="bke-save" onclick="executeBulkEdit()"><i class="fa-solid fa-check"></i> Änderungen anwenden</button>
        <button class="bke-cancel" onclick="closeBulkModal()">Abbrechen</button>
    </div>
</div>

<div class="flex h-[calc(100vh-60px)] overflow-hidden">
    <!-- SIDEBAR -->
    <div id="sidebar" class="w-64 bg-zinc-950 border-r border-white/[0.06] flex-shrink-0 overflow-y-auto" style="transition:transform .3s">
        <div class="p-4">
            <div class="sidebar-section-label">Verwaltung</div>
            <div onclick="switchTab(0)" id="sidebar-0" class="sidebar-item tab-active"><i class="fa-solid fa-box"></i><span>Produkte</span><span class="sidebar-notif" id="sb-notif-0" style="display:none"></span></div>
            <div onclick="switchTab(1)" id="sidebar-1" class="sidebar-item"><i class="fa-solid fa-receipt"></i><span>Bestellungen</span><span class="sidebar-badge" id="sb-badge-orders" style="display:none">0</span></div>
            <div onclick="switchTab(2)" id="sidebar-2" class="sidebar-item"><i class="fa-solid fa-users"></i><span>Benutzer</span></div>
            <div onclick="switchTab(3)" id="sidebar-3" class="sidebar-item"><i class="fa-solid fa-tags"></i><span>Kategorien</span></div>
            <div onclick="switchTab(4)" id="sidebar-4" class="sidebar-item"><i class="fa-solid fa-ticket"></i><span>Gutscheine</span></div>

            <div class="sidebar-section-label" style="margin-top:8px">Insights</div>
            <div onclick="switchTab(5)" id="sidebar-5" class="sidebar-item"><i class="fa-solid fa-chart-line"></i><span>Analytics</span></div>
            <div onclick="switchTab(9)" id="sidebar-9" class="sidebar-item"><i class="fa-solid fa-users-viewfinder"></i><span>Live Online</span><span class="sidebar-notif" id="sb-live-dot" style="display:none"></span></div>
            <div onclick="switchTab(15)" id="sidebar-15" class="sidebar-item"><i class="fa-solid fa-computer-mouse"></i><span>Klick-Analyse</span><span class="sidebar-notif" id="sb-click-dot" style="display:none"></span></div>
            <div onclick="switchTab(17)" id="sidebar-17" class="sidebar-item"><i class="fa-solid fa-list-check"></i><span>Admin Logs</span></div>

            <div class="sidebar-section-label" style="margin-top:8px">Konfiguration</div>
            <div onclick="switchTab(7)" id="sidebar-7" class="sidebar-item"><i class="fa-solid fa-sliders"></i><span>Settings</span></div>
            <div onclick="switchTab(8)" id="sidebar-8" class="sidebar-item"><i class="fa-solid fa-arrows-up-down"></i><span>Sortierung</span></div>
            <div onclick="switchTab(10)" id="sidebar-10" class="sidebar-item"><i class="fa-solid fa-users-cog"></i><span>Erw. Benutzer</span></div>
            <div onclick="switchTab(11)" id="sidebar-11" class="sidebar-item"><i class="fa-solid fa-star"></i><span>Bewertungen</span><span class="sidebar-badge" id="sb-reviews-badge" style="display:none">0</span></div>
            <div onclick="switchTab(18)" id="sidebar-18" class="sidebar-item"><i class="fa-solid fa-wand-magic-sparkles"></i><span>Review Generator</span></div>
            <div onclick="switchTab(13)" id="sidebar-13" class="sidebar-item"><i class="fa-solid fa-crown"></i><span>Kunden-Übersicht</span></div>
            <div onclick="switchTab(14)" id="sidebar-14" class="sidebar-item"><i class="fa-solid fa-bolt"></i><span>Aktionen</span><span class="sidebar-badge" id="sb-promos-badge" style="display:none">0</span></div>
            <div onclick="switchTab(16)" id="sidebar-16" class="sidebar-item"><i class="fa-solid fa-layer-group"></i><span>Bundles</span><span class="sidebar-badge" id="sb-bundles-badge" style="display:none">0</span></div>

            <div class="sidebar-section-label" style="margin-top:12px; border-top:1px solid rgba(251,191,36,.1); padding-top:12px;">Superadmin</div>
            <div onclick="openSuperadminZone()" id="sidebar-12" class="sidebar-item-locked" title="Nur für Superadmin">
                <i class="fa-solid fa-shield-halved"></i>
                <span>Superadmin Zone</span>
                <i class="fa-solid fa-lock" style="margin-left:auto;font-size:10px;opacity:.6"></i>
            </div>
        </div>
    </div>
    <!-- MAIN CONTENT -->
    <div class="flex-1 overflow-y-auto p-6 max-w-none xl:px-8 lg:px-6 md:px-4 px-4">

        <!-- TAB 0: PRODUKTE v2 -->
        <div id="tab-content-0">
        <div class="prd-shell">

            <!-- Page header -->
            <div class="prd-page-hdr">
                <div class="prd-page-title"><i class="fa-solid fa-box"></i> Produkte</div>
                <div class="prd-utils-bar">
                    <button class="prd-btn prd-btn-green" onclick="exportProductsToCSV()"><i class="fa-solid fa-file-csv"></i> Export</button>
                    <button class="prd-btn prd-btn-amber" onclick="document.getElementById('csv-upload-products').click()"><i class="fa-solid fa-file-import"></i> Import</button>
                    <button class="prd-btn prd-btn-red"   onclick="resetAllStatistics()"><i class="fa-solid fa-rotate-left"></i> Stats reset</button>
                </div>
            </div>
            <input type="file" id="csv-upload-products" accept=".csv" class="hidden" onchange="importProductsFromCSV(event)">

            <!-- Stock warning banner -->
            <div id="stock-warning-banner" class="prd-warn-banner hidden">
                <div class="prd-warn-hdr">
                    <div class="prd-warn-title">
                        <i class="fa-solid fa-triangle-exclamation" style="animation:ord-pulse 1.5s infinite"></i>
                        Lagerwarnung – Kritische Bestände
                    </div>
                    <button class="prd-warn-close" onclick="document.getElementById('stock-warning-banner').classList.add('hidden')">✕</button>
                </div>
                <div id="stock-warning-list" class="prd-warn-grid"></div>
                <div class="prd-warn-footer" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
                    <span>Schwellenwert in <button onclick="switchTab(7)" style="color:var(--prd-cyan);text-decoration:underline;background:none;border:none;cursor:pointer;font-size:10px">Settings</button> konfigurieren</span>
                    <button id="prd-ai-stock-btn" onclick="aiStockReorder()" style="display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:8px;background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.3);color:#a78bfa;font-size:11px;font-weight:700;cursor:pointer"><i class="fa-solid fa-wand-magic-sparkles"></i> KI-Nachbestellungsplan</button>
                </div>
                <div id="prd-ai-stock-result" style="display:none;margin-top:12px;padding:14px 16px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.18);border-radius:12px;font-size:12px;line-height:1.75;color:rgba(255,255,255,.82)"></div>
            </div>

            <!-- KPI strip -->
            <div class="prd-kpis">
                <div class="prd-kpi">
                    <div class="prd-kpi-glow" style="background:#34d399"></div>
                    <div class="prd-kpi-lbl">Gesamtumsatz</div>
                    <div class="prd-kpi-val" id="total-revenue" style="color:var(--prd-green)">0 €</div>
                </div>
                <div class="prd-kpi">
                    <div class="prd-kpi-glow" style="background:#67e8f9"></div>
                    <div class="prd-kpi-lbl">Aktive Produkte</div>
                    <div class="prd-kpi-val" id="active-products" style="color:var(--prd-cyan)">0</div>
                </div>
                <div class="prd-kpi">
                    <div class="prd-kpi-glow" style="background:#a78bfa"></div>
                    <div class="prd-kpi-lbl">Verkaufte Einheiten</div>
                    <div class="prd-kpi-val" id="total-sold" style="color:var(--prd-purple)">0</div>
                </div>
                <div class="prd-kpi">
                    <div class="prd-kpi-glow" style="background:#fbbf24"></div>
                    <div class="prd-kpi-lbl">Top-Seller</div>
                    <div class="prd-kpi-val" id="top-seller" style="color:var(--prd-amber);font-size:14px;font-family:'Inter',sans-serif;font-weight:700;margin-top:4px">—</div>
                </div>
            </div>

            <!-- Add product panel (collapsible) -->
            <div class="prd-add-panel" id="prd-add-panel">
                <div class="prd-add-hdr" onclick="prdToggleAddPanel()">
                    <div class="prd-add-hdr-left">
                        <div class="prd-add-icon"><i class="fa-solid fa-plus"></i></div>
                        <div class="prd-add-hdr-title">Neues Produkt hinzufügen</div>
                    </div>
                    <i class="fa-solid fa-chevron-down prd-add-chevron"></i>
                </div>
                <div class="prd-add-body">
                    <form id="add-form">
                        <div class="prd-add-grid">
                            <div class="prd-add-field" style="grid-column:span 3">
                                <label class="prd-add-label">Produktname</label>
                                <input id="prod-name" class="prd-add-input" placeholder="z.B. Blue Raspberry Ice" required>
                            </div>
                            <div class="prd-add-field">
                                <label class="prd-add-label">Aktueller Preis (€)</label>
                                <input id="prod-price" type="number" step="0.01" class="prd-add-input" placeholder="7.99" required>
                            </div>
                            <div class="prd-add-field">
                                <label class="prd-add-label">Alter Preis (Strikethrough)</label>
                                <input id="prod-original-price" type="number" step="0.01" class="prd-add-input" placeholder="9.99">
                            </div>
                            <div class="prd-add-field">
                                <label class="prd-add-label" style="color:#fbbf24">Einkaufspreis (€) <span style="font-weight:400;opacity:.6;font-size:9px">intern</span></label>
                                <input id="prod-cost-price" type="number" step="0.01" class="prd-add-input" placeholder="3.50" style="border-color:rgba(251,191,36,.2);background:rgba(251,191,36,.03)">
                            </div>
                            <div class="prd-add-field">
                                <label class="prd-add-label">Lagerbestand</label>
                                <input id="prod-stock" type="number" class="prd-add-input" placeholder="50" required>
                            </div>
                            <div class="prd-add-field" style="grid-column:span 3">
                                <label class="prd-add-label">Kategorie</label>
                                <select id="prod-category" class="prd-add-input"></select>
                            </div>
                            <div class="prd-add-toggle-row">
                                <div><div class="prd-add-toggle-lbl">Neue Sorte</div><div class="prd-add-toggle-sub">Zeigt NEW-Badge</div></div>
                                <label class="prd-add-sw lime"><input id="prod-new" type="checkbox"><span class="prd-add-sw-sl"></span></label>
                            </div>
                            <div class="prd-add-toggle-row">
                                <div><div class="prd-add-toggle-lbl">Nicht verfügbar</div><div class="prd-add-toggle-sub">Ausgegraut im Shop</div></div>
                                <label class="prd-add-sw red"><input id="prod-unavailable" type="checkbox"><span class="prd-add-sw-sl"></span></label>
                            </div>
                            <div class="prd-add-toggle-row">
                                <div><div class="prd-add-toggle-lbl">Nikotin enthalten</div><div class="prd-add-toggle-sub">10 / 20 mg Auswahl</div></div>
                                <label class="prd-add-sw"><input id="prod-has-nicotine" type="checkbox" checked><span class="prd-add-sw-sl"></span></label>
                            </div>
                            <div class="prd-add-field" style="grid-column:span 3">
                                <label class="prd-add-label" style="display:flex;align-items:center;justify-content:space-between">
                                    Beschreibung
                                    <button type="button" onclick="aiGenerateDescriptionAdd()" id="ai-desc-add-btn"
                                        style="display:flex;align-items:center;gap:5px;padding:3px 10px;border-radius:6px;background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.3);color:#a78bfa;font-size:10px;font-weight:700;cursor:pointer;transition:all .2s"
                                        onmouseover="this.style.background='rgba(167,139,250,.22)'" onmouseout="this.style.background='rgba(167,139,250,.12)'">
                                        <i class="fa-solid fa-wand-magic-sparkles" style="font-size:10px"></i> KI
                                    </button>
                                </label>
                                <textarea id="prod-description" rows="3" class="prd-add-input" style="resize:vertical" placeholder="Intensiver Blue Raspberry Geschmack..."></textarea>
                                <div id="ai-desc-add-result" style="display:none;margin-top:6px;padding:8px 11px;background:rgba(167,139,250,.07);border:1px solid rgba(167,139,250,.2);border-radius:8px;font-size:11px;color:rgba(255,255,255,.7);line-height:1.6"></div>
                            </div>
                            <div id="dropzone" class="prd-dropzone" style="grid-column:span 3">
                                <i class="fa-solid fa-cloud-arrow-up" style="font-size:28px;color:var(--prd-cyan);display:block;margin-bottom:8px"></i>
                                <div style="font-size:12px;color:rgba(103,232,249,.7)">Produktbild hochladen oder hierher ziehen</div>
                                <img id="preview-thumb" class="hidden" style="max-height:120px;border-radius:10px;margin:10px auto 0;border:1px solid rgba(103,232,249,.2)">
                            </div>
                        </div>
                        <button type="submit" class="prd-add-submit">
                            <i class="fa-solid fa-cloud-arrow-up"></i> Produkt speichern
                        </button>
                    </form>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="prd-topbar">
                <div class="prd-search-wrap">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input id="product-search" class="prd-search" placeholder="Produkt suchen..." oninput="applyAdminFilters()">
                </div>
                <select id="admin-category-filter" class="prd-fsel" onchange="applyAdminFilters()">
                    <option value="Alle">Alle Kategorien</option>
                </select>
                <select id="admin-status-filter" class="prd-fsel" onchange="applyAdminFilters()">
                    <option value="">Alle Produkte</option>
                    <option value="available">Nur verfügbar</option>
                    <option value="unavailable">Nur nicht verfügbar</option>
                    <option value="new">Nur neue Sorten</option>
                    <option value="tornado">Nur Tornado 30000</option>
                    <option value="lowstock">⚠ Niedriger Bestand</option>
                </select>
                <div class="prd-sep"></div>
                <button class="prd-btn prd-btn-purple" onclick="openBulkEditModal()"><i class="fa-solid fa-list-check"></i> Bulk-Edit</button>
                <button class="prd-btn prd-btn-amber"  onclick="enforceCategories()"><i class="fa-solid fa-wand-magic-sparkles"></i> Auto-Kategorien</button>
                <button class="prd-btn" style="background:rgba(251,191,36,.09);color:#fbbf24;border-color:rgba(251,191,36,.2)" onclick="openCatCostModal()"><i class="fa-solid fa-tag"></i> Kategorie-EK</button>
                <div class="prd-sep"></div>
                <span class="prd-result-count" id="prd-result-count"></span>
                <!-- Erscheint nur wenn Filter aktiv -->
                <button id="bke-filtered-btn" class="prd-btn" onclick="openBulkEditFiltered()"
                    style="display:none;background:rgba(167,139,250,.12);color:#a78bfa;border-color:rgba(167,139,250,.28);animation:bke-pulse .8s ease-in-out 2">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> <span id="bke-filtered-label">Alle sichtbaren bulk-editieren</span>
                </button>
            </div>

            <!-- Product table -->
            <div class="prd-table-card">
                <div class="prd-scroll">
                    <table class="prd-table">
                        <thead>
                            <tr>
                                <th class="no-sort" style="width:40px;text-align:center"><input type="checkbox" id="select-all-products" onclick="toggleSelectAllProducts(this)" class="accent-cyan-400 w-4 h-4"></th>
                                <th onclick="sortAdminTable('name')">Produkt</th>
                                <th onclick="sortAdminTable('category')">Kategorie</th>
                                <th onclick="sortAdminTable('price')" style="text-align:right">Preis</th>
                                <th onclick="sortAdminTable('stock')" style="text-align:center">Lager</th>
                                <th onclick="sortAdminTable('available')" style="text-align:center">Verfügbar</th>
                                <th onclick="sortAdminTable('sold')" style="text-align:right">Verkauft</th>
                                <th onclick="sortAdminTable('revenue')" style="text-align:right">Umsatz</th>
                                <th class="no-sort" style="text-align:right;padding-right:16px">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody id="products-tbody">
                            <tr><td colspan="9"><div class="prd-empty"><span class="eu-spinner"></span><br><br>Lade Produkte...</div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div><!-- /prd-shell -->
        </div>

        <!-- TAB 1: BESTELLUNGEN v2 -->
        <div id="tab-content-1" class="hidden">
        <div class="ord-shell">

            <!-- Page header -->
            <div class="ord-page-hdr">
                <div class="ord-page-title">
                    <i class="fa-solid fa-receipt"></i> Bestellungen
                    <span class="ord-live-dot" title="Live-Updates aktiv"></span>
                </div>
                <div style="display:flex;gap:8px;flex-wrap:wrap">
                    <button class="ord-btn ord-btn-green" onclick="exportOrdersToCSV()"><i class="fa-solid fa-file-csv"></i> CSV</button>
                    <button class="ord-btn ord-btn-cyan"  onclick="exportOrdersWithTracking()"><i class="fa-solid fa-link"></i> Tracking-Export</button>
                    <button class="ord-btn ord-btn-amber" onclick="document.getElementById('csv-upload-orders').click()"><i class="fa-solid fa-file-import"></i> Import</button>
                </div>
            </div>

            <!-- KPI strip – klickbar als Status-Filter -->
            <div class="ord-kpi-strip">
                <div class="ord-kpi active" id="ord-kpi-all" style="--ord-kpi-color:var(--ord-cyan);--ord-kpi-accent:rgba(103,232,249,.25)" onclick="ordSetFilter('')">
                    <div class="ord-kpi-glow"></div>
                    <div class="ord-kpi-lbl">Gesamt</div>
                    <div class="ord-kpi-val" id="ord-cnt-all">—</div>
                </div>
                <div class="ord-kpi" id="ord-kpi-zahlung" style="--ord-kpi-color:#facc15;--ord-kpi-accent:rgba(250,204,21,.2)" onclick="ordSetFilter('Zahlung erwartet')">
                    <div class="ord-kpi-glow" style="background:#facc15"></div>
                    <div class="ord-kpi-lbl">Zahlung</div>
                    <div class="ord-kpi-val" id="ord-cnt-zahlung">—</div>
                </div>
                <div class="ord-kpi" id="ord-kpi-wird" style="--ord-kpi-color:#60a5fa;--ord-kpi-accent:rgba(96,165,250,.2)" onclick="ordSetFilter('Wird bearbeitet')">
                    <div class="ord-kpi-glow" style="background:#60a5fa"></div>
                    <div class="ord-kpi-lbl">Bearbeitung</div>
                    <div class="ord-kpi-val" id="ord-cnt-wird">—</div>
                </div>
                <div class="ord-kpi" id="ord-kpi-versendet" style="--ord-kpi-color:#a78bfa;--ord-kpi-accent:rgba(167,139,250,.2)" onclick="ordSetFilter('Versendet')">
                    <div class="ord-kpi-glow" style="background:#a78bfa"></div>
                    <div class="ord-kpi-lbl">Versendet</div>
                    <div class="ord-kpi-val" id="ord-cnt-versendet">—</div>
                </div>
                <div class="ord-kpi" id="ord-kpi-zugestellt" style="--ord-kpi-color:#34d399;--ord-kpi-accent:rgba(52,211,153,.2)" onclick="ordSetFilter('Zugestellt')">
                    <div class="ord-kpi-glow" style="background:#34d399"></div>
                    <div class="ord-kpi-lbl">Zugestellt</div>
                    <div class="ord-kpi-val" id="ord-cnt-zugestellt">—</div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="ord-toolbar">
                <div class="ord-search-wrap">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input id="order-search" class="ord-search" placeholder="Bestellnr. oder E-Mail...">
                </div>
                <select id="status-filter" class="ord-fsel" onchange="ordSyncKpiFilter()">
                    <option value="">Alle Status</option>
                    <option value="Zahlung erwartet">Zahlung erwartet</option>
                    <option value="Wird bearbeitet">Wird bearbeitet</option>
                    <option value="Versendet">Versendet</option>
                    <option value="Zugestellt">Zugestellt</option>
                    <option value="Storniert">Storniert</option>
                </select>
                <span style="font-size:11px;color:var(--ord-muted)" id="ord-result-count"></span>
            </div>

            <!-- Table -->
            <div class="ord-table-card">
                <div class="ord-scroll">
                    <table class="ord-table">
                        <thead>
                            <tr>
                                <th style="text-align:left;padding-left:18px">Bestellnr.</th>
                                <th style="text-align:left">Datum</th>
                                <th style="text-align:left">Kunde</th>
                                <th style="text-align:right">Gesamt</th>
                                <th style="text-align:center">Status</th>
                                <th style="text-align:right;padding-right:18px">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody id="orders-tbody">
                            <tr><td colspan="6"><div class="ord-empty"><span class="eu-spinner"></span><br><br>Lade Bestellungen...</div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div><!-- /ord-shell -->
        <input type="file" id="csv-upload-orders" accept=".csv" class="hidden" onchange="importOrdersFromCSV(event)">
        </div>

        <!-- ORDER DETAIL DRAWER -->
        <div class="ord-overlay" id="ord-overlay" onclick="closeOrderModal()"></div>
        <div class="ord-drawer" id="ord-drawer">
            <div class="ord-drawer-hdr">
                <div>
                    <div style="font-size:10px;color:var(--ord-muted);letter-spacing:.08em;text-transform:uppercase;margin-bottom:3px">Bestellung</div>
                    <div class="ord-drawer-num" id="ord-d-num">#—</div>
                </div>
                <button class="ord-drawer-close" onclick="closeOrderModal()">✕</button>
            </div>
            <div class="ord-drawer-body">

                <!-- Meta -->
                <div class="ord-d-section">
                    <div class="ord-d-section-title">Übersicht</div>
                    <div class="ord-d-meta-grid">
                        <div class="ord-d-meta-item"><div class="ord-d-meta-lbl">Datum</div><div class="ord-d-meta-val" id="ord-d-date">—</div></div>
                        <div class="ord-d-meta-item"><div class="ord-d-meta-lbl">Kunde</div><div class="ord-d-meta-val" id="ord-d-email">—</div></div>
                        <div class="ord-d-meta-item"><div class="ord-d-meta-lbl">Straße</div><div class="ord-d-meta-val" id="ord-d-street">—</div></div>
                        <div class="ord-d-meta-item"><div class="ord-d-meta-lbl">PLZ / Stadt</div><div class="ord-d-meta-val" id="ord-d-city">—</div></div>
                    </div>
                </div>

                <!-- Items -->
                <div class="ord-d-section">
                    <div class="ord-d-section-title">Artikel</div>
                    <div id="ord-d-items"></div>
                    <div id="ord-d-discount" style="display:none;align-items:center;justify-content:space-between;padding:8px 14px;background:rgba(251,191,36,.06);border:1px solid rgba(251,191,36,.15);border-radius:10px;margin-top:6px">
                        <span style="font-size:11px;font-weight:700;color:rgba(251,191,36,.7)"><i class="fa-solid fa-tag" style="margin-right:5px"></i><span id="ord-d-discount-code">—</span></span>
                        <span style="font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;color:#fbbf24" id="ord-d-discount-val">−0,00 €</span>
                    </div>
                    <div id="ord-d-shipping-row" style="display:none;align-items:center;justify-content:space-between;padding:8px 14px;background:rgba(103,232,249,.04);border:1px solid rgba(103,232,249,.12);border-radius:10px;margin-top:6px">
                        <span style="font-size:11px;font-weight:700;color:rgba(103,232,249,.6)"><i class="fa-solid fa-truck" style="margin-right:5px"></i><span id="ord-d-shipping-label">Versand</span></span>
                        <span style="font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;color:#67e8f9" id="ord-d-shipping-val">0,00 €</span>
                    </div>
                    <div class="ord-d-total">
                        <span class="ord-d-total-lbl">GESAMT</span>
                        <span class="ord-d-total-val" id="ord-d-total">0,00 €</span>
                    </div>
                </div>

                <!-- Status selector -->
                <div class="ord-d-section">
                    <div class="ord-d-section-title">Status ändern</div>
                    <div class="ord-status-grid">
                        <div class="ord-status-opt" data-s="Zahlung erwartet" onclick="ordSelectStatus(this)">Zahlung erwartet</div>
                        <div class="ord-status-opt" data-s="Wird bearbeitet"  onclick="ordSelectStatus(this)">Wird bearbeitet</div>
                        <div class="ord-status-opt" data-s="Versendet"        onclick="ordSelectStatus(this)">Versendet</div>
                        <div class="ord-status-opt" data-s="Zugestellt"       onclick="ordSelectStatus(this)">Zugestellt</div>
                        <div class="ord-status-opt" data-s="Storniert"        onclick="ordSelectStatus(this)">Storniert</div>
                    </div>
                    <!-- hidden select kept for saveOrderChanges() compatibility -->
                    <select id="modal-status" style="display:none"></select>
                </div>

                <!-- Tracking -->
                <div class="ord-d-section">
                    <div class="ord-d-section-title">Versand & Tracking</div>
                    <div class="ord-d-grid2">
                        <div class="ord-d-field">
                            <label class="ord-d-label">Versanddienst</label>
                            <select id="modal-carrier" class="ord-d-input ord-d-select">
                                <option value="DHL">DHL</option>
                                <option value="Hermes">Hermes</option>
                                <option value="DPD">DPD</option>
                            </select>
                        </div>
                        <div class="ord-d-field">
                            <label class="ord-d-label">Tracking-Nummer</label>
                            <input id="modal-tracking" class="ord-d-input" placeholder="JD000000000000000000" onkeydown="if(event.key==='Enter')saveOrderChanges()">
                        </div>
                    </div>
                </div>

                <!-- KI E-Mail -->
                <div class="ord-d-section">
                    <div class="ord-d-section-title" style="display:flex;align-items:center;justify-content:space-between">
                        <span>KI-E-Mail-Entwurf</span>
                        <div style="display:flex;gap:6px;flex-wrap:wrap">
                            <button onclick="aiOrderEmail('delay')" class="ord-ai-email-btn" title="Verzögerung">⏳ Verzögerung</button>
                            <button onclick="aiOrderEmail('thanks')" class="ord-ai-email-btn" title="Dankeschön">🙏 Danke</button>
                            <button onclick="aiOrderEmail('question')" class="ord-ai-email-btn" title="Rückfrage">❓ Rückfrage</button>
                        </div>
                    </div>
                    <div id="ord-ai-email-result" style="display:none;margin-top:10px;padding:12px 14px;background:rgba(167,139,250,.07);border:1px solid rgba(167,139,250,.2);border-radius:12px;font-size:12px;color:rgba(255,255,255,.8);line-height:1.7;white-space:pre-wrap"></div>
                    <div id="ord-ai-email-actions" style="display:none;margin-top:8px;gap:8px">
                        <button onclick="aiEmailCopy()" style="padding:6px 14px;border-radius:8px;background:rgba(103,232,249,.12);border:1px solid rgba(103,232,249,.25);color:#67e8f9;font-size:11px;font-weight:700;cursor:pointer"><i class="fa-solid fa-copy" style="margin-right:5px"></i>Kopieren</button>
                        <button onclick="aiEmailIntoNotes()" style="padding:6px 14px;border-radius:8px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);color:#34d399;font-size:11px;font-weight:700;cursor:pointer"><i class="fa-solid fa-arrow-down" style="margin-right:5px"></i>In Notizen</button>
                    </div>
                </div>

                <!-- Customer Note -->
                <div class="ord-d-section" id="ord-d-note-section" style="display:none">
                    <div class="ord-d-section-title" style="color:#f59e0b">
                        <i class="fa-solid fa-comment-dots" style="margin-right:5px"></i>Kundenwunsch
                    </div>
                    <div id="ord-d-note" style="background:rgba(251,191,36,.06);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:10px 14px;font-size:12px;color:rgba(255,255,255,.8);line-height:1.6;white-space:pre-wrap"></div>
                </div>

                <!-- Notes -->
                <div class="ord-d-section">
                    <div class="ord-d-section-title">Interne Notizen</div>
                    <textarea id="modal-internal-notes" class="ord-d-input ord-d-textarea" placeholder="Nur für Admins sichtbar..."></textarea>
                </div>

            </div>
            <div class="ord-drawer-footer">
                <button class="ord-d-save-btn" onclick="saveOrderChanges()">
                    <i class="fa-solid fa-cloud-arrow-up"></i> Speichern
                </button>
                <button class="ord-d-del-btn" onclick="deleteOrder()">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </div>
        </div>

        <!-- TAB 2: BENUTZER v2 -->
        <div id="tab-content-2" class="hidden">
        <div class="usr-shell">

            <!-- KPI Strip -->
            <div class="usr-stats">
                <div class="usr-stat" style="--glow:#67e8f9">
                    <div class="usr-stat-glow" style="background:#67e8f9"></div>
                    <div class="usr-stat-lbl">Gesamt</div>
                    <div class="usr-stat-val" id="usr-kpi-total">—</div>
                </div>
                <div class="usr-stat">
                    <div class="usr-stat-glow" style="background:#34d399"></div>
                    <div class="usr-stat-lbl">Aktiv</div>
                    <div class="usr-stat-val" style="color:var(--usr-green)" id="usr-kpi-active">—</div>
                </div>
                <div class="usr-stat">
                    <div class="usr-stat-glow" style="background:#fbbf24"></div>
                    <div class="usr-stat-lbl">Ø Punkte</div>
                    <div class="usr-stat-val" style="color:var(--usr-amber)" id="usr-kpi-pts">—</div>
                </div>
                <div class="usr-stat">
                    <div class="usr-stat-glow" style="background:#f87171"></div>
                    <div class="usr-stat-lbl">Gesperrt</div>
                    <div class="usr-stat-val" style="color:var(--usr-red)" id="usr-kpi-blocked">—</div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="usr-toolbar">
                <div class="usr-search-wrap">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input class="usr-search" id="user-search" placeholder="E-Mail oder Username suchen...">
                </div>
                <button class="usr-btn usr-btn-green"  onclick="exportUsersToCSV()"><i class="fa-solid fa-file-csv"></i> Export</button>
                <button class="usr-btn usr-btn-amber"  onclick="document.getElementById('csv-upload-users').click()"><i class="fa-solid fa-file-import"></i> Import</button>
                <button class="usr-btn" id="usr-ai-churn-btn" onclick="aiChurnAnalysis()" style="background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.3);color:#a78bfa"><i class="fa-solid fa-wand-magic-sparkles"></i> KI-Churn-Analyse</button>
                <button class="usr-btn usr-btn-ghost"  id="usr-count-badge" style="cursor:default;pointer-events:none">— User</button>
            </div>

            <!-- KI Churn-Analyse Ergebnis -->
            <div id="usr-ai-churn-result" style="display:none;background:rgba(167,139,250,.07);border:1px solid rgba(167,139,250,.2);border-radius:16px;padding:18px 20px;margin-bottom:4px"></div>

            <!-- Table -->
            <div class="usr-table-card">
                <div class="usr-scroll">
                    <table class="usr-table">
                        <thead>
                            <tr>
                                <th style="text-align:left;padding-left:18px">Benutzer</th>
                                <th style="text-align:center">Referral</th>
                                <th style="text-align:center">Punkte</th>
                                <th style="text-align:center">IP-Adresse</th>
                                <th style="text-align:center">Gratis&shy;versand</th>
                                <th style="text-align:center">Status</th>
                                <th style="text-align:right;padding-right:18px">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody id="users-tbody">
                            <tr><td colspan="7"><div class="usr-empty"><span class="eu-spinner"></span><br><br>Lade Benutzer...</div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="usr-danger-zone">
                <div>
                    <div style="font-size:13px;font-weight:700;color:var(--usr-red);margin-bottom:3px"><i class="fa-solid fa-triangle-exclamation" style="margin-right:6px"></i>Danger Zone</div>
                    <div class="usr-danger-label">Setzt alle Loyalty-Punkte aller User auf 0. Nicht rückgängig machbar.</div>
                </div>
                <button class="usr-btn usr-btn-red" onclick="resetAllLoyaltyPoints()" style="padding:10px 18px;font-size:12px">
                    <i class="fa-solid fa-rotate-left"></i> Alle Punkte zurücksetzen
                </button>
            </div>

        </div><!-- /usr-shell -->
        <input type="file" id="csv-upload-users" accept=".csv" class="hidden" onchange="importUsersFromCSV(event)">
        </div>

        <!-- TAB 3: KATEGORIEN v2 -->
        <div id="tab-content-3" class="hidden">

            <!-- Page header -->
            <div class="cat-page-hdr">
                <div class="cat-page-title"><i class="fa-solid fa-tags"></i> Kategorien</div>
                <span class="cat-count-badge" id="cat-total-badge">— Kategorien</span>
            </div>

            <div class="cat-shell">

                <!-- ── Create form (left, sticky) ── -->
                <div class="cat-create">
                    <div class="cat-create-hdr">
                        <div class="cat-create-icon"><i class="fa-solid fa-plus"></i></div>
                        <div class="cat-create-title">Neue Kategorie</div>
                    </div>
                    <form id="add-category-form" class="cat-form">
                        <div class="cat-field">
                            <label class="cat-label">Name</label>
                            <input id="cat-name" class="cat-input" placeholder="z.B. Sommer Specials" required>
                        </div>
                        <div class="cat-field">
                            <label class="cat-label">Sortierposition</label>
                            <input id="cat-order" type="number" class="cat-input cat-input-num" value="10" required>
                            <span class="cat-input-hint">Niedrige Zahl = weiter oben im Shop</span>
                        </div>
                        <div class="cat-toggle-row">
                            <div>
                                <div class="cat-toggle-lbl">Angebot aktiv</div>
                                <div class="cat-toggle-sub">Zeigt Badge + Aktion im Shop</div>
                            </div>
                            <label class="cat-sw">
                                <input type="checkbox" id="cat-special" onchange="catToggleOfferBox('cat-offer-box-add', this.checked)">
                                <span class="cat-sw-sl"></span>
                            </label>
                        </div>
                        <div class="cat-offer-box" id="cat-offer-box-add">
                            <div class="cat-offer-label">Angebotstyp</div>
                            <div class="cat-offer-type-row" id="cat-offer-type-row-add">
                                <button type="button" class="cat-offer-type-btn active" data-type="nforn" onclick="catSelectOfferType('add',this)">X für N</button>
                                <button type="button" class="cat-offer-type-btn" data-type="percent" onclick="catSelectOfferType('add',this)">% Rabatt</button>
                                <button type="button" class="cat-offer-type-btn" data-type="fixed" onclick="catSelectOfferType('add',this)">Fester Rabatt €</button>
                                <button type="button" class="cat-offer-type-btn" data-type="badge" onclick="catSelectOfferType('add',this)">Nur Badge-Text</button>
                            </div>
                            <div id="cat-offer-config-add">
                                <div class="cat-offer-label" style="margin-top:6px">Konfiguration</div>
                                <div id="cat-offer-fields-add" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px"></div>
                            </div>
                            <div style="display:flex;align-items:center;gap:8px;margin-top:4px">
                                <div class="cat-offer-label">Badge-Text:</div>
                                <input class="cat-offer-input" id="cat-badge-text-add" placeholder="z.B. 4 FÜR 3" style="flex:1">
                            </div>
                            <div id="cat-offer-preview-add" class="cat-offer-preview">Vorschau: –</div>
                        </div>
                        <input type="hidden" id="cat-offer-type-val-add" value="nforn">
                        <input type="hidden" id="cat-offer-n-add" value="4">
                        <input type="hidden" id="cat-offer-m-add" value="3">
                        <button type="submit" class="cat-submit">
                            <i class="fa-solid fa-tag"></i> Kategorie erstellen
                        </button>
                    </form>
                </div>

                <!-- ── Category list (right) ── -->
                <div class="cat-list-panel">
                    <div class="cat-list-hdr">
                        <div class="cat-list-title">
                            <i class="fa-solid fa-layer-group" style="color:var(--cat-cyan)"></i>
                            Alle Kategorien
                        </div>
                        <div style="display:flex;gap:8px;align-items:center">
                            <button class="cat-seed-btn" onclick="seedDefaultCategories()">
                                <i class="fa-solid fa-wand-magic-sparkles"></i> Standard laden
                            </button>
                        </div>
                    </div>

                    <!-- Inline edit panel (hidden by default) -->
                    <div class="cat-edit-panel" id="cat-edit-panel">
                        <div class="cat-edit-title"><i class="fa-solid fa-pen"></i> Kategorie bearbeiten</div>
                        <div class="cat-edit-grid">
                            <div class="cat-field">
                                <label class="cat-label">Name</label>
                                <input id="edit-cat-name" class="cat-input" placeholder="Name">
                            </div>
                            <div class="cat-field">
                                <label class="cat-label">Position</label>
                                <input id="edit-cat-order" type="number" class="cat-input cat-input-num">
                            </div>
                            <div class="cat-toggle-row" style="align-self:end">
                                <div>
                                    <div class="cat-toggle-lbl" style="font-size:11px">Angebot aktiv</div>
                                </div>
                                <label class="cat-sw">
                                    <input type="checkbox" id="edit-cat-special" onchange="catToggleOfferBox('cat-offer-box-edit', this.checked)">
                                    <span class="cat-sw-sl"></span>
                                </label>
                            </div>
                            <div style="display:flex;gap:6px;align-self:end">
                                <button class="cat-edit-save" id="cat-edit-save-btn" onclick="catSaveInlineEdit()">
                                    <i class="fa-solid fa-check"></i> Speichern
                                </button>
                                <button class="cat-edit-cancel" onclick="catCloseInlineEdit()">✕</button>
                            </div>
                        </div>
                        <div class="cat-offer-box" id="cat-offer-box-edit" style="margin-top:8px">
                            <div class="cat-offer-label">Angebotstyp</div>
                            <div class="cat-offer-type-row" id="cat-offer-type-row-edit">
                                <button type="button" class="cat-offer-type-btn active" data-type="nforn" onclick="catSelectOfferType('edit',this)">X für N</button>
                                <button type="button" class="cat-offer-type-btn" data-type="percent" onclick="catSelectOfferType('edit',this)">% Rabatt</button>
                                <button type="button" class="cat-offer-type-btn" data-type="fixed" onclick="catSelectOfferType('edit',this)">Fester Rabatt €</button>
                                <button type="button" class="cat-offer-type-btn" data-type="badge" onclick="catSelectOfferType('edit',this)">Nur Badge-Text</button>
                            </div>
                            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px" id="cat-offer-fields-edit"></div>
                            <div style="display:flex;align-items:center;gap:8px;margin-top:4px">
                                <div class="cat-offer-label">Badge-Text:</div>
                                <input class="cat-offer-input" id="cat-badge-text-edit" placeholder="z.B. 4 FÜR 3" style="flex:1">
                            </div>
                            <div id="cat-offer-preview-edit" class="cat-offer-preview">Vorschau: –</div>
                        </div>
                        <input type="hidden" id="cat-offer-type-val-edit" value="nforn">
                        <input type="hidden" id="cat-offer-n-edit" value="4">
                        <input type="hidden" id="cat-offer-m-edit" value="3">
                    </div>

                    <div class="cat-grid" id="cat-grid">
                        <div class="cat-empty"><span class="eu-spinner"></span><br><br>Lade Kategorien...</div>
                    </div>
                </div>

            </div><!-- /cat-shell -->
        </div>

        <!-- TAB 4: GUTSCHEINE v2 -->
        <div id="tab-content-4" class="hidden">

            <!-- Page header (full width, above grid) -->
            <div class="cpn-page-hdr">
                <div class="cpn-page-title"><i class="fa-solid fa-ticket"></i> Gutschein-Manager</div>
                <span class="cpn-count-badge" id="cpn-total-badge">— Gutscheine</span>
            </div>

            <div class="cpn-shell">

                <!-- ── Create form (left column, sticky) ── -->
                <div class="cpn-create">
                    <div class="cpn-create-hdr" style="flex-direction:column;align-items:stretch;gap:10px">
                        <div style="display:flex;align-items:center;gap:10px">
                            <div class="cpn-create-icon"><i class="fa-solid fa-plus"></i></div>
                            <div class="cpn-create-title">Gutschein erstellen</div>
                        </div>
                        <!-- Mode switcher -->
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">
                            <button type="button" id="cpn-mode-single" onclick="cpnSwitchMode('single')"
                                style="padding:8px;border-radius:9px;border:1px solid rgba(251,191,36,.4);background:rgba(251,191,36,.12);color:#fbbf24;font-size:11px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px">
                                <i class="fa-solid fa-ticket"></i> Einzeln
                            </button>
                            <button type="button" id="cpn-mode-bulk" onclick="cpnSwitchMode('bulk')"
                                style="padding:8px;border-radius:9px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);color:rgba(255,255,255,.4);font-size:11px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px">
                                <i class="fa-solid fa-layer-group"></i> Bulk Generator
                            </button>
                        </div>
                    </div>
                    <form id="add-coupon-form" class="cpn-form">

                        <div class="cpn-field">
                            <label class="cpn-label">Code</label>
                            <input id="coupon-code" class="cpn-input" placeholder="SUMMER25" style="text-transform:uppercase;letter-spacing:.08em" required>
                        </div>

                        <div class="cpn-field">
                            <label class="cpn-label">Rabatt-Typ</label>
                            <div class="cpn-type-toggle" id="cpn-type-toggle">
                                <div class="cpn-type-opt active" data-val="percent" onclick="cpnSelectType('percent',this)"><i class="fa-solid fa-percent" style="margin-right:5px"></i> Prozent</div>
                                <div class="cpn-type-opt"        data-val="fixed"   onclick="cpnSelectType('fixed',this)"><i class="fa-solid fa-euro-sign" style="margin-right:5px"></i> Festbetrag</div>
                            </div>
                            <!-- hidden select for form submit -->
                            <select id="coupon-type" style="display:none"><option value="percent">Prozent</option><option value="fixed">Festbetrag €</option></select>
                        </div>

                        <div class="cpn-field-row">
                            <div class="cpn-field">
                                <label class="cpn-label">Wert</label>
                                <input id="coupon-value" type="number" step="0.01" class="cpn-input" placeholder="10" required>
                            </div>
                            <div class="cpn-field">
                                <label class="cpn-label">Ablaufdatum</label>
                                <input id="coupon-expiry" type="date" class="cpn-input" required>
                            </div>
                        </div>

                        <div class="cpn-toggle-row">
                            <div>
                                <div class="cpn-toggle-lbl">Einmalnutzung</div>
                                <div class="cpn-toggle-sub">Nur 1× pro User einlösbar</div>
                            </div>
                            <label class="cpn-sw">
                                <input type="checkbox" id="coupon-onetime">
                                <span class="cpn-sw-sl"></span>
                            </label>
                        </div>

                        <div class="cpn-toggle-row" style="background:rgba(251,191,36,.04);border:1px solid rgba(251,191,36,.12);border-radius:12px;padding:10px 14px;margin-top:-4px">
                            <div>
                                <div class="cpn-toggle-lbl" style="display:flex;align-items:center;gap:6px">
                                    <i class="fa-solid fa-globe" style="font-size:11px;color:#fbbf24"></i>
                                    Global nur 1× einlösbar
                                </div>
                                <div class="cpn-toggle-sub">Code kann insgesamt nur <strong style="color:rgba(255,255,255,.5)">einmal</strong> genutzt werden — egal von wem</div>
                            </div>
                            <label class="cpn-sw">
                                <input type="checkbox" id="coupon-global-once">
                                <span class="cpn-sw-sl"></span>
                            </label>
                        </div>

                        <!-- NEU-02 FIX: maxUsages-Feld — war bisher nur über Firestore direkt setzbar -->
                        <div class="cpn-field" style="margin-top:6px">
                            <label class="cpn-label" style="display:flex;justify-content:space-between;align-items:center">
                                Max. Einlösungen gesamt
                                <span style="font-size:10px;color:rgba(255,255,255,.3);font-weight:400">leer = unbegrenzt</span>
                            </label>
                            <input id="coupon-maxusages" type="number" min="1" class="cpn-input" placeholder="z.B. 50">
                        </div>

                        <button type="submit" class="cpn-submit">
                            <i class="fa-solid fa-ticket"></i> Gutschein erstellen
                        </button>

                        <!-- KI Gutschein-Beratung -->
                        <div style="margin-top:16px;padding:14px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.18);border-radius:12px">
                            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:10px">
                                <div style="font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:#a78bfa;display:flex;align-items:center;gap:6px"><i class="fa-solid fa-wand-magic-sparkles"></i> KI-Beratung</div>
                                <div style="display:flex;gap:6px;flex-wrap:wrap">
                                    <button onclick="aiCouponAdvice('winback')" class="ord-ai-email-btn">🔄 Rückgewinnung</button>
                                    <button onclick="aiCouponAdvice('firstorder')" class="ord-ai-email-btn">🆕 Erstbestellung</button>
                                    <button onclick="aiCouponAdvice('vip')" class="ord-ai-email-btn">⭐ VIP-Belohnung</button>
                                </div>
                            </div>
                            <div id="cpn-ai-result" style="font-size:12px;color:rgba(255,255,255,.35);line-height:1.6">← Ziel wählen für KI-Empfehlung zu Rabatt, Gültigkeitsdauer und Nutzungstyp.</div>
                        </div>
                    </form>

                    <!-- ══════════════════════════════════════════════
                         BULK GENERATOR PANEL
                    ══════════════════════════════════════════════ -->
                    <div id="cpn-bulk-panel" class="cpn-form" style="display:none">

                        <!-- Info banner -->
                        <div style="display:flex;align-items:flex-start;gap:10px;padding:11px 13px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.2);border-radius:11px">
                            <i class="fa-solid fa-layer-group" style="color:#a78bfa;margin-top:2px;flex-shrink:0;font-size:13px"></i>
                            <div style="font-size:11px;color:rgba(255,255,255,.6);line-height:1.55">
                                Generiert mehrere eindeutige Codes auf einmal.<br>
                                <strong style="color:#a78bfa">Jeder Code ist nur einmal einlösbar</strong> — genau 1 Person, 1 Mal.
                            </div>
                        </div>

                        <!-- Prefix + Count -->
                        <div class="cpn-field-row">
                            <div class="cpn-field">
                                <label class="cpn-label">Prefix</label>
                                <input id="bulk-prefix" class="cpn-input" placeholder="WAVE" maxlength="10"
                                    style="text-transform:uppercase;letter-spacing:.08em"
                                    oninput="this.value=this.value.toUpperCase().replace(/[^A-Z0-9]/g,'');cpnBulkPreview()">
                            </div>
                            <div class="cpn-field">
                                <label class="cpn-label">Anzahl</label>
                                <select id="bulk-count" class="cpn-input cpn-select" onchange="cpnBulkPreview()">
                                    <option value="5">5 Codes</option>
                                    <option value="10" selected>10 Codes</option>
                                    <option value="25">25 Codes</option>
                                    <option value="50">50 Codes</option>
                                    <option value="100">100 Codes</option>
                                </select>
                            </div>
                        </div>

                        <!-- Type toggle -->
                        <div class="cpn-field">
                            <label class="cpn-label">Rabatt-Typ</label>
                            <div class="cpn-type-toggle" id="bulk-type-toggle">
                                <div class="cpn-type-opt active" data-val="percent" onclick="cpnBulkSelectType('percent',this)"><i class="fa-solid fa-percent" style="margin-right:5px"></i> Prozent</div>
                                <div class="cpn-type-opt"        data-val="fixed"   onclick="cpnBulkSelectType('fixed',this)"><i class="fa-solid fa-euro-sign" style="margin-right:5px"></i> Festbetrag</div>
                            </div>
                            <select id="bulk-type" style="display:none"><option value="percent">Prozent</option><option value="fixed">Festbetrag €</option></select>
                        </div>

                        <!-- Value + Expiry -->
                        <div class="cpn-field-row">
                            <div class="cpn-field">
                                <label class="cpn-label">Wert</label>
                                <input id="bulk-value" type="number" step="0.01" min="0.01" class="cpn-input" placeholder="10" required>
                            </div>
                            <div class="cpn-field">
                                <label class="cpn-label">Ablaufdatum</label>
                                <input id="bulk-expiry" type="date" class="cpn-input" required>
                            </div>
                        </div>

                        <!-- Single-use lock (always on, shown as info) -->
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 13px;background:rgba(167,139,250,.08);border:1px solid rgba(167,139,250,.25);border-radius:10px">
                            <div>
                                <div class="cpn-toggle-lbl" style="color:#a78bfa;font-weight:700">
                                    <i class="fa-solid fa-lock" style="margin-right:5px;font-size:11px"></i>Nur 1× einlösbar — global
                                </div>
                                <div class="cpn-toggle-sub">Jeder Code kann nur von <strong style="color:rgba(255,255,255,.5)">einer einzigen Person</strong> einmal genutzt werden</div>
                            </div>
                            <i class="fa-solid fa-circle-check" style="color:#a78bfa;font-size:18px;flex-shrink:0"></i>
                        </div>

                        <!-- Preview line -->
                        <div id="bulk-preview-line" style="font-size:11px;color:rgba(255,255,255,.3);font-family:'JetBrains Mono',monospace;text-align:center;padding:4px 0">
                            z.B. WAVE-A3F9K2, WAVE-X7BQ81, …
                        </div>

                        <!-- Generate button -->
                        <button type="button" onclick="cpnBulkGenerate()"
                            style="width:100%;padding:13px;background:linear-gradient(135deg,rgba(167,139,250,.2),rgba(139,92,246,.12));border:1px solid rgba(167,139,250,.4);border-radius:12px;font-weight:700;font-size:12px;letter-spacing:.05em;color:#a78bfa;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .25s"
                            onmouseover="this.style.background='linear-gradient(135deg,rgba(167,139,250,.3),rgba(139,92,246,.2))'"
                            onmouseout="this.style.background='linear-gradient(135deg,rgba(167,139,250,.2),rgba(139,92,246,.12))'">
                            <i class="fa-solid fa-layer-group"></i> <span id="bulk-btn-label">Codes generieren</span>
                        </button>

                        <!-- Result panel (hidden until generated) -->
                        <div id="bulk-result-panel" style="display:none;flex-direction:column;gap:10px">
                            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
                                <div style="font-size:11px;font-weight:700;color:#a78bfa;display:flex;align-items:center;gap:6px">
                                    <i class="fa-solid fa-circle-check"></i>
                                    <span id="bulk-result-title">— Codes erstellt</span>
                                </div>
                                <div style="display:flex;gap:6px">
                                    <button type="button" onclick="cpnBulkCopyAll()"
                                        style="padding:6px 12px;border-radius:8px;border:1px solid rgba(167,139,250,.3);background:rgba(167,139,250,.08);color:#a78bfa;font-size:11px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .2s"
                                        onmouseover="this.style.background='rgba(167,139,250,.16)'" onmouseout="this.style.background='rgba(167,139,250,.08)'">
                                        <i class="fa-solid fa-copy"></i> Alle kopieren
                                    </button>
                                    <button type="button" onclick="cpnBulkDownloadCSV()"
                                        style="padding:6px 12px;border-radius:8px;border:1px solid rgba(52,211,153,.3);background:rgba(52,211,153,.08);color:#34d399;font-size:11px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .2s"
                                        onmouseover="this.style.background='rgba(52,211,153,.16)'" onmouseout="this.style.background='rgba(52,211,153,.08)'">
                                        <i class="fa-solid fa-download"></i> CSV
                                    </button>
                                </div>
                            </div>
                            <!-- Code list -->
                            <div id="bulk-code-list"
                                style="max-height:220px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding-right:4px">
                            </div>
                        </div>

                    </div><!-- /cpn-bulk-panel -->

                </div>

                <!-- ── Coupons list (right column) ── -->
                <div class="cpn-list-panel">
                    <div class="cpn-list-hdr">
                        <div class="cpn-list-title">
                            <i class="fa-solid fa-list" style="color:var(--cpn-amber)"></i>
                            Alle Gutscheine
                        </div>
                        <div style="display:flex;align-items:center;gap:8px">
                            <div class="cpn-search-wrap">
                                <i class="fa-solid fa-magnifying-glass"></i>
                                <input class="cpn-search" id="cpn-search" placeholder="Code suchen..." oninput="cpnFilterRender()">
                            </div>
                        </div>
                    </div>
                    <div class="cpn-grid" id="cpn-grid">
                        <div class="cpn-empty"><span class="eu-spinner"></span><br><br>Lade Gutscheine...</div>
                    </div>
                </div>

            </div><!-- /cpn-shell -->

        </div>

        <!-- COUPON HISTORY DRAWER -->
        <div class="cpn-overlay" id="cpn-overlay" onclick="cpnCloseHistory()"></div>
        <div class="cpn-hist-drawer" id="cpn-hist-drawer">
            <div class="cpn-hist-hdr">
                <div>
                    <div style="font-size:9px;color:var(--cpn-muted);letter-spacing:.08em;text-transform:uppercase;margin-bottom:2px">Einlösungs-History</div>
                    <div class="cpn-hist-title" id="cpn-hist-code" style="color:var(--cpn-amber)">—</div>
                </div>
                <button class="cpn-hist-close" onclick="cpnCloseHistory()">✕</button>
            </div>
            <div class="cpn-hist-meta">
                <div class="cpn-hist-stat">
                    <div class="cpn-hist-stat-val" id="cpn-hist-stat-uses">—</div>
                    <div class="cpn-hist-stat-lbl">Eingelöst</div>
                </div>
                <div style="width:1px;background:rgba(255,255,255,.07);margin:0 6px"></div>
                <div class="cpn-hist-stat">
                    <div class="cpn-hist-stat-val" id="cpn-hist-stat-val">—</div>
                    <div class="cpn-hist-stat-lbl">Rabatt</div>
                </div>
                <div style="width:1px;background:rgba(255,255,255,.07);margin:0 6px"></div>
                <div class="cpn-hist-stat">
                    <div class="cpn-hist-stat-val" id="cpn-hist-stat-exp" style="font-size:13px">—</div>
                    <div class="cpn-hist-stat-lbl">Ablauf</div>
                </div>
            </div>
            <div class="cpn-hist-body" id="cpn-hist-body">
                <div class="cpn-hist-empty"><i class="fa-solid fa-clock-rotate-left"></i>Keine Einlösungen</div>
            </div>
        </div>

        <!-- TAB 5: ANALYTICS v2 -->
        <div id="tab-content-5" class="hidden">

            <!-- Header + Period Selector -->
            <div class="an-header">
                <div class="an-title"><i class="fa-solid fa-chart-line"></i> Analytics Dashboard</div>
                <div class="an-period-bar">
                    <button class="an-period-btn active" id="an-btn-7"  onclick="anSetPeriod(7)">7T</button>
                    <button class="an-period-btn"        id="an-btn-30" onclick="anSetPeriod(30)">30T</button>
                    <button class="an-period-btn"        id="an-btn-90" onclick="anSetPeriod(90)">90T</button>
                    <div style="display:flex;align-items:center;gap:6px;margin-left:4px">
                        <input type="date" id="an-date-from" class="an-period-btn" style="font-family:'JetBrains Mono',monospace;font-size:11px;cursor:pointer;padding:6px 10px" onchange="anSetCustomRange()">
                        <span style="font-size:10px;color:rgba(255,255,255,.3)">–</span>
                        <input type="date" id="an-date-to"   class="an-period-btn" style="font-family:'JetBrains Mono',monospace;font-size:11px;cursor:pointer;padding:6px 10px" onchange="anSetCustomRange()">
                    </div>
                </div>
            </div>

            <!-- KPI Strip -->
            <div class="an-kpi-strip">
                <div class="an-kpi" style="background:linear-gradient(135deg,#0e1f1a,#111b18);--an-accent:rgba(52,211,153,.22);--an-glow:#34d399;--an-color:#34d399">
                    <div class="an-kpi-glow"></div>
                    <div class="an-kpi-icon-bg"><i class="fa-solid fa-euro-sign"></i></div>
                    <div class="an-kpi-label">Gesamtumsatz</div>
                    <div class="an-kpi-value" id="metric-revenue">—</div>
                    <div class="an-kpi-delta an-delta-neu" id="an-rev-delta"><i class="fa-solid fa-clock-rotate-left"></i> <span id="an-period-lbl">7 Tage</span></div>
                </div>
                <div class="an-kpi" style="background:linear-gradient(135deg,#0d1a1f,#101c22);--an-accent:rgba(103,232,249,.22);--an-glow:#67e8f9;--an-color:#67e8f9">
                    <div class="an-kpi-glow"></div>
                    <div class="an-kpi-icon-bg"><i class="fa-solid fa-receipt"></i></div>
                    <div class="an-kpi-label">Bestellungen</div>
                    <div class="an-kpi-value" id="metric-orders">—</div>
                    <div class="an-kpi-delta an-delta-neu"><i class="fa-solid fa-arrow-trend-up"></i> Zeitraum</div>
                </div>
                <div class="an-kpi" style="background:linear-gradient(135deg,#12101f,#15111f);--an-accent:rgba(167,139,250,.22);--an-glow:#a78bfa;--an-color:#a78bfa">
                    <div class="an-kpi-glow"></div>
                    <div class="an-kpi-icon-bg"><i class="fa-solid fa-users"></i></div>
                    <div class="an-kpi-label">Unique Kunden</div>
                    <div class="an-kpi-value" id="metric-users">—</div>
                    <div class="an-kpi-delta an-delta-neu"><i class="fa-solid fa-user-check"></i> mit Bestellung</div>
                </div>
                <div class="an-kpi" style="background:linear-gradient(135deg,#1a160a,#1f1b0d);--an-accent:rgba(251,191,36,.22);--an-glow:#fbbf24;--an-color:#fbbf24">
                    <div class="an-kpi-glow"></div>
                    <div class="an-kpi-icon-bg"><i class="fa-solid fa-cart-shopping"></i></div>
                    <div class="an-kpi-label">Ø Warenkorb</div>
                    <div class="an-kpi-value" id="metric-avg">—</div>
                    <div class="an-kpi-delta an-delta-neu"><i class="fa-solid fa-chart-bar"></i> pro Bestellung</div>
                </div>
            </div>

            <!-- Charts Row 1: Revenue (wide) -->
            <div class="an-chart-grid">
                <div class="an-chart-card wide">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-euro-sign" style="color:#34d399"></i> Umsatz-Verlauf</div>
                        <span class="an-chart-badge" id="an-rev-badge">7 Tage</span>
                    </div>
                    <div class="an-chart-inner tall"><canvas id="revenueChart"></canvas></div>
                </div>
            </div>

            <!-- Charts Row 2: Orders + Status -->
            <div class="an-chart-grid">
                <div class="an-chart-card">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-cart-shopping" style="color:#67e8f9"></i> Bestellungen pro Tag</div>
                        <span class="an-chart-badge">Zeitreihe</span>
                    </div>
                    <div class="an-chart-inner"><canvas id="dailyOrdersChart"></canvas></div>
                </div>
                <div class="an-chart-card">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-circle-half-stroke" style="color:#a78bfa"></i> Bestellstatus-Verteilung</div>
                        <span class="an-chart-badge" id="an-status-total-badge">gesamt</span>
                    </div>
                    <div style="padding-top:8px" id="an-status-list"></div>
                </div>
            </div>

            <!-- Charts Row 3: Top Products + Referrer -->
            <div class="an-chart-grid">
                <div class="an-chart-card">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-trophy" style="color:#fbbf24"></i> Top 10 Produkte</div>
                        <span class="an-chart-badge">nach Stückzahl</span>
                    </div>
                    <div class="an-prod-list" id="an-prod-list" style="max-height:290px;overflow-y:auto"></div>
                </div>
                <div class="an-chart-card">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-share-nodes" style="color:#f472b6"></i> Top Referrer</div>
                        <span class="an-chart-badge">geworbene Freunde</span>
                    </div>
                    <div class="an-chart-inner"><canvas id="referralChart"></canvas></div>
                </div>
            </div>

            <!-- Charts Row 4: Umsatz nach Kategorie + Wochentag-Heatmap (NEU) -->
            <div class="an-chart-grid" style="margin-top:16px">
                <div class="an-chart-card">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-layer-group" style="color:#67e8f9"></i> Umsatz nach Kategorie</div>
                        <span class="an-chart-badge">Zeitraum</span>
                    </div>
                    <div class="an-chart-inner"><canvas id="categoryRevenueChart"></canvas></div>
                </div>
                <div class="an-chart-card">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-fire" style="color:#fb923c"></i> Bestellungen nach Wochentag</div>
                        <span class="an-chart-badge">Ø pro Tag</span>
                    </div>
                    <div class="an-chart-inner"><canvas id="weekdayChart"></canvas></div>
                </div>
            </div>

            <!-- Charts Row 5: Wiederkäufer + Ø Tage zwischen Bestellungen (NEU) -->
            <div class="an-chart-grid" style="margin-top:16px">
                <div class="an-chart-card wide">
                    <div class="an-chart-hdr">
                        <div class="an-chart-title"><i class="fa-solid fa-rotate" style="color:#34d399"></i> Neue vs. Wiederkehrende Kunden</div>
                        <span class="an-chart-badge">Zeitreihe</span>
                    </div>
                    <div class="an-chart-inner"><canvas id="newVsReturnChart"></canvas></div>
                </div>
            </div>

            <!-- ═══════════════════════════════════════════════
                 PUSH-BENACHRICHTIGUNGEN CENTER
            ═══════════════════════════════════════════════ -->
            <div style="margin-top:16px;background:#13131f;border:1px solid rgba(251,191,36,.2);border-radius:22px;overflow:hidden">

                <!-- Header mit KPI-Leiste -->
                <div style="background:linear-gradient(135deg,rgba(251,191,36,.08),rgba(251,191,36,.02));border-bottom:1px solid rgba(251,191,36,.15);padding:18px 22px">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px">
                        <div style="display:flex;align-items:center;gap:12px">
                            <div style="width:40px;height:40px;border-radius:12px;background:rgba(251,191,36,.15);border:1px solid rgba(251,191,36,.3);display:flex;align-items:center;justify-content:center;color:#fbbf24;font-size:18px">
                                <i class="fa-solid fa-bell"></i>
                            </div>
                            <div>
                                <div style="font-family:'Orbitron',sans-serif;font-size:15px;font-weight:700;color:#fbbf24;letter-spacing:.04em">Push-Benachrichtigungen</div>
                                <div style="font-size:11px;color:rgba(255,255,255,.35);margin-top:2px">Gezielte Nachrichten an Kunden senden</div>
                            </div>
                        </div>
                        <button onclick="pushRefreshStats()" style="display:flex;align-items:center;gap:6px;padding:7px 14px;border-radius:10px;background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.2);color:#fbbf24;font-size:11px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(251,191,36,.2)'" onmouseout="this.style.background='rgba(251,191,36,.1)'">
                            <i class="fa-solid fa-rotate-right"></i> Aktualisieren
                        </button>
                    </div>
                    <!-- KPI Strip -->
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px">
                        <div style="background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:12px 14px">
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Abonnenten</div>
                            <div id="push-kpi-subs" style="font-size:22px;font-weight:700;color:#fbbf24;font-family:'JetBrains Mono',monospace">—</div>
                        </div>
                        <div style="background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:12px 14px">
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Versendet (gesamt)</div>
                            <div id="push-kpi-sent" style="font-size:22px;font-weight:700;color:#67e8f9;font-family:'JetBrains Mono',monospace">—</div>
                        </div>
                        <div style="background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:12px 14px">
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Letzte 7 Tage</div>
                            <div id="push-kpi-week" style="font-size:22px;font-weight:700;color:#a78bfa;font-family:'JetBrains Mono',monospace">—</div>
                        </div>
                        <div style="background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:12px 14px">
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Zugestellt</div>
                            <div id="push-kpi-delivered" style="font-size:22px;font-weight:700;color:#34d399;font-family:'JetBrains Mono',monospace">—</div>
                        </div>
                    </div>
                </div>

                <!-- Tab-Navigation -->
                <div style="display:flex;border-bottom:1px solid rgba(255,255,255,.06)">
                    <button id="push-tab-compose" onclick="pushSwitchTab('compose')" style="flex:1;padding:12px;font-size:12px;font-weight:600;background:rgba(251,191,36,.08);border:none;border-bottom:2px solid #fbbf24;color:#fbbf24;cursor:pointer;transition:all .2s">
                        <i class="fa-solid fa-pen-to-square"></i> Neue Nachricht
                    </button>
                    <button id="push-tab-templates" onclick="pushSwitchTab('templates')" style="flex:1;padding:12px;font-size:12px;font-weight:600;background:transparent;border:none;border-bottom:2px solid transparent;color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s">
                        <i class="fa-solid fa-layer-group"></i> Vorlagen
                    </button>
                    <button id="push-tab-history" onclick="pushSwitchTab('history')" style="flex:1;padding:12px;font-size:12px;font-weight:600;background:transparent;border:none;border-bottom:2px solid transparent;color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s">
                        <i class="fa-solid fa-clock-rotate-left"></i> Verlauf
                    </button>
                    <button id="push-tab-subscribers" onclick="pushSwitchTab('subscribers')" style="flex:1;padding:12px;font-size:12px;font-weight:600;background:transparent;border:none;border-bottom:2px solid transparent;color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s">
                        <i class="fa-solid fa-users"></i> Abonnenten
                    </button>
                </div>

                <!-- TAB: NEUE NACHRICHT -->
                <div id="push-panel-compose" style="padding:20px;display:flex;flex-direction:column;gap:14px">

                    <!-- Vorschau -->
                    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:14px;display:flex;gap:12px;align-items:flex-start">
                        <div style="width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#0a0a0a,#1a1a2e);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">🌊</div>
                        <div style="flex:1;min-width:0">
                            <div id="push-preview-title" style="font-size:13px;font-weight:700;color:#fff;margin-bottom:3px">Titel der Benachrichtigung</div>
                            <div id="push-preview-body" style="font-size:11px;color:rgba(255,255,255,.5);line-height:1.5">Nachricht erscheint hier…</div>
                        </div>
                        <div style="font-size:9px;color:rgba(255,255,255,.25);flex-shrink:0">jetzt</div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                        <div>
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Titel *</div>
                            <input id="push-title" placeholder="z.B. 🔥 Neue Aktion!" oninput="pushUpdatePreview()" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 13px;color:#fff;font-size:13px;outline:none;box-sizing:border-box;transition:border-color .2s" onfocus="this.style.borderColor='rgba(251,191,36,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                        </div>
                        <div>
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Zielgruppe</div>
                            <select id="push-target" style="width:100%;background:#1a1a2e;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 13px;color:#fff;font-size:12px;outline:none;color-scheme:dark;box-sizing:border-box" onchange="pushUpdateAudienceInfo()">
                                <option value="all">🌐 Alle Nutzer</option>
                                <option value="no-order-30">😴 Inaktiv 30+ Tage</option>
                                <option value="no-order-60">💤 Inaktiv 60+ Tage</option>
                                <option value="loyalty-high">⭐ Loyalty &gt; 500 Punkte</option>
                                <option value="loyalty-low">🌱 Neue Kunden (&lt; 100 Punkte)</option>
                                <option value="new-users">🆕 Registriert letzte 7 Tage</option>
                                <option value="vip">👑 VIP (Bestellwert &gt; 200 €)</option>
                                <option value="single-user" id="push-target-single-opt" style="display:none">👤 Einzelner Nutzer</option>
                            </select>
                        </div>
                    </div>

                    <div id="push-audience-info" style="display:none;font-size:11px;color:#67e8f9;background:rgba(103,232,249,.06);border:1px solid rgba(103,232,249,.15);border-radius:8px;padding:8px 12px">
                        <i class="fa-solid fa-circle-info"></i> <span id="push-audience-info-text"></span>
                    </div>

                    <div id="push-single-user-wrap" style="display:none">
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Nutzer (E-Mail oder Name)</div>
                        <div style="display:flex;gap:8px">
                            <input id="push-single-user-input" placeholder="E-Mail eingeben…"
                                style="flex:1;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px;color:#fff;font-size:12px;outline:none;transition:border-color .2s"
                                onfocus="this.style.borderColor='rgba(251,191,36,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                        </div>
                        <div id="push-single-user-info" style="margin-top:6px;font-size:11px;color:rgba(255,255,255,.35)"></div>
                    </div>

                    <div>
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Nachricht *</div>
                        <textarea id="push-body" placeholder="Deine Nachricht an die Kunden…" rows="3" oninput="pushUpdatePreview()" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 13px;color:#fff;font-size:13px;outline:none;resize:vertical;font-family:inherit;box-sizing:border-box;transition:border-color .2s" onfocus="this.style.borderColor='rgba(251,191,36,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'"></textarea>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                        <div>
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Link (optional)</div>
                            <input id="push-url" placeholder="https://wavevapes.de" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 13px;color:#fff;font-size:13px;outline:none;box-sizing:border-box;transition:border-color .2s" onfocus="this.style.borderColor='rgba(251,191,36,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                        </div>
                        <div>
                            <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:6px">Geplant für (optional)</div>
                            <input id="push-schedule" type="datetime-local" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 13px;color:#fff;font-size:12px;outline:none;box-sizing:border-box;color-scheme:dark;transition:border-color .2s" onfocus="this.style.borderColor='rgba(251,191,36,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                        </div>
                    </div>

                    <!-- Schnell-Tags -->
                    <div>
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:8px">Schnell-Einfügen</div>
                        <div style="display:flex;gap:6px;flex-wrap:wrap">
                            <button onclick="pushInsertTag('🔥 Neue Aktion!')" style="padding:4px 12px;border-radius:99px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:11px;cursor:pointer;transition:all .15s" onmouseover="this.style.background='rgba(251,191,36,.1)';this.style.borderColor='rgba(251,191,36,.3)'" onmouseout="this.style.background='rgba(255,255,255,.05)';this.style.borderColor='rgba(255,255,255,.1)'">🔥 Neue Aktion</button>
                            <button onclick="pushInsertTag('🎁 Mystery Vape gratis')" style="padding:4px 12px;border-radius:99px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:11px;cursor:pointer;transition:all .15s" onmouseover="this.style.background='rgba(251,191,36,.1)';this.style.borderColor='rgba(251,191,36,.3)'" onmouseout="this.style.background='rgba(255,255,255,.05)';this.style.borderColor='rgba(255,255,255,.1)'">🎁 Mystery Vape</button>
                            <button onclick="pushInsertTag('🚚 Gratis Versand ab 100€')" style="padding:4px 12px;border-radius:99px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:11px;cursor:pointer;transition:all .15s" onmouseover="this.style.background='rgba(251,191,36,.1)';this.style.borderColor='rgba(251,191,36,.3)'" onmouseout="this.style.background='rgba(255,255,255,.05)';this.style.borderColor='rgba(255,255,255,.1)'">🚚 Gratis Versand</button>
                            <button onclick="pushInsertTag('⭐ Loyalty-Punkte warten!')" style="padding:4px 12px;border-radius:99px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:11px;cursor:pointer;transition:all .15s" onmouseover="this.style.background='rgba(251,191,36,.1)';this.style.borderColor='rgba(251,191,36,.3)'" onmouseout="this.style.background='rgba(255,255,255,.05)';this.style.borderColor='rgba(255,255,255,.1)'">⭐ Loyalty-Punkte</button>
                            <button onclick="pushInsertTag('🆕 Neue Produkte sind da!')" style="padding:4px 12px;border-radius:99px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:11px;cursor:pointer;transition:all .15s" onmouseover="this.style.background='rgba(251,191,36,.1)';this.style.borderColor='rgba(251,191,36,.3)'" onmouseout="this.style.background='rgba(255,255,255,.05)';this.style.borderColor='rgba(255,255,255,.1)'">🆕 Neue Produkte</button>
                        </div>
                    </div>

                    <div style="display:flex;justify-content:flex-end;gap:10px;padding-top:4px">
                        <button onclick="pushSaveAsTemplate()" style="display:flex;align-items:center;gap:7px;padding:10px 18px;border-radius:12px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);font-size:12px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.5)'">
                            <i class="fa-solid fa-floppy-disk"></i> Als Vorlage
                        </button>
                        <button id="push-send-btn" onclick="sendPushNotification()" style="display:flex;align-items:center;gap:8px;padding:10px 24px;border-radius:12px;background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;font-weight:700;font-size:13px;border:none;cursor:pointer;transition:opacity .2s">
                            <i class="fa-solid fa-paper-plane"></i> Senden
                        </button>
                    </div>
                </div>

                <!-- TAB: VORLAGEN -->
                <div id="push-panel-templates" style="display:none;padding:20px">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                        <div style="font-size:12px;color:rgba(255,255,255,.4)">Kampagnen-Vorlagen</div>
                        <button onclick="pushLoadCustomTemplates()" style="font-size:11px;padding:5px 12px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);cursor:pointer">↻ Neu laden</button>
                    </div>

                    <div style="font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-bottom:10px">Standard-Vorlagen</div>
                    <div id="push-builtin-templates" style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px"></div>

                    <div style="font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-bottom:10px">Eigene Vorlagen</div>
                    <div id="push-custom-templates-list" style="font-size:12px;color:rgba(255,255,255,.25);text-align:center;padding:20px">Noch keine eigenen Vorlagen</div>
                </div>

                <!-- TAB: VERLAUF -->
                <div id="push-panel-history" style="display:none;padding:20px">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                        <div style="font-size:12px;color:rgba(255,255,255,.4)">Zuletzt versendete Kampagnen</div>
                        <button onclick="pushLoadHistory()" style="font-size:11px;padding:5px 12px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);cursor:pointer">↻ Neu laden</button>
                    </div>
                    <div id="push-history-list">
                        <div style="text-align:center;padding:40px;color:rgba(255,255,255,.2);font-size:12px"><i class="fa-solid fa-spinner fa-spin"></i> Lade…</div>
                    </div>
                </div>

                <!-- TAB: NUTZER / ABONNENTEN -->
                <div id="push-panel-subscribers" style="display:none;padding:20px">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px">
                        <div style="font-size:12px;color:rgba(255,255,255,.4)">Alle registrierten Nutzer — direkt anschreiben</div>
                        <div style="display:flex;gap:8px">
                            <button onclick="pushExportSubscribers()" style="font-size:11px;padding:5px 12px;border-radius:8px;background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.2);color:#34d399;cursor:pointer"><i class="fa-solid fa-file-csv"></i> Export</button>
                            <button onclick="pushLoadSubscribers()" style="font-size:11px;padding:5px 12px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);cursor:pointer">↻ Laden</button>
                        </div>
                    </div>

                    <!-- KPI-Zeile -->
                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px">
                        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:10px;text-align:center">
                            <div id="push-seg-total" style="font-size:20px;font-weight:700;color:#fbbf24;font-family:'JetBrains Mono',monospace">—</div>
                            <div style="font-size:9px;color:rgba(255,255,255,.3);margin-top:2px;text-transform:uppercase;letter-spacing:.06em">Nutzer gesamt</div>
                        </div>
                        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:10px;text-align:center">
                            <div id="push-seg-active" style="font-size:20px;font-weight:700;color:#34d399;font-family:'JetBrains Mono',monospace">—</div>
                            <div style="font-size:9px;color:rgba(255,255,255,.3);margin-top:2px;text-transform:uppercase;letter-spacing:.06em">Aktiv (30T)</div>
                        </div>
                        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:10px;text-align:center">
                            <div id="push-seg-orders" style="font-size:20px;font-weight:700;color:#67e8f9;font-family:'JetBrains Mono',monospace">—</div>
                            <div style="font-size:9px;color:rgba(255,255,255,.3);margin-top:2px;text-transform:uppercase;letter-spacing:.06em">Mit Bestellung</div>
                        </div>
                    </div>

                    <!-- Suche -->
                    <div style="position:relative;margin-bottom:12px">
                        <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:rgba(255,255,255,.3);font-size:12px;pointer-events:none"></i>
                        <input id="push-user-search" placeholder="Nutzer suchen (Name oder E-Mail)…" oninput="pushFilterUsers()"
                            style="width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px 9px 34px;color:#fff;font-size:12px;outline:none;box-sizing:border-box;transition:border-color .2s"
                            onfocus="this.style.borderColor='rgba(251,191,36,.4)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                    </div>

                    <div id="push-subscribers-list">
                        <div style="text-align:center;padding:40px;color:rgba(255,255,255,.2);font-size:12px"><i class="fa-solid fa-spinner fa-spin"></i> Lade Nutzer…</div>
                    </div>
                </div>

            </div>

            <!-- Erweiterte Export-Optionen (NEU) -->
            <div style="margin-top:16px;background:#13131f;border:1px solid rgba(52,211,153,.15);border-radius:20px;overflow:hidden">
                <div style="display:flex;align-items:center;gap:10px;padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06)">
                    <div style="width:34px;height:34px;border-radius:10px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);display:flex;align-items:center;justify-content:center;color:#34d399;font-size:14px"><i class="fa-solid fa-download"></i></div>
                    <div>
                        <div style="font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#34d399">Erweiterte Exporte</div>
                        <div style="font-size:10px;color:rgba(255,255,255,.3);margin-top:1px">Daten als CSV, JSON oder PDF exportieren</div>
                    </div>
                </div>
                <div style="padding:16px 20px;display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px">
                    <button onclick="exportAnalyticsCSV()" style="display:flex;align-items:center;gap:8px;padding:11px 14px;border-radius:12px;background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.2);color:#34d399;font-size:12px;font-weight:600;cursor:pointer;transition:all .18s" onmouseover="this.style.background='rgba(52,211,153,.16)'" onmouseout="this.style.background='rgba(52,211,153,.08)'">
                        <i class="fa-solid fa-file-csv"></i> Analytics CSV (Zeitraum)
                    </button>
                    <button onclick="exportRevenueByCategory()" style="display:flex;align-items:center;gap:8px;padding:11px 14px;border-radius:12px;background:rgba(103,232,249,.08);border:1px solid rgba(103,232,249,.2);color:#67e8f9;font-size:12px;font-weight:600;cursor:pointer;transition:all .18s" onmouseover="this.style.background='rgba(103,232,249,.16)'" onmouseout="this.style.background='rgba(103,232,249,.08)'">
                        <i class="fa-solid fa-table"></i> Umsatz nach Kategorie
                    </button>
                    <button onclick="exportTopCustomers()" style="display:flex;align-items:center;gap:8px;padding:11px 14px;border-radius:12px;background:rgba(167,139,250,.08);border:1px solid rgba(167,139,250,.2);color:#a78bfa;font-size:12px;font-weight:600;cursor:pointer;transition:all .18s" onmouseover="this.style.background='rgba(167,139,250,.16)'" onmouseout="this.style.background='rgba(167,139,250,.08)'">
                        <i class="fa-solid fa-users"></i> Top Kunden CSV
                    </button>
                    <button onclick="generatePDFReport()" style="display:flex;align-items:center;gap:8px;padding:11px 14px;border-radius:12px;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);color:#f87171;font-size:12px;font-weight:600;cursor:pointer;transition:all .18s" onmouseover="this.style.background='rgba(248,113,113,.16)'" onmouseout="this.style.background='rgba(248,113,113,.08)'">
                        <i class="fa-solid fa-file-pdf"></i> Monatsbericht PDF
                    </button>
                    <button onclick="exportLoyaltyReport()" style="display:flex;align-items:center;gap:8px;padding:11px 14px;border-radius:12px;background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.2);color:#fbbf24;font-size:12px;font-weight:600;cursor:pointer;transition:all .18s" onmouseover="this.style.background='rgba(251,191,36,.16)'" onmouseout="this.style.background='rgba(251,191,36,.08)'">
                        <i class="fa-solid fa-star"></i> Loyalty Report CSV
                    </button>
                    <button onclick="exportOrdersJSON()" style="display:flex;align-items:center;gap:8px;padding:11px 14px;border-radius:12px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:12px;font-weight:600;cursor:pointer;transition:all .18s" onmouseover="this.style.background='rgba(255,255,255,.1)'" onmouseout="this.style.background='rgba(255,255,255,.05)'">
                        <i class="fa-solid fa-file-code"></i> Bestellungen JSON
                    </button>
                </div>
            </div>

            <!-- KI-Zusammenfassung -->
            <div id="an-ai-box" style="margin-top:16px;padding:20px;background:linear-gradient(135deg,rgba(167,139,250,.08),rgba(103,232,249,.05));border:1px solid rgba(167,139,250,.25);border-radius:20px">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:14px">
                    <div style="display:flex;align-items:center;gap:10px">
                        <div style="width:34px;height:34px;border-radius:10px;background:rgba(167,139,250,.15);border:1px solid rgba(167,139,250,.3);display:flex;align-items:center;justify-content:center;color:#a78bfa;font-size:14px;flex-shrink:0"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
                        <div>
                            <div style="font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#a78bfa">KI-Analyse</div>
                            <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:1px">Was lief gut? Was solltest du tun?</div>
                        </div>
                    </div>
                    <button onclick="aiAnalyticsSummary()" id="an-ai-btn"
                        style="display:flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;background:rgba(167,139,250,.15);border:1px solid rgba(167,139,250,.35);color:#a78bfa;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s"
                        onmouseover="this.style.background='rgba(167,139,250,.28)'" onmouseout="this.style.background='rgba(167,139,250,.15)'">
                        <i class="fa-solid fa-wand-magic-sparkles" style="font-size:12px"></i> Jetzt analysieren
                    </button>
                </div>
                <div id="an-ai-result" style="font-size:13px;color:rgba(255,255,255,.3);line-height:1.7">← Klicke "Jetzt analysieren" für eine KI-Zusammenfassung des aktuellen Zeitraums.</div>
            </div>

            <!-- (PDF-Export jetzt im Erweiterte Exporte Panel oben) -->

        </div>

        <!-- TAB 6: ADMIN LOGS v2 -->
        <div id="tab-content-6" class="hidden">
            <!-- IP-Sicherheit wurde in die Superadmin Zone verschoben -->
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 20px;text-align:center">
                <div style="width:72px;height:72px;border-radius:20px;background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.25);display:flex;align-items:center;justify-content:center;font-size:32px;margin-bottom:20px">🔒</div>
                <div style="font-family:'Orbitron',sans-serif;font-size:18px;font-weight:700;color:#fbbf24;margin-bottom:8px">Superadmin erforderlich</div>
                <div style="font-size:13px;color:rgba(255,255,255,.4);max-width:320px;line-height:1.6">IP-Sicherheit &amp; Bann ist jetzt in der Superadmin Zone verfügbar.</div>
                <button onclick="openSuperadminZone()" style="margin-top:20px;padding:12px 28px;border-radius:14px;border:none;cursor:pointer;background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;font-weight:700;font-size:13px">
                    Superadmin Zone öffnen
                </button>
            </div>
        </div>

        <!-- TAB 7: SETTINGS v2 -->
        <div id="tab-content-7" class="hidden">

            <!-- Page header -->
            <div class="cfg-page-hdr">
                <div class="cfg-page-title"><i class="fa-solid fa-sliders"></i> Shop Settings</div>
                <span class="cfg-status-pill cfg-status-live" id="cfg-shop-status-pill">
                    <i class="fa-solid fa-circle" style="font-size:6px"></i> Shop online
                </span>
            </div>

            <div class="cfg-shell">

                <!-- ── Bankdaten ── -->
                <div class="cfg-section">
                    <div class="cfg-section-hdr">
                        <div class="cfg-section-icon" style="background:rgba(103,232,249,.1);color:var(--cfg-cyan)"><i class="fa-solid fa-building-columns"></i></div>
                        <div class="cfg-section-title">Bankverbindung</div>
                    </div>
                    <div class="cfg-section-body">
                        <div class="cfg-field">
                            <label class="cfg-label">Bank / Institut</label>
                            <!-- BUG-11 FIX: bank_name-Feld war nicht vorhanden — Admin konnte Banknamen nie ändern -->
                            <input id="set-bank-name" class="cfg-input" placeholder="z.B. NATIONAL-BANK AG">
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Empfänger</label>
                            <input id="set-bank-owner" class="cfg-input" placeholder="Max Mustermann">
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">IBAN</label>
                            <input id="set-iban" class="cfg-input" placeholder="DE00 0000 0000 0000 0000 00">
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">BIC</label>
                            <input id="set-bic" class="cfg-input" placeholder="XXXXXXXX">
                        </div>
                    </div>
                </div>

                <!-- ── Versand ── -->
                <div class="cfg-section">
                    <div class="cfg-section-hdr">
                        <div class="cfg-section-icon" style="background:rgba(52,211,153,.1);color:var(--cfg-green)"><i class="fa-solid fa-truck"></i></div>
                        <div class="cfg-section-title">Versand & Schwellenwerte</div>
                    </div>
                    <div class="cfg-section-body">
                        <div class="cfg-field-row">
                            <div class="cfg-field">
                                <label class="cfg-label">Versandkosten</label>
                                <input id="set-shipping" type="number" step="0.01" class="cfg-input" placeholder="4.99">
                                <span class="cfg-input-hint">Euro, z.B. 4.99</span>
                            </div>
                            <div class="cfg-field">
                                <label class="cfg-label">Gratis ab</label>
                                <input id="set-free-threshold" type="number" class="cfg-input" placeholder="100">
                                <span class="cfg-input-hint">Bestellwert in €</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Lagerwarnung ── -->
                <div class="cfg-section">
                    <div class="cfg-section-hdr">
                        <div class="cfg-section-icon" style="background:rgba(251,191,36,.1);color:var(--cfg-amber)"><i class="fa-solid fa-triangle-exclamation"></i></div>
                        <div class="cfg-section-title">Lagerwarnung-Schwellenwerte</div>
                    </div>
                    <div class="cfg-section-body">
                        <div class="cfg-field-row">
                            <div class="cfg-field">
                                <label class="cfg-label" style="color:var(--cfg-red)">Kritisch ≤ (rot)</label>
                                <input id="set-stock-critical" type="number" min="0" class="cfg-input red" placeholder="3">
                            </div>
                            <div class="cfg-field">
                                <label class="cfg-label" style="color:var(--cfg-amber)">Warnung ≤ (gelb)</label>
                                <input id="set-stock-warning" type="number" min="0" class="cfg-input amber" placeholder="10">
                            </div>
                        </div>
                        <div class="cfg-threshold-preview">
                            <div class="cfg-threshold-dot" style="background:var(--cfg-red)"></div>
                            <span>Produkte mit Lager ≤ <strong id="cfg-prev-crit" style="color:var(--cfg-red)">3</strong> → rot markiert</span>
                        </div>
                        <div class="cfg-threshold-preview">
                            <div class="cfg-threshold-dot" style="background:var(--cfg-amber)"></div>
                            <span>Produkte mit Lager ≤ <strong id="cfg-prev-warn" style="color:var(--cfg-amber)">10</strong> → gelb markiert</span>
                        </div>
                    </div>
                </div>

                <!-- ── Admin-Benachrichtigungen ── -->
                <div class="cfg-section">
                    <div class="cfg-section-hdr">
                        <div class="cfg-section-icon" style="background:rgba(103,232,249,.1);color:var(--cfg-cyan)"><i class="fa-solid fa-bell"></i></div>
                        <div class="cfg-section-title">Admin-Benachrichtigungen</div>
                    </div>
                    <div class="cfg-section-body">
                        <div class="cfg-field">
                            <label class="cfg-label">E-Mail bei kritischem Lagerbestand</label>
                            <input id="set-notify-email" type="email" class="cfg-input" placeholder="admin@wavevapes.de">
                            <span class="cfg-input-hint">Wird automatisch benachrichtigt wenn ein Produkt den kritischen Schwellenwert unterschreitet. Leer lassen = keine E-Mail.</span>
                        </div>
                    </div>
                </div>

                <!-- ── E-Mail Template (full width) ── -->
                <div class="cfg-section cfg-col-full">
                    <div class="cfg-section-hdr">
                        <div class="cfg-section-icon" style="background:rgba(167,139,250,.1);color:var(--cfg-purple)"><i class="fa-solid fa-envelope"></i></div>
                        <div class="cfg-section-title">Bestellbestätigung Template</div>
                    </div>
                    <div class="cfg-section-body">
                        <div class="cfg-field">
                            <label class="cfg-label">HTML-Template</label>
                            <textarea id="set-email-template" class="cfg-input cfg-textarea" rows="7" placeholder="<p>Deine Bestellung wurde bestätigt...</p>"></textarea>
                            <span class="cfg-input-hint">Wird als HTML in Bestätigungs-E-Mails gerendert. Platzhalter: {{orderNumber}}, {{total}}</span>
                        </div>
                    </div>
                </div>

                <!-- ── Save button (full width) ── -->
                <div class="cfg-col-full">
                    <button class="cfg-save-btn" onclick="saveSettings()">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        EINSTELLUNGEN SPEICHERN
                    </button>
                </div>

            </div><!-- /cfg-shell -->
        </div>

        <!-- TAB 8: SORTIERUNG v2 -->
        <div id="tab-content-8" class="hidden">
        <div class="srt-shell">

            <!-- Header -->
            <div class="srt-header">
                <div class="srt-title"><i class="fa-solid fa-arrows-up-down"></i> Produkt-Sortierung</div>
                <span class="srt-count" id="srt-count">— Produkte</span>
            </div>

            <!-- Auto-sort pills -->
            <div class="srt-pills">
                <button class="srt-pill" onclick="autoSort('alpha')">
                    <i class="fa-solid fa-arrow-down-a-z"></i> Alphabetisch A–Z
                </button>
                <button class="srt-pill" onclick="autoSort('new')">
                    <i class="fa-solid fa-star"></i> Neue Sorten zuerst
                </button>
                <button class="srt-pill" onclick="autoSort('tornado')">
                    <i class="fa-solid fa-tornado"></i> Tornado zuerst
                </button>
                <button class="srt-pill" onclick="autoSort('available')">
                    <i class="fa-solid fa-circle-check"></i> Verfügbare zuerst
                </button>
                <button class="srt-pill" onclick="autoSort('stock')">
                    <i class="fa-solid fa-boxes-stacked"></i> Lager hoch → niedrig
                </button>
                <button class="srt-pill srt-pill-auto" onclick="autoSortPriority()">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> AUTO-PRIORITÄT
                </button>
                <button class="srt-pill" id="srt-ai-btn" onclick="aiSortRecommendation()" style="background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.3);color:#a78bfa">
                    <i class="fa-solid fa-robot"></i> KI-Empfehlung
                </button>
            </div>

            <!-- Category filter bar -->
            <div class="srt-cat-bar" id="srt-cat-bar">
                <button class="srt-cat-pill active" data-cat="Alle" onclick="srtSetCat('Alle',this)">
                    <i class="fa-solid fa-layer-group"></i> Alle
                </button>
            </div>

            <!-- KI Sortierungs-Empfehlung Ergebnis -->
            <div id="srt-ai-result" style="display:none;background:rgba(167,139,250,.07);border:1px solid rgba(167,139,250,.2);border-radius:16px;padding:18px 20px;margin-bottom:8px"></div>

            <!-- Drag list -->
            <div class="srt-list-wrap">
                <div id="sort-list"></div>
                <div id="srt-cat-hint" class="srt-cat-hint hidden">
                    <i class="fa-solid fa-info-circle"></i>
                    Du sortierst nur innerhalb dieser Kategorie. Beim Speichern wird die neue Reihenfolge global übernommen.
                </div>
            </div>

            <!-- Save -->
            <button class="srt-save-btn" onclick="saveProductOrder()">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                SORTIERUNG SPEICHERN &amp; LIVE ÜBERNEHMEN
            </button>

        </div><!-- /srt-shell -->
        </div>

        <!-- TAB 9: LIVE ONLINE v2 -->
        <div id="tab-content-9" class="hidden">
        <div class="prs-shell">

            <div class="prs-page-hdr">
                <div class="prs-page-title">
                    <i class="fa-solid fa-users-viewfinder"></i> Live Online
                    <span class="prs-live-dot" id="prs-live-dot" style="display:none"></span>
                </div>
                <div id="prs-last-update" style="font-size:10px;color:rgba(255,255,255,.25);font-family:'JetBrains Mono',monospace"></div>
            </div>

            <!-- Stats -->
            <div class="prs-stats">
                <div class="prs-stat">
                    <div class="prs-stat-glow" style="background:#67e8f9"></div>
                    <div class="prs-stat-lbl">Gesamt online</div>
                    <div class="prs-stat-val" id="prs-total" style="color:#67e8f9">0</div>
                </div>
                <div class="prs-stat">
                    <div class="prs-stat-glow" style="background:#34d399"></div>
                    <div class="prs-stat-lbl">Eingeloggt</div>
                    <div class="prs-stat-val" id="prs-loggedin" style="color:#34d399">0</div>
                </div>
                <div class="prs-stat">
                    <div class="prs-stat-glow" style="background:#fbbf24"></div>
                    <div class="prs-stat-lbl">Gäste</div>
                    <div class="prs-stat-val" id="prs-guests" style="color:#fbbf24">0</div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="prs-toolbar">
                <button class="prs-btn prs-btn-cyan" onclick="loadPresence()"><i class="fa-solid fa-rotate-right"></i> Aktualisieren</button>
                <button class="prs-btn prs-btn-red"  onclick="cleanupOldPresence()"><i class="fa-solid fa-broom"></i> Alte löschen</button>
                <span class="prs-auto-badge" id="prs-auto-badge">Auto-Refresh: 15s</span>
            </div>

            <!-- Card grid -->
            <div class="prs-grid" id="presence-list">
                <div class="prs-empty"><span class="eu-spinner"></span><br><br>Lade...</div>
            </div>

        </div>
        </div>

        <!-- TAB 11: BEWERTUNGEN -->
        <div id="tab-content-11" class="hidden">
        <div class="rv-shell">

            <div class="rv-admin-header">
                <div class="rv-admin-title"><i class="fa-solid fa-star"></i> Bewertungs-Moderation</div>
                <div class="rv-admin-tabs">
                    <button class="rv-admin-tab active" id="rv-tab-pending" onclick="rvAdminSwitch('pending',this)">
                        Ausstehend <span id="rv-pending-count" style="background:rgba(251,191,36,.2);color:#fbbf24;padding:1px 7px;border-radius:20px;font-size:10px;margin-left:4px">0</span>
                    </button>
                    <button class="rv-admin-tab" id="rv-tab-approved" onclick="rvAdminSwitch('approved',this)">Freigegeben</button>
                    <button class="rv-admin-tab" id="rv-tab-rejected" onclick="rvAdminSwitch('rejected',this)">Abgelehnt</button>
                </div>
            </div>

            <!-- Stats row -->
            <div class="rv-admin-stat-row">
                <div class="rv-admin-stat"><div class="rv-admin-stat-val" id="rv-stat-total">—</div><div class="rv-admin-stat-lbl">Bewertungen gesamt</div></div>
                <div class="rv-admin-stat"><div class="rv-admin-stat-val" id="rv-stat-avg">—</div><div class="rv-admin-stat-lbl">Ø Bewertung</div></div>
                <div class="rv-admin-stat"><div class="rv-admin-stat-val" id="rv-stat-pending">—</div><div class="rv-admin-stat-lbl">Ausstehend</div></div>
                <div class="rv-admin-stat" style="cursor:pointer;transition:background .15s" onclick="rvDeleteAllFake()"
                    onmouseover="this.style.background='rgba(248,113,113,.08)'" onmouseout="this.style.background=''">
                    <div class="rv-admin-stat-val" id="rv-stat-fake" style="color:#f87171">—</div>
                    <div class="rv-admin-stat-lbl" style="color:rgba(248,113,113,.6)">Fake-Reviews 🗑️</div>
                </div>
            </div>

            <div class="rv-admin-list" id="rv-admin-list">
                <div class="rv-admin-empty"><i class="fa-solid fa-spinner fa-spin"></i>Lade Bewertungen...</div>
            </div>

        </div>
        </div>

        <!-- TAB 12: SUPERADMIN ZONE -->
        <!-- TAB 14: AKTIONEN / PROMOTIONS -->
        <div id="tab-content-14" class="hidden">
        <div style="display:flex;flex-direction:column;gap:20px">

            <!-- Header -->
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
                <div>
                    <div style="font-family:'Orbitron',sans-serif;font-size:1.3rem;font-weight:700;display:flex;align-items:center;gap:10px">
                        <div style="width:38px;height:38px;border-radius:11px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);display:flex;align-items:center;justify-content:center;color:#ef4444">⚡</div>
                        Live Aktionen
                    </div>
                    <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:4px">Rabatte die sofort im Shop sichtbar sind — auf Produktkarten, im Modal und im Warenkorb</div>
                </div>
                <button onclick="promoOpenCreate()" style="display:flex;align-items:center;gap:8px;padding:10px 20px;border-radius:14px;background:linear-gradient(135deg,#ef4444,#f97316);color:#fff;font-size:13px;font-weight:700;border:none;cursor:pointer">
                    <i class="fa-solid fa-plus"></i> Neue Aktion
                </button>
            </div>

            <!-- KPI -->
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px">
                <div class="metric-card card" style="padding:18px 20px">
                    <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3)">Aktionen Gesamt</div>
                    <div style="font-size:28px;font-weight:800;margin-top:4px" id="promo-kpi-total">—</div>
                </div>
                <div class="metric-card card" style="padding:18px 20px">
                    <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3)">Aktiv</div>
                    <div style="font-size:28px;font-weight:800;margin-top:4px;color:#34d399" id="promo-kpi-active">—</div>
                </div>
                <div class="metric-card card" style="padding:18px 20px">
                    <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3)">Betroffene Kategorie</div>
                    <div style="font-size:14px;font-weight:700;margin-top:6px;color:#67e8f9" id="promo-kpi-cats">—</div>
                </div>
            </div>

            <!-- Promo List -->
            <div class="card" style="overflow:hidden">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid #27272a">
                    <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.35)"><i class="fa-solid fa-bolt" style="color:#ef4444;margin-right:6px"></i>Alle Aktionen</div>
                </div>
                <div id="promo-list" style="min-height:80px">
                    <div style="padding:32px;text-align:center;color:rgba(255,255,255,.25);font-size:13px"><i class="fa-solid fa-spinner fa-spin"></i> Lade...</div>
                </div>
            </div>

            <!-- Create/Edit Form (hidden by default) -->
            <div id="promo-form-card" class="card" style="display:none;padding:24px">
                <div style="font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:20px" id="promo-form-title">Neue Aktion erstellen</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)">Name der Aktion</label>
                        <input id="promo-f-name" class="cfg-input" placeholder="z.B. Summer Sale" style="width:100%;box-sizing:border-box">
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)">Badge-Text im Shop</label>
                        <input id="promo-f-label" class="cfg-input" placeholder="z.B. -10% SALE" style="width:100%;box-sizing:border-box">
                        <span style="font-size:10px;color:rgba(255,255,255,.25)">Erscheint als Aufkleber auf der Produktkarte</span>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)">Kategorie</label>
                        <select id="promo-f-category" class="cfg-input" style="width:100%;box-sizing:border-box">
                            <option value="Alle">Alle Produkte</option>
                        </select>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)">Rabatt-Typ</label>
                        <select id="promo-f-type" class="cfg-input" style="width:100%;box-sizing:border-box" onchange="promoTypeChange()">
                            <option value="percent">Prozent (%) Rabatt</option>
                            <option value="fixed">Fester Betrag (€) Rabatt</option>
                        </select>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)" id="promo-f-value-label">Rabatt in %</label>
                        <div style="display:flex;align-items:center;gap:8px">
                            <input id="promo-f-value" type="number" min="1" max="99" step="0.5" class="cfg-input" placeholder="10" style="flex:1;box-sizing:border-box">
                            <span id="promo-f-unit" style="font-size:18px;font-weight:800;color:rgba(255,255,255,.4);flex-shrink:0">%</span>
                        </div>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)">Sofort aktiv schalten?</label>
                        <label class="cfg-switch" style="margin-top:4px">
                            <input type="checkbox" id="promo-f-active" checked>
                            <span class="cfg-switch-sl"></span>
                        </label>
                    </div>
                </div>
                <!-- KI Strategie -->
                <div style="margin-top:20px;padding:16px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.2);border-radius:14px">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:10px">
                        <div style="font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#a78bfa;display:flex;align-items:center;gap:7px">
                            <i class="fa-solid fa-wand-magic-sparkles"></i> KI-Strategie-Assistent
                        </div>
                        <div style="display:flex;gap:6px;flex-wrap:wrap">
                            <button onclick="aiPromoStrategy('clearance')" class="ord-ai-email-btn">🏷️ Lagerräumung</button>
                            <button onclick="aiPromoStrategy('newcustomer')" class="ord-ai-email-btn">🎯 Neukundenbonus</button>
                            <button onclick="aiPromoStrategy('retention')" class="ord-ai-email-btn">💎 Stammkunden</button>
                        </div>
                    </div>
                    <div id="promo-ai-result" style="font-size:12px;color:rgba(255,255,255,.35);line-height:1.6">← Ziel wählen — KI empfiehlt Rabatthöhe, Kategorie und Laufzeit.</div>
                </div>

                <div style="display:flex;gap:10px;margin-top:20px;justify-content:flex-end">
                    <button onclick="promoCloseForm()" style="padding:10px 20px;border-radius:12px;background:rgba(255,255,255,.07);color:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.1);font-size:13px;font-weight:600;cursor:pointer">Abbrechen</button>
                    <button onclick="promoSave()" style="padding:10px 24px;border-radius:12px;background:linear-gradient(135deg,#ef4444,#f97316);color:#fff;border:none;font-size:13px;font-weight:700;cursor:pointer"><i class="fa-solid fa-check" style="margin-right:6px"></i>Speichern & Live schalten</button>
                </div>
            </div>

            <!-- Countdown-Timer -->
            <div class="card" style="overflow:hidden">
                <div style="display:flex;align-items:center;gap:10px;padding:14px 20px;border-bottom:1px solid #27272a">
                    <div style="width:34px;height:34px;border-radius:10px;background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.25);display:flex;align-items:center;justify-content:center;color:#fbbf24;font-size:14px;flex-shrink:0"><i class="fa-solid fa-clock"></i></div>
                    <div>
                        <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.4)">Countdown-Timer</div>
                        <div style="font-size:10px;color:rgba(255,255,255,.22);margin-top:1px">Erscheint im Banner neben der aktiven Aktion</div>
                    </div>
                </div>
                <div style="padding:20px;display:flex;flex-direction:column;gap:16px">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
                        <div>
                            <div style="font-size:13px;font-weight:600;color:rgba(255,255,255,.75)">Timer aktivieren</div>
                            <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:2px">Fügt einen Countdown zum Aktions-Banner hinzu</div>
                        </div>
                        <label class="cfg-switch">
                            <input type="checkbox" id="set-countdown-active">
                            <span class="cfg-switch-sl"></span>
                        </label>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
                        <div style="display:flex;flex-direction:column;gap:6px">
                            <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)">Text neben dem Timer</label>
                            <input id="set-countdown-label" type="text" class="cfg-input" placeholder="🔥 Angebot endet in" maxlength="60" oninput="cdAdminPreview()" style="box-sizing:border-box;width:100%">
                        </div>
                        <div style="display:flex;flex-direction:column;gap:6px">
                            <label style="font-size:11px;font-weight:600;color:rgba(255,255,255,.4)">Enddatum & Uhrzeit</label>
                            <input id="set-countdown-end" type="datetime-local" class="cfg-input" oninput="cdAdminPreview()" onchange="cdAdminPreview()" style="box-sizing:border-box;width:100%">
                        </div>
                    </div>
                    <!-- Live Preview -->
                    <div id="cd-admin-preview" style="display:none">
                        <div style="font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.2);margin-bottom:8px">Live-Vorschau</div>
                        <div style="display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:10px 16px;background:linear-gradient(135deg,rgba(251,191,36,.08),rgba(239,68,68,.08));border:1px solid rgba(251,191,36,.25);border-radius:14px;padding:12px 18px">
                            <div style="font-size:13px;font-weight:700;color:#fbbf24" id="cd-prev-label">🔥 Angebot endet in</div>
                            <div style="display:flex;align-items:center;gap:6px">
                                <div style="display:flex;flex-direction:column;align-items:center;background:rgba(0,0,0,.35);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:6px 12px;min-width:46px">
                                    <span style="font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:800;color:#fff;line-height:1" id="cd-prev-h">00</span>
                                    <span style="font-size:8px;font-weight:700;letter-spacing:.1em;color:rgba(255,255,255,.3);text-transform:uppercase;margin-top:3px">Std</span>
                                </div>
                                <span style="font-size:18px;font-weight:800;color:rgba(251,191,36,.4);margin-bottom:12px">:</span>
                                <div style="display:flex;flex-direction:column;align-items:center;background:rgba(0,0,0,.35);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:6px 12px;min-width:46px">
                                    <span style="font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:800;color:#fff;line-height:1" id="cd-prev-m">00</span>
                                    <span style="font-size:8px;font-weight:700;letter-spacing:.1em;color:rgba(255,255,255,.3);text-transform:uppercase;margin-top:3px">Min</span>
                                </div>
                                <span style="font-size:18px;font-weight:800;color:rgba(251,191,36,.4);margin-bottom:12px">:</span>
                                <div style="display:flex;flex-direction:column;align-items:center;background:rgba(0,0,0,.35);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:6px 12px;min-width:46px">
                                    <span style="font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:800;color:#fff;line-height:1" id="cd-prev-s">00</span>
                                    <span style="font-size:8px;font-weight:700;letter-spacing:.1em;color:rgba(255,255,255,.3);text-transform:uppercase;margin-top:3px">Sek</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div style="display:flex;justify-content:flex-end">
                        <button onclick="saveCountdown()" style="display:flex;align-items:center;gap:8px;padding:10px 22px;border-radius:12px;background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;font-size:13px;font-weight:700;border:none;cursor:pointer">
                            <i class="fa-solid fa-clock"></i> Timer speichern
                        </button>
                    </div>
                </div>
            </div>

        </div><!-- /shell -->
        </div>
        <div id="tab-content-13" class="hidden">
        <div class="cu-shell">

            <!-- KI Kundensegment -->
            <div style="padding:20px;background:linear-gradient(135deg,rgba(167,139,250,.07),rgba(103,232,249,.04));border:1px solid rgba(167,139,250,.22);border-radius:20px">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:14px">
                    <div style="display:flex;align-items:center;gap:10px">
                        <div style="width:36px;height:36px;border-radius:11px;background:rgba(167,139,250,.15);border:1px solid rgba(167,139,250,.3);display:flex;align-items:center;justify-content:center;color:#a78bfa;font-size:15px;flex-shrink:0"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
                        <div>
                            <div style="font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#a78bfa">KI-Kundensegmentierung</div>
                            <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:1px">Wer kauft oft? Wer ist inaktiv? Was soll man tun?</div>
                        </div>
                    </div>
                    <button onclick="aiCustomerSegments()" id="cu-ai-btn"
                        style="display:flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;background:rgba(167,139,250,.15);border:1px solid rgba(167,139,250,.35);color:#a78bfa;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s"
                        onmouseover="this.style.background='rgba(167,139,250,.28)'" onmouseout="this.style.background='rgba(167,139,250,.15)'">
                        <i class="fa-solid fa-users-viewfinder"></i> Jetzt analysieren
                    </button>
                </div>
                <div id="cu-ai-result" style="font-size:13px;color:rgba(255,255,255,.3);line-height:1.7">← Klicke "Jetzt analysieren" — KI clustert deine Kunden und gibt konkrete Handlungsempfehlungen.</div>
            </div>

            <!-- KPI Strip -->
            <div class="cu-kpi-row" id="cu-kpi-row">
                <div class="cu-kpi">
                    <div class="cu-kpi-glow" style="background:#67e8f9"></div>
                    <div class="cu-kpi-lbl">Registrierte Kunden</div>
                    <div class="cu-kpi-val" id="cu-kpi-total">—</div>
                    <div class="cu-kpi-sub">aus Firestore users</div>
                </div>
                <div class="cu-kpi">
                    <div class="cu-kpi-glow" style="background:#34d399"></div>
                    <div class="cu-kpi-lbl">Gesamtumsatz (Kunden)</div>
                    <div class="cu-kpi-val" id="cu-kpi-revenue" style="color:#34d399">—</div>
                    <div class="cu-kpi-sub">aus abgeschlossenen Bestellungen</div>
                </div>
                <div class="cu-kpi">
                    <div class="cu-kpi-glow" style="background:#fbbf24"></div>
                    <div class="cu-kpi-lbl">Ø Bestellwert / Kunde</div>
                    <div class="cu-kpi-val" id="cu-kpi-avg" style="color:#fbbf24">—</div>
                    <div class="cu-kpi-sub">nur Kunden mit Bestellungen</div>
                </div>
                <div class="cu-kpi">
                    <div class="cu-kpi-glow" style="background:#a78bfa"></div>
                    <div class="cu-kpi-lbl">Top Loyalty-Punkte</div>
                    <div class="cu-kpi-val" id="cu-kpi-toppts" style="color:#a78bfa">—</div>
                    <div class="cu-kpi-sub" id="cu-kpi-toppts-name">—</div>
                </div>
            </div>

            <!-- Rankings side by side -->
            <div class="cu-panels">
                <!-- Top Spender -->
                <div class="cu-panel">
                    <div class="cu-panel-hdr">
                        <div class="cu-panel-title"><i class="fa-solid fa-fire-flame-curved"></i> Top 10 Spender</div>
                        <span style="font-size:10px;color:rgba(255,255,255,.2)">nach Umsatz</span>
                    </div>
                    <div class="cu-panel-body" id="cu-top-spenders">
                        <div class="cu-empty"><div class="cu-spinner"></div><br>Lade...</div>
                    </div>
                </div>
                <!-- Loyalty Ranking -->
                <div class="cu-panel">
                    <div class="cu-panel-hdr">
                        <div class="cu-panel-title"><i class="fa-solid fa-star"></i> Loyalty-Punkte Ranking</div>
                        <span style="font-size:10px;color:rgba(255,255,255,.2)">Top 10</span>
                    </div>
                    <div class="cu-panel-body" id="cu-top-loyalty">
                        <div class="cu-empty"><div class="cu-spinner"></div><br>Lade...</div>
                    </div>
                </div>
            </div>

            <!-- Full Customer Table -->
            <div class="cu-panel">
                <div class="cu-panel-hdr">
                    <div class="cu-panel-title"><i class="fa-solid fa-table-list"></i> Alle Kunden</div>
                    <div class="cu-toolbar">
                        <div class="cu-search-wrap">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input class="cu-search" id="cu-search" placeholder="E-Mail oder Name suchen..." oninput="cuRenderTable()">
                        </div>
                        <button class="cu-btn cu-btn-cyan" onclick="cuExportCSV()"><i class="fa-solid fa-file-csv"></i> Export</button>
                    </div>
                </div>
                <div class="cu-table-scroll">
                    <table class="cu-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Kunde</th>
                                <th>Bestellungen</th>
                                <th>Umsatz</th>
                                <th>Ø Bestellwert</th>
                                <th>Loyalty-Pts</th>
                                <th>Letzter Kauf</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="cu-tbody">
                            <tr><td colspan="8"><div class="cu-empty"><div class="cu-spinner"></div><br>Lade...</div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div><!-- /cu-shell -->
        </div>

        <!-- TAB 15: KLICK-ANALYSE -->
        <div id="tab-content-15" class="hidden">
        <div style="display:flex;flex-direction:column;gap:20px">

            <!-- Header -->
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px">
                <div>
                    <div style="font-family:'Orbitron',sans-serif;font-size:1.3rem;font-weight:700;color:#67e8f9;text-shadow:0 0 20px rgba(103,232,249,.5);display:flex;align-items:center;gap:12px">
                        <div style="width:40px;height:40px;border-radius:12px;background:rgba(103,232,249,.1);border:1px solid rgba(103,232,249,.25);display:flex;align-items:center;justify-content:center"><i class="fa-solid fa-computer-mouse" style="color:#67e8f9"></i></div>
                        Klick-Analyse
                    </div>
                    <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:6px">Wo klicken Gäste und eingeloggte Nutzer im Shop?</div>
                </div>
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                    <!-- Period filter -->
                    <div style="display:flex;gap:6px">
                        <button class="ca-period-btn" id="ca-btn-1" onclick="caSetPeriod(1,this)">Heute</button>
                        <button class="ca-period-btn" id="ca-btn-7" onclick="caSetPeriod(7,this)">7 Tage</button>
                        <button class="ca-period-btn" id="ca-btn-30" onclick="caSetPeriod(30,this)">30 Tage</button>
                        <button class="ca-period-btn active" id="ca-btn-0" onclick="caSetPeriod(0,this)">Alle</button>
                    </div>
                    <button onclick="caExportCSV()" style="display:flex;align-items:center;gap:7px;padding:8px 16px;border-radius:12px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);color:#34d399;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(52,211,153,.2)'" onmouseout="this.style.background='rgba(52,211,153,.1)'">
                        <i class="fa-solid fa-file-csv"></i> CSV Export
                    </button>
                    <button onclick="caWriteTestEvent()" style="display:flex;align-items:center;gap:7px;padding:8px 16px;border-radius:12px;background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.2);color:#fbbf24;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(251,191,36,.16)'" onmouseout="this.style.background='rgba(251,191,36,.08)'">
                        <i class="fa-solid fa-vial"></i> Test-Event
                    </button>
                    <button onclick="loadClickAnalytics()" style="display:flex;align-items:center;gap:7px;padding:8px 16px;border-radius:12px;background:rgba(103,232,249,.08);border:1px solid rgba(103,232,249,.2);color:#67e8f9;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(103,232,249,.16)'" onmouseout="this.style.background='rgba(103,232,249,.08)'">
                        <i class="fa-solid fa-rotate"></i> Aktualisieren
                    </button>
                </div>
            </div>

            <!-- KPI Strip -->
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px" id="ca-kpi-strip">
                <div class="ca-kpi" style="--ca-glow:#67e8f9">
                    <div class="ca-kpi-glow"></div>
                    <div class="ca-kpi-icon"><i class="fa-solid fa-computer-mouse"></i></div>
                    <div class="ca-kpi-lbl">Gesamt Klicks</div>
                    <div class="ca-kpi-val" id="ca-kpi-total" style="color:#67e8f9">—</div>
                </div>
                <div class="ca-kpi" style="--ca-glow:#a78bfa">
                    <div class="ca-kpi-glow" style="background:#a78bfa"></div>
                    <div class="ca-kpi-icon" style="color:#a78bfa"><i class="fa-solid fa-user-check"></i></div>
                    <div class="ca-kpi-lbl">Eingeloggt</div>
                    <div class="ca-kpi-val" id="ca-kpi-loggedin" style="color:#a78bfa">—</div>
                </div>
                <div class="ca-kpi" style="--ca-glow:#fbbf24">
                    <div class="ca-kpi-glow" style="background:#fbbf24"></div>
                    <div class="ca-kpi-icon" style="color:#fbbf24"><i class="fa-solid fa-user-secret"></i></div>
                    <div class="ca-kpi-lbl">Gäste</div>
                    <div class="ca-kpi-val" id="ca-kpi-guests" style="color:#fbbf24">—</div>
                </div>
                <div class="ca-kpi" style="--ca-glow:#34d399">
                    <div class="ca-kpi-glow" style="background:#34d399"></div>
                    <div class="ca-kpi-icon" style="color:#34d399"><i class="fa-solid fa-trophy"></i></div>
                    <div class="ca-kpi-lbl">Top Element</div>
                    <div class="ca-kpi-val" id="ca-kpi-top" style="color:#34d399;font-size:12px;font-family:'Inter',sans-serif;font-weight:700;margin-top:6px;line-height:1.3">—</div>
                </div>
            </div>

            <!-- Charts Row -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <!-- Bar Chart: Top Klicks -->
                <div class="ca-chart-card">
                    <div class="ca-chart-title"><i class="fa-solid fa-chart-bar" style="color:#67e8f9"></i> Top 10 Klick-Elemente</div>
                    <div style="position:relative;height:260px"><canvas id="ca-bar-chart"></canvas></div>
                </div>
                <!-- Donut: Gast vs Eingeloggt -->
                <div class="ca-chart-card">
                    <div class="ca-chart-title"><i class="fa-solid fa-chart-pie" style="color:#a78bfa"></i> Gast vs. Eingeloggt</div>
                    <div style="position:relative;height:220px;display:flex;align-items:center;justify-content:center"><canvas id="ca-donut-chart" style="max-height:220px"></canvas></div>
                    <div style="display:flex;justify-content:center;gap:20px;margin-top:8px;font-size:11px;color:rgba(255,255,255,.5)">
                        <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#a78bfa;margin-right:5px;vertical-align:middle"></span>Eingeloggt</span>
                        <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#fbbf24;margin-right:5px;vertical-align:middle"></span>Gast</span>
                    </div>
                </div>
            </div>

            <!-- Line Chart: Verlauf -->
            <div class="ca-chart-card">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                    <div class="ca-chart-title" style="margin-bottom:0"><i class="fa-solid fa-chart-line" style="color:#34d399"></i> Klick-Verlauf</div>
                    <div style="display:flex;gap:14px;font-size:11px;color:rgba(255,255,255,.4)">
                        <span><span style="display:inline-block;width:24px;height:2px;background:#67e8f9;margin-right:5px;vertical-align:middle;border-radius:2px"></span>Alle</span>
                        <span><span style="display:inline-block;width:24px;height:2px;background:#a78bfa;margin-right:5px;vertical-align:middle;border-radius:2px"></span>Eingeloggt</span>
                        <span><span style="display:inline-block;width:24px;height:2px;background:#fbbf24;margin-right:5px;vertical-align:middle;border-radius:2px"></span>Gäste</span>
                    </div>
                </div>
                <div style="position:relative;height:200px"><canvas id="ca-line-chart"></canvas></div>
            </div>

            <!-- Top Produkte -->
            <div class="ca-chart-card" style="padding:0;overflow:hidden">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06);flex-wrap:wrap;gap:10px">
                    <div class="ca-chart-title" style="margin-bottom:0">
                        <i class="fa-solid fa-fire" style="color:#ef4444"></i>
                        Top Produkte
                    </div>
                    <div style="display:flex;gap:16px;font-size:10px;color:rgba(255,255,255,.3)">
                        <span><i class="fa-solid fa-eye" style="margin-right:4px;color:#67e8f9"></i>Aufrufe</span>
                        <span><i class="fa-solid fa-cart-plus" style="margin-right:4px;color:#a78bfa"></i>In den Warenkorb</span>
                        <span><i class="fa-solid fa-percent" style="margin-right:4px;color:#34d399"></i>Conversion</span>
                    </div>
                </div>
                <!-- Table header -->
                <div style="display:grid;grid-template-columns:28px 1fr 80px 80px 90px 72px;gap:10px;padding:8px 16px;border-bottom:1px solid rgba(255,255,255,.04)">
                    <div></div>
                    <div style="font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.25)">Produkt</div>
                    <div style="font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#67e8f9;text-align:right">Aufrufe</div>
                    <div style="font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#a78bfa;text-align:right">Adds</div>
                    <div style="font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.25)">Beliebtheit</div>
                    <div style="font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#34d399;text-align:right">Conv.</div>
                </div>
                <div id="ca-top-products-list">
                    <div class="ca-tp-empty"><i class="fa-solid fa-spinner fa-spin" style="display:block;font-size:22px;margin-bottom:8px;opacity:.3"></i>Wird geladen…</div>
                </div>
            </div>

            <!-- Event Table -->
            <div class="ca-chart-card" style="padding:0;overflow:hidden">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06)">
                    <div class="ca-chart-title" style="margin-bottom:0"><i class="fa-solid fa-table" style="color:#67e8f9"></i> Letzte Click-Events</div>
                    <div style="display:flex;align-items:center;gap:10px">
                        <div style="position:relative">
                            <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:11px;color:rgba(255,255,255,.3);pointer-events:none"></i>
                            <input id="ca-search" placeholder="Suchen..." oninput="caFilterTable()" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:7px 10px 7px 28px;color:#fff;font-size:12px;outline:none;width:180px">
                        </div>
                        <div class="cs-wrap" style="width:140px">
                            <div class="cs-trigger bke-input" id="ca-type-filter-trigger" onclick="document.getElementById('ca-type-filter-dd').parentElement.classList.toggle('open')" style="padding:7px 10px;font-size:12px;border-radius:8px">
                                Alle Typen <span class="cs-trigger-arrow">▼</span>
                            </div>
                            <div class="cs-dropdown" id="ca-type-filter-dd">
                                <div class="cs-option" onclick="caSetTypeFilter('',this)">Alle Typen</div>
                                <div class="cs-option" onclick="caSetTypeFilter('loggedin',this)">Nur Eingeloggt</div>
                                <div class="cs-option" onclick="caSetTypeFilter('guest',this)">Nur Gäste</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div style="overflow-x:auto">
                    <table style="width:100%;border-collapse:collapse">
                        <thead>
                            <tr style="border-bottom:1px solid rgba(255,255,255,.05)">
                                <th style="padding:10px 14px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Zeit</th>
                                <th style="padding:10px 14px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Event / Label</th>
                                <th style="padding:10px 14px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Nutzer</th>
                                <th style="padding:10px 14px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Typ</th>
                                <th style="padding:10px 14px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Seite</th>
                            </tr>
                        </thead>
                        <tbody id="ca-events-tbody">
                            <tr><td colspan="5" style="text-align:center;padding:40px;color:rgba(255,255,255,.2);font-size:13px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Events...</td></tr>
                        </tbody>
                    </table>
                </div>
                <div id="ca-table-footer" style="padding:10px 20px;font-size:11px;color:rgba(255,255,255,.2);border-top:1px solid rgba(255,255,255,.05);display:flex;justify-content:space-between;align-items:center">
                    <span id="ca-showing-label">—</span>
                    <div style="display:flex;gap:8px">
                        <button id="ca-prev-btn" onclick="caPagePrev()" style="padding:5px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.5);font-size:11px;cursor:pointer" disabled>← Zurück</button>
                        <button id="ca-next-btn" onclick="caPageNext()" style="padding:5px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.5);font-size:11px;cursor:pointer">Weiter →</button>
                    </div>
                </div>
            </div>

        </div>
        </div>

        <div id="tab-content-12" class="hidden">
        <div class="sa-shell">

            <!-- ── Header ── -->
            <div class="sa-header">
                <div>
                    <div class="sa-header-title"><i class="fa-solid fa-shield-halved"></i> Superadmin Zone</div>
                    <div class="sa-header-meta" id="sa-session-info">Sitzung aktiv • Zugriff verifiziert</div>
                </div>
                <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                    <div class="sa-ip-badge"><i class="fa-solid fa-location-dot" style="color:#34d399"></i><span id="sa-current-ip-display">Lade...</span></div>
                    <button onclick="saRefreshZone()" style="padding:8px 14px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);color:rgba(255,255,255,.6);font-size:12px;font-weight:600;cursor:pointer"><i class="fa-solid fa-rotate"></i> Aktualisieren</button>
                    <button onclick="saLockZone()" style="padding:8px 16px;border-radius:10px;border:1px solid rgba(251,191,36,.3);background:rgba(251,191,36,.08);color:#fbbf24;font-size:12px;font-weight:600;cursor:pointer"><i class="fa-solid fa-lock"></i> Zone sperren</button>
                </div>
            </div>

            <!-- ── Inner Navigation Tabs ── -->
            <div class="sa-inner-tabs">
                <div class="sa-inner-tab active" onclick="saSwitchInner('dashboard',this)"><i class="fa-solid fa-gauge-high" style="margin-right:6px"></i>Dashboard</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('analytics',this)"><i class="fa-solid fa-chart-line" style="margin-right:6px"></i>Shop-Analyse</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('admins',this)"><i class="fa-solid fa-users-cog" style="margin-right:6px"></i>Admin-Verwaltung</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('ipsec',this)"><i class="fa-solid fa-ban" style="margin-right:6px"></i>IP-Sicherheit &amp; Bann</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('security',this)"><i class="fa-solid fa-shield-halved" style="margin-right:6px"></i>Sicherheit</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('sessions',this)"><i class="fa-solid fa-eye" style="margin-right:6px"></i>Session Monitor</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('backup',this)"><i class="fa-solid fa-database" style="margin-right:6px"></i>Backup &amp; Export</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('actlog',this)"><i class="fa-solid fa-scroll" style="margin-right:6px"></i>SA-Aktivitätslog</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('shopconfig',this)"><i class="fa-solid fa-sliders" style="margin-right:6px"></i>Shop-Konfiguration</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('health',this)"><i class="fa-solid fa-heart-pulse" style="margin-right:6px"></i>System-Health</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('audittrail',this)"><i class="fa-solid fa-shield-check" style="margin-right:6px;color:rgba(167,139,250,.7)"></i>Audit-Trail</div>
                <div class="sa-inner-tab" onclick="saSwitchInner('danger',this)" style="color:rgba(248,113,113,.6)"><i class="fa-solid fa-triangle-exclamation" style="margin-right:6px"></i>Danger Zone</div>
            </div>

            <!-- PANEL: DASHBOARD -->
            <div class="sa-inner-panel active" id="sa-panel-dashboard">
                <div class="sa-section-title"><i class="fa-solid fa-gauge-high" style="color:#fbbf24"></i> Shop-Übersicht</div>
                <div class="sa-kpi-grid">
                    <div class="sa-kpi"><div class="sa-kpi-icon">💶</div><div class="sa-kpi-label">Gesamtumsatz</div><div class="sa-kpi-value" id="sa-kpi-revenue">—</div><div class="sa-kpi-sub">Alle Bestellungen</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">📅</div><div class="sa-kpi-label">Heute</div><div class="sa-kpi-value" id="sa-kpi-today">—</div><div class="sa-kpi-sub" id="sa-kpi-today-orders">— Bestellungen</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">📈</div><div class="sa-kpi-label">Letzte 7 Tage</div><div class="sa-kpi-value" id="sa-kpi-7d">—</div><div class="sa-kpi-sub" id="sa-kpi-7d-orders">— Bestellungen</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">📊</div><div class="sa-kpi-label">Letzte 30 Tage</div><div class="sa-kpi-value" id="sa-kpi-30d">—</div><div class="sa-kpi-sub" id="sa-kpi-30d-orders">— Bestellungen</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">⏳</div><div class="sa-kpi-label">Offene Bestellungen</div><div class="sa-kpi-value" id="sa-kpi-open">—</div><div class="sa-kpi-sub">Wird bearbeitet</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">👤</div><div class="sa-kpi-label">Registrierte User</div><div class="sa-kpi-value" id="sa-kpi-users">—</div><div class="sa-kpi-sub" id="sa-kpi-users-new">— neu (7 Tage)</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">🌐</div><div class="sa-kpi-label">Live Online</div><div class="sa-kpi-value" id="sa-kpi-online">—</div><div class="sa-kpi-sub">Besucher jetzt</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">🛡️</div><div class="sa-kpi-label">Aktive Admins</div><div class="sa-kpi-value" id="sa-kpi-admins">—</div><div class="sa-kpi-sub">inkl. Superadmin</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">⭐</div><div class="sa-kpi-label">Aussteh. Reviews</div><div class="sa-kpi-value" id="sa-kpi-reviews">—</div><div class="sa-kpi-sub">Warten auf Freigabe</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">🚫</div><div class="sa-kpi-label">Gesperrte IPs</div><div class="sa-kpi-value" id="sa-kpi-banned">—</div><div class="sa-kpi-sub">Aktive Bans</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">🏷️</div><div class="sa-kpi-label">Produkte</div><div class="sa-kpi-value" id="sa-kpi-products">—</div><div class="sa-kpi-sub" id="sa-kpi-products-sub">Im Shop</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">🏆</div><div class="sa-kpi-label">Top-Produkt</div><div class="sa-kpi-value" style="font-size:14px;line-height:1.3" id="sa-kpi-top-product">—</div><div class="sa-kpi-sub" id="sa-kpi-top-product-sub">Meistverkauft</div></div>
                </div>

                <!-- Shop-Status Banner -->
                <div id="sa-shop-status-banner" style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-radius:16px;border:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.03);flex-wrap:wrap;gap:10px">
                    <div style="display:flex;align-items:center;gap:10px">
                        <div id="sa-shop-status-dot" style="width:10px;height:10px;border-radius:50%;background:#34d399;box-shadow:0 0 10px #34d399;flex-shrink:0"></div>
                        <span id="sa-shop-status-text" style="font-size:13px;font-weight:600">Shop-Status wird geladen…</span>
                    </div>
                    <div style="display:flex;gap:8px">
                        <button onclick="saDangerShopClose()" style="padding:7px 16px;border-radius:10px;border:1px solid rgba(248,113,113,.3);background:rgba(248,113,113,.08);color:#f87171;font-size:12px;font-weight:600;cursor:pointer"><i class="fa-solid fa-power-off"></i> Schließen</button>
                        <button onclick="saDangerShopOpen()" style="padding:7px 16px;border-radius:10px;border:1px solid rgba(52,211,153,.3);background:rgba(52,211,153,.08);color:#34d399;font-size:12px;font-weight:600;cursor:pointer"><i class="fa-solid fa-door-open"></i> Öffnen</button>
                    </div>
                </div>

                <!-- Umsatz-Verlauf Chart -->
                <div class="sa-section-title" style="margin-top:4px"><i class="fa-solid fa-chart-area" style="color:#67e8f9"></i> Umsatz-Verlauf (letzte 14 Tage)</div>
                <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:20px">
                    <div id="sa-dash-revenue-chart" style="height:120px;display:flex;align-items:flex-end;gap:4px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;width:100%;text-align:center;padding-top:40px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Chart...</div>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-top:10px;flex-wrap:wrap;gap:8px">
                        <div style="font-size:11px;color:rgba(255,255,255,.2)">Tagesumsatz in € — Hover für Details</div>
                        <div style="display:flex;gap:16px">
                            <div style="font-size:11px;color:rgba(255,255,255,.3)">Ø/Tag: <span id="sa-dash-avg-day" style="color:#67e8f9;font-weight:700">—</span></div>
                            <div style="font-size:11px;color:rgba(255,255,255,.3)">Bester Tag: <span id="sa-dash-best-day" style="color:#fbbf24;font-weight:700">—</span></div>
                        </div>
                    </div>
                </div>

                <!-- Schnellaktionen -->
                <div class="sa-section-title"><i class="fa-solid fa-bolt" style="color:#fbbf24"></i> Schnellaktionen</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px">
                    <button onclick="saSwitchInner('shopconfig',document.querySelector('[onclick*=shopconfig]'))" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:14px;border:1px solid rgba(103,232,249,.15);background:rgba(103,232,249,.05);color:#67e8f9;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;text-align:left" onmouseover="this.style.background='rgba(103,232,249,.12)'" onmouseout="this.style.background='rgba(103,232,249,.05)'"><i class="fa-solid fa-sliders" style="font-size:16px"></i><span>Shop konfigurieren</span></button>
                    <button onclick="saSwitchInner('health',document.querySelector('[onclick*=health]'))" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:14px;border:1px solid rgba(52,211,153,.15);background:rgba(52,211,153,.05);color:#34d399;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;text-align:left" onmouseover="this.style.background='rgba(52,211,153,.12)'" onmouseout="this.style.background='rgba(52,211,153,.05)'"><i class="fa-solid fa-heart-pulse" style="font-size:16px"></i><span>Health-Check</span></button>
                    <button onclick="saSwitchInner('audittrail',document.querySelector('[onclick*=audittrail]'))" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:14px;border:1px solid rgba(167,139,250,.15);background:rgba(167,139,250,.05);color:#a78bfa;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;text-align:left" onmouseover="this.style.background='rgba(167,139,250,.12)'" onmouseout="this.style.background='rgba(167,139,250,.05)'"><i class="fa-solid fa-shield-check" style="font-size:16px"></i><span>Audit-Trail</span></button>
                    <button onclick="saSwitchInner('backup',document.querySelector('[onclick*=backup]'))" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);color:rgba(255,255,255,.6);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;text-align:left" onmouseover="this.style.background='rgba(255,255,255,.08)'" onmouseout="this.style.background='rgba(255,255,255,.03)'"><i class="fa-solid fa-database" style="font-size:16px"></i><span>Backup starten</span></button>
                    <button onclick="saDangerShopClose()" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:14px;border:1px solid rgba(248,113,113,.2);background:rgba(248,113,113,.06);color:#f87171;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;text-align:left" onmouseover="this.style.background='rgba(248,113,113,.14)'" onmouseout="this.style.background='rgba(248,113,113,.06)'"><i class="fa-solid fa-power-off" style="font-size:16px"></i><span>Shop schließen</span></button>
                    <button onclick="saSwitchInner('admins',document.querySelector('[onclick*=admins]'))" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:14px;border:1px solid rgba(251,191,36,.15);background:rgba(251,191,36,.05);color:#fbbf24;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;text-align:left" onmouseover="this.style.background='rgba(251,191,36,.12)'" onmouseout="this.style.background='rgba(251,191,36,.05)'"><i class="fa-solid fa-users-cog" style="font-size:16px"></i><span>Admins verwalten</span></button>
                </div>

                <!-- Alert Feed + Security Score nebeneinander -->
                <div style="display:grid;grid-template-columns:1fr 340px;gap:16px;align-items:start">

                    <!-- Alert Feed -->
                    <div>
                        <div class="sa-section-title"><i class="fa-solid fa-bell" style="color:#f87171"></i> Alert-Feed <span id="sa-alert-badge" style="display:none;font-size:9px;padding:1px 7px;border-radius:99px;background:rgba(248,113,113,.18);color:#f87171;border:1px solid rgba(248,113,113,.3);margin-left:6px;font-weight:700"></span></div>
                        <div id="sa-alert-feed" style="display:flex;flex-direction:column;gap:6px;max-height:260px;overflow-y:auto">
                            <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px;text-align:center"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Alerts...</div>
                        </div>
                    </div>

                    <!-- Security Score Card -->
                    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:20px;padding:20px">
                        <div style="font-size:12px;font-weight:700;color:rgba(255,255,255,.5);margin-bottom:14px;text-transform:uppercase;letter-spacing:.07em"><i class="fa-solid fa-shield-halved" style="margin-right:6px;color:#67e8f9"></i>Security Score</div>
                        <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
                            <div id="sa-sec-score-ring" style="position:relative;width:72px;height:72px;flex-shrink:0">
                                <svg width="72" height="72" viewBox="0 0 72 72" style="transform:rotate(-90deg)">
                                    <circle cx="36" cy="36" r="28" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="8"/>
                                    <circle id="sa-sec-score-arc" cx="36" cy="36" r="28" fill="none" stroke="#34d399" stroke-width="8" stroke-linecap="round" stroke-dasharray="176" stroke-dashoffset="176" style="transition:stroke-dashoffset 1s ease,stroke .5s"/>
                                </svg>
                                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700;color:#fff" id="sa-sec-score-val">—</div>
                            </div>
                            <div>
                                <div id="sa-sec-score-label" style="font-size:15px;font-weight:700;color:#34d399">Sehr sicher</div>
                                <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:3px;line-height:1.5" id="sa-sec-score-sub">Wird berechnet...</div>
                            </div>
                        </div>
                        <div id="sa-sec-score-breakdown" style="display:flex;flex-direction:column;gap:7px">
                            <!-- rendered by JS -->
                        </div>
                    </div>
                </div>

                <div class="sa-section-title"><i class="fa-solid fa-clock-rotate-left" style="color:#a78bfa"></i> Letzte SA-Aktionen</div>
                <div class="sa-log-list" id="sa-dash-log" style="max-height:240px">
                    <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade...</div>
                </div>
            </div>

            <!-- PANEL: SHOP-ANALYSE -->
            <div class="sa-inner-panel" id="sa-panel-analytics">
                <div class="sa-section-title"><i class="fa-solid fa-chart-line" style="color:#67e8f9"></i> Umsatz-Übersicht</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px" id="sa-analytics-kpis">
                    <div style="color:rgba(255,255,255,.2);font-size:12px;padding:20px;grid-column:1/-1"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Analysiere…</div>
                </div>

                <!-- Umsatz-Zeitstrahl -->
                <div class="sa-section-title"><i class="fa-solid fa-chart-area" style="color:#a78bfa"></i> Umsatz-Zeitstrahl (letzte 30 Tage)</div>
                <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:20px">
                    <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">
                        <button class="sa-inner-tab active" id="anlz-period-7"  onclick="anlzSetPeriod(7,this)"  style="padding:5px 14px;font-size:11px">7 Tage</button>
                        <button class="sa-inner-tab"        id="anlz-period-14" onclick="anlzSetPeriod(14,this)" style="padding:5px 14px;font-size:11px">14 Tage</button>
                        <button class="sa-inner-tab"        id="anlz-period-30" onclick="anlzSetPeriod(30,this)" style="padding:5px 14px;font-size:11px">30 Tage</button>
                        <button class="sa-inner-tab"        id="anlz-period-90" onclick="anlzSetPeriod(90,this)" style="padding:5px 14px;font-size:11px">90 Tage</button>
                        <div style="margin-left:auto;display:flex;gap:10px;font-size:11px;color:rgba(255,255,255,.3);align-items:center">
                            <span>Gesamt: <span id="anlz-period-total" style="color:#fbbf24;font-weight:700">—</span></span>
                            <span>Trend: <span id="anlz-trend-badge" style="font-weight:700">—</span></span>
                        </div>
                    </div>
                    <div id="sa-revenue-timeline" style="height:130px;display:flex;align-items:flex-end;gap:3px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;width:100%;text-align:center;padding-top:50px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:6px"></i>Lade…</div>
                    </div>
                </div>

                <!-- Stunden-Heatmap -->
                <div class="sa-section-title"><i class="fa-solid fa-fire" style="color:#f87171"></i> Bestell-Heatmap (Uhrzeit)</div>
                <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:20px">
                    <div id="sa-order-heatmap" style="display:flex;gap:3px;flex-wrap:wrap">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;width:100%"><i class="fa-solid fa-spinner fa-spin" style="margin-right:6px"></i>Lade…</div>
                    </div>
                    <div style="font-size:10px;color:rgba(255,255,255,.2);margin-top:8px">Jede Zelle = 1 Stunde des Tages · Intensität = Anzahl Bestellungen</div>
                </div>

                <div class="sa-section-title"><i class="fa-solid fa-trophy" style="color:#fbbf24"></i> Top 10 Produkte</div>
                <div id="sa-top-products" style="display:flex;flex-direction:column;gap:8px">
                    <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade…</div>
                </div>

                <div class="sa-section-title"><i class="fa-solid fa-chart-pie" style="color:#a78bfa"></i> Bestellstatus-Verteilung</div>
                <div id="sa-order-status-chart" style="display:flex;flex-direction:column;gap:8px">
                    <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade…</div>
                </div>

                <!-- Coupon-Nutzung -->
                <div class="sa-section-title"><i class="fa-solid fa-ticket" style="color:#34d399"></i> Coupon-Nutzung</div>
                <div id="sa-coupon-stats" style="display:flex;flex-direction:column;gap:8px">
                    <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade…</div>
                </div>

                <div class="sa-section-title"><i class="fa-solid fa-users" style="color:#34d399"></i> User-Wachstum (letzte 30 Tage)</div>
                <div id="sa-user-growth" style="display:flex;flex-direction:column;gap:6px">
                    <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade…</div>
                </div>
            </div>

            <!-- PANEL: ADMIN-VERWALTUNG -->
            <div class="sa-inner-panel" id="sa-panel-admins">

                <!-- Stats Row -->
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px">
                    <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Gesamt</div><div class="sa-kpi-value" id="sa-admins-total" style="font-size:22px">—</div></div>
                    <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Co-Superadmins</div><div class="sa-kpi-value" id="sa-admins-cosupercount" style="font-size:22px;color:#fb923c">—</div></div>
                    <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Mit 2FA</div><div class="sa-kpi-value" id="sa-admins-2facount" style="font-size:22px;color:#34d399">—</div></div>
                    <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Nur-Lesen</div><div class="sa-kpi-value" id="sa-admins-rocount" style="font-size:22px;color:rgba(255,255,255,.4)">—</div></div>
                    <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Heute aktiv</div><div class="sa-kpi-value" id="sa-admins-todaycount" style="font-size:22px;color:#67e8f9">—</div></div>
                </div>

                <!-- Search + Filter -->
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <input type="text" id="sa-admins-search" placeholder="Admin suchen (E-Mail, Username)…" oninput="saFilterAdmins()" style="flex:1;min-width:180px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:9px 14px;color:#fff;font-size:12px;outline:none;transition:border-color .2s" onfocus="this.style.borderColor='rgba(251,191,36,.4)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                    <select id="sa-admins-filter-role" onchange="saFilterAdmins()" style="background:#1a1a2e;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:9px 14px;color:#fff;font-size:12px;outline:none;cursor:pointer">
                        <option value="">Alle Rollen</option>
                        <option value="super">👑 Superadmin</option>
                        <option value="cosuper">🛡️ Co-Superadmin</option>
                        <option value="regular">👤 Admin</option>
                    </select>
                    <select id="sa-admins-filter-2fa" onchange="saFilterAdmins()" style="background:#1a1a2e;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:9px 14px;color:#fff;font-size:12px;outline:none;cursor:pointer">
                        <option value="">Alle 2FA-Status</option>
                        <option value="yes">✅ 2FA aktiv</option>
                        <option value="no">⚠️ Kein 2FA</option>
                    </select>
                </div>

                <div class="sa-add-panel">
                    <div class="sa-section-title"><i class="fa-solid fa-user-plus" style="color:#67e8f9"></i> Neuen Admin hinzufügen</div>
                    <div class="sa-add-row">
                        <input class="sa-add-input" id="sa-new-admin-email" placeholder="E-Mail-Adresse des Benutzers" type="email" onkeydown="if(event.key==='Enter')saAddAdmin()">
                        <div style="position:relative">
                            <select id="sa-new-admin-role" style="display:none"></select>
                            <select id="sa-new-admin-role-vis" style="background:#1a1a2e;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:11px 16px;color:#fff;font-size:13px;outline:none;cursor:pointer">
                                <option value="admin">Regular Admin</option>
                                <option value="cosuper">Co-Superadmin</option>
                                <option value="readonly">👁️ Nur-Lesen</option>
                            </select>
                        </div>
                        <button class="sa-btn-add" onclick="saAddAdmin()"><i class="fa-solid fa-plus"></i> Admin ernennen</button>
                    </div>
                    <p style="font-size:11px;color:rgba(255,255,255,.2);margin-top:10px"><i class="fa-solid fa-info-circle" style="margin-right:5px"></i>Der Benutzer muss bereits registriert sein. Nur-Lesen: Darf alles sehen, aber nichts ändern.</p>
                </div>

                <!-- Admin-Aktivitäts-Übersicht -->
                <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:18px 20px">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px">
                        <div style="font-size:13px;font-weight:700;color:rgba(255,255,255,.7)"><i class="fa-solid fa-chart-simple" style="margin-right:8px;color:#67e8f9"></i>Admin-Aktivität (letzte 30 Tage)</div>
                        <button onclick="adminActivityLoad()" style="padding:6px 14px;border-radius:9px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.5);font-size:11px;cursor:pointer"><i class="fa-solid fa-rotate"></i></button>
                    </div>
                    <div id="admin-activity-table" style="display:flex;flex-direction:column;gap:6px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px;text-align:center"><i class="fa-solid fa-spinner fa-spin" style="margin-right:6px"></i>Lade...</div>
                    </div>
                </div>

                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-users-cog" style="color:#a78bfa"></i> Admin-Übersicht &amp; Berechtigungen</div>
                    <div class="sa-admin-grid" id="sa-admin-grid">
                        <div style="color:rgba(255,255,255,.2);font-size:13px;padding:20px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Admins...</div>
                    </div>
                </div>

                <!-- Rollen-Matrix -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-table" style="color:#67e8f9"></i> Rollen-Matrix</div>
                    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;overflow:hidden">
                        <div style="overflow-x:auto">
                            <table style="width:100%;border-collapse:collapse;min-width:600px">
                                <thead>
                                    <tr style="border-bottom:1px solid rgba(255,255,255,.07)">
                                        <th style="padding:12px 16px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.3);text-align:left">Berechtigung</th>
                                        <th style="padding:12px 16px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;text-align:center;color:#fbbf24">👑 Super</th>
                                        <th style="padding:12px 16px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;text-align:center;color:#fb923c">🛡️ Co-Super</th>
                                        <th style="padding:12px 16px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;text-align:center;color:#67e8f9">👤 Admin</th>
                                        <th style="padding:12px 16px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;text-align:center;color:rgba(255,255,255,.3)">👁️ Nur-Lesen</th>
                                    </tr>
                                </thead>
                                <tbody id="sa-role-matrix-tbody">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Admin-Detail-Modal (hidden) -->
                <div id="sa-admin-detail-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:99997;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(8px)">
                    <div style="background:linear-gradient(160deg,#0f0f1a,#1a1a2e);border:1px solid rgba(251,191,36,.2);border-radius:26px;padding:32px;max-width:560px;width:100%;max-height:90vh;overflow-y:auto;animation:modalPop .3s cubic-bezier(.34,1.56,.64,1)">
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:22px">
                            <div style="display:flex;align-items:center;gap:14px">
                                <div id="adm-modal-avatar" style="width:52px;height:52px;border-radius:16px;background:linear-gradient(135deg,#fbbf24,#f59e0b);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#000;flex-shrink:0">?</div>
                                <div>
                                    <div id="adm-modal-email" style="font-size:15px;font-weight:700;color:#fff;word-break:break-all">—</div>
                                    <div id="adm-modal-role-badge" style="margin-top:4px"></div>
                                </div>
                            </div>
                            <button onclick="document.getElementById('sa-admin-detail-modal').style.display='none'" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;width:34px;height:34px;color:rgba(255,255,255,.5);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center">✕</button>
                        </div>

                        <!-- KPI Mini Row -->
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px">
                            <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:13px;padding:12px;text-align:center">
                                <div style="font-size:9px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px">Aktionen (30d)</div>
                                <div id="adm-modal-actions" style="font-size:20px;font-weight:700;color:#67e8f9;font-family:'JetBrains Mono',monospace">—</div>
                            </div>
                            <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:13px;padding:12px;text-align:center">
                                <div style="font-size:9px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px">Letzter Login</div>
                                <div id="adm-modal-lastlogin" style="font-size:13px;font-weight:700;color:#fbbf24;font-family:'JetBrains Mono',monospace">—</div>
                            </div>
                            <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:13px;padding:12px;text-align:center">
                                <div style="font-size:9px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px">Status</div>
                                <div id="adm-modal-status" style="font-size:13px;font-weight:700;color:#34d399">Aktiv</div>
                            </div>
                        </div>

                        <!-- Activity Timeline -->
                        <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px"><i class="fa-solid fa-timeline" style="margin-right:6px;color:#a78bfa"></i>Letzte Aktionen</div>
                        <div id="adm-modal-timeline" style="display:flex;flex-direction:column;gap:6px;max-height:220px;overflow-y:auto;margin-bottom:20px">
                            <div style="color:rgba(255,255,255,.2);font-size:12px;padding:10px;text-align:center"><i class="fa-solid fa-spinner fa-spin"></i></div>
                        </div>

                        <!-- Actions -->
                        <div style="display:flex;gap:8px;flex-wrap:wrap">
                            <button id="adm-modal-promote-btn" onclick="admModalPromote()" style="flex:1;padding:10px;border-radius:12px;border:none;cursor:pointer;background:rgba(251,191,36,.12);color:#fbbf24;font-size:12px;font-weight:600;transition:all .15s" onmouseover="this.style.background='rgba(251,191,36,.22)'" onmouseout="this.style.background='rgba(251,191,36,.12)'"><i class="fa-solid fa-arrow-up"></i> Befördern</button>
                            <button id="adm-modal-demote-btn" onclick="admModalDemote()" style="flex:1;padding:10px;border-radius:12px;border:none;cursor:pointer;background:rgba(251,146,60,.1);color:#fb923c;font-size:12px;font-weight:600;transition:all .15s" onmouseover="this.style.background='rgba(251,146,60,.22)'" onmouseout="this.style.background='rgba(251,146,60,.1)'"><i class="fa-solid fa-arrow-down"></i> Degradieren</button>
                            <button onclick="admModalResetToken()" style="padding:10px 16px;border-radius:12px;border:none;cursor:pointer;background:rgba(103,232,249,.08);color:#67e8f9;font-size:12px;font-weight:600;transition:all .15s" onmouseover="this.style.background='rgba(103,232,249,.18)'" onmouseout="this.style.background='rgba(103,232,249,.08)'"><i class="fa-solid fa-rotate"></i> Token resetten</button>
                            <button onclick="admModalRemove()" style="padding:10px 16px;border-radius:12px;border:none;cursor:pointer;background:rgba(248,113,113,.08);color:#f87171;font-size:12px;font-weight:600;transition:all .15s" onmouseover="this.style.background='rgba(248,113,113,.18)'" onmouseout="this.style.background='rgba(248,113,113,.08)'"><i class="fa-solid fa-trash"></i> Entfernen</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PANEL: SICHERHEIT -->
            <div class="sa-inner-panel" id="sa-panel-security">
                <div class="sa-add-panel">
                    <div class="sa-section-title"><i class="fa-solid fa-map-pin" style="color:#fbbf24"></i> IP-Whitelist (Superadmin Zone)</div>
                    <div class="sa-add-row" style="margin-bottom:14px">
                        <input class="sa-add-input" id="sa-ip-input" placeholder="IP-Adresse (z.B. 123.45.67.89)" style="font-family:'JetBrains Mono',monospace" onkeydown="if(event.key==='Enter')saAddIP()">
                        <button class="sa-btn-add" onclick="saAddIP()" style="background:linear-gradient(135deg,#fbbf24,#f59e0b)"><i class="fa-solid fa-plus"></i> Hinzufügen</button>
                        <button onclick="saAddCurrentIP()" style="padding:11px 16px;border-radius:12px;border:1px solid rgba(52,211,153,.3);background:rgba(52,211,153,.08);color:#34d399;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap"><i class="fa-solid fa-location-dot"></i> Meine IP</button>
                    </div>
                    <div class="sa-ip-list" id="sa-ip-list"><div style="color:rgba(255,255,255,.2);font-size:12px">Lade IP-Whitelist...</div></div>
                </div>

                <!-- NEW: Brute-Force Monitor -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-chart-line" style="color:#f87171"></i> Brute-Force &amp; Login-Anomalien</div>
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:14px">
                        <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Zugriffe (24h)</div><div class="sa-kpi-value" id="sa-bf-24h" style="font-size:22px;color:#f87171">—</div></div>
                        <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Gesperrte IPs</div><div class="sa-kpi-value" id="sa-bf-banned" style="font-size:22px;color:#fbbf24">—</div></div>
                        <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Unique IPs</div><div class="sa-kpi-value" id="sa-bf-uniqueips" style="font-size:22px;color:#a78bfa">—</div></div>
                        <div class="sa-kpi" style="padding:13px 16px"><div class="sa-kpi-label">Top-Angreifer</div><div class="sa-kpi-value" id="sa-bf-topip" style="font-size:13px;color:#f87171;font-family:'JetBrains Mono',monospace">—</div></div>
                    </div>
                    <div id="sa-bf-log" style="display:flex;flex-direction:column;gap:6px;max-height:300px;overflow-y:auto">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px;text-align:center"><i class="fa-solid fa-spinner fa-spin" style="margin-right:6px"></i>Lade...</div>
                    </div>
                    <button onclick="saLoadBruteForce()" style="margin-top:10px;padding:7px 16px;border-radius:10px;border:1px solid rgba(248,113,113,.2);background:rgba(248,113,113,.06);color:#f87171;font-size:11px;font-weight:600;cursor:pointer"><i class="fa-solid fa-rotate"></i> Aktualisieren</button>
                </div>

                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-gear" style="color:#67e8f9"></i> Sicherheitseinstellungen</div>
                    <div class="sa-sec-grid">
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-clock" style="color:#fbbf24"></i> Session-Timeout</div>
                            <div class="sa-sec-card-desc">Nach wie vielen Minuten Inaktivität wird die SA-Zone automatisch gesperrt.</div>
                            <div class="sa-sec-row"><div class="sa-sec-label">Timeout (Minuten)</div><input type="number" class="sa-sec-input" id="sa-sec-timeout" value="30" min="5" max="480"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-key" style="color:#a78bfa"></i> Login-Versuche</div>
                            <div class="sa-sec-card-desc">Maximale fehlgeschlagene Versuche bevor die Zone für 10 Minuten gesperrt wird.</div>
                            <div class="sa-sec-row"><div class="sa-sec-label">Max. Versuche</div><input type="number" class="sa-sec-input" id="sa-sec-maxattempts" value="5" min="1" max="20"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-bell" style="color:#34d399"></i> Benachrichtigungen</div>
                            <div class="sa-sec-card-desc">E-Mail bei jedem Zugriff auf die Superadmin Zone.</div>
                            <div class="sa-sec-row"><div class="sa-sec-label">E-Mail bei Zugriff</div><label class="sa-switch"><input type="checkbox" id="sa-sec-notify" checked><span class="sa-switch-sl"></span></label></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-shield-halved" style="color:#f87171"></i> IP-Pflicht</div>
                            <div class="sa-sec-card-desc">Zugang nur wenn IP in Whitelist — auch wenn die Whitelist leer ist.</div>
                            <div class="sa-sec-row"><div class="sa-sec-label">IP-Check erzwingen</div><label class="sa-switch"><input type="checkbox" id="sa-sec-force-ip"><span class="sa-switch-sl"></span></label></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-file-lines" style="color:#67e8f9"></i> Erweitertes Logging</div>
                            <div class="sa-sec-card-desc">Alle SA-Änderungen werden in einem separaten Sicherheitslog gespeichert.</div>
                            <div class="sa-sec-row"><div class="sa-sec-label">Detailliertes Logging</div><label class="sa-switch"><input type="checkbox" id="sa-sec-verbose" checked><span class="sa-switch-sl"></span></label></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-user-slash" style="color:#f59e0b"></i> Auto-Sperre</div>
                            <div class="sa-sec-card-desc">SA-Zone nach jedem Tab-Wechsel automatisch sperren (maximale Sicherheit).</div>
                            <div class="sa-sec-row"><div class="sa-sec-label">Immer sperren</div><label class="sa-switch"><input type="checkbox" id="sa-sec-auto-lock"><span class="sa-switch-sl"></span></label></div>
                        </div>
                    </div>
                </div>

                <!-- Brute-Force-Schutz -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-shield-virus" style="color:#f87171"></i> Brute-Force-Schutz</div>
                    <div class="sa-sec-grid">
                        <div class="sa-sec-card" style="border-color:rgba(248,113,113,.15)">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-lock-open" style="color:#f87171"></i> Rate-Limiting</div>
                            <div class="sa-sec-card-desc">Wie viele Bestellungen / Aktionen pro Minute erlaubt sind, bevor ein Nutzer temporär gesperrt wird.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Max. Aktionen/Min.</span><input type="number" class="sa-sec-input" id="sa-sec-rate-limit" value="30" min="5" max="200"></div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Sperrzeit (Minuten)</span><input type="number" class="sa-sec-input" id="sa-sec-rate-lockout" value="15" min="1" max="1440"></div>
                        </div>
                        <div class="sa-sec-card" style="border-color:rgba(248,113,113,.15)">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-robot" style="color:#a78bfa"></i> Bot-Schutz</div>
                            <div class="sa-sec-card-desc">Verdächtige IPs (viele Fehlversuche) automatisch bannen.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Auto-Ban aktiv</span><label class="sa-switch"><input type="checkbox" id="sa-sec-autoban" checked><span class="sa-switch-sl"></span></label></div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Fehlversuche vor Ban</span><input type="number" class="sa-sec-input" id="sa-sec-autoban-threshold" value="10" min="3" max="50"></div>
                        </div>
                        <div class="sa-sec-card" style="border-color:rgba(248,113,113,.15)">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-network-wired" style="color:#67e8f9"></i> Geo-Blocking</div>
                            <div class="sa-sec-card-desc">Bestellungen aus bestimmten Ländern blockieren (kommagetrennte ISO-2-Codes).</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Aktiv</span><label class="sa-switch"><input type="checkbox" id="sa-sec-geo-active"><span class="sa-switch-sl"></span></label></div>
                            <input type="text" id="sa-sec-geo-blocklist" placeholder="z.B. RU,CN,KP" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:8px 12px;color:#fff;font-size:12px;outline:none;box-sizing:border-box;margin-top:8px;font-family:'JetBrains Mono',monospace">
                        </div>
                        <div class="sa-sec-card" id="sa-ev-card" style="border-color:rgba(52,211,153,.2);grid-column:1/-1">
                            <div class="sa-sec-card-title">
                                <i class="fa-solid fa-envelope-circle-check" style="color:#34d399"></i>
                                E-Mail-Verifizierung bei Registrierung
                                <span id="sa-ev-status-badge" style="margin-left:auto;font-size:10px;font-weight:800;padding:3px 10px;border-radius:99px;background:rgba(52,211,153,.15);color:#34d399;border:1px solid rgba(52,211,153,.3)">
                                    <i class="fa-solid fa-circle" style="font-size:7px;margin-right:4px"></i>AKTIV
                                </span>
                            </div>
                            <div class="sa-sec-card-desc" style="margin-bottom:16px">
                                Steuert ob neue Nutzer nach der Registrierung ihre E-Mail-Adresse bestätigen müssen, bevor sie sich einloggen können. Deaktivieren ermöglicht sofortigen Zugang ohne Bestätigung.
                            </div>
                            <div class="sa-sec-row" style="margin-bottom:12px">
                                <span class="sa-sec-label" style="font-size:13px;font-weight:600;color:#fff">E-Mail-Bestätigung erforderlich</span>
                                <label class="sa-switch" style="width:50px;height:28px">
                                    <input type="checkbox" id="sa-sec-email-verify" checked onchange="saPreviewEmailVerifyChange(this.checked)">
                                    <span class="sa-switch-sl" style="border-radius:99px"></span>
                                </label>
                            </div>
                            <div id="sa-ev-preview" style="border-radius:14px;padding:12px 16px;display:flex;align-items:flex-start;gap:12px;font-size:12px;line-height:1.55;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);color:rgba(255,255,255,.7)">
                                <i class="fa-solid fa-circle-info" style="color:#34d399;margin-top:1px;flex-shrink:0"></i>
                                <span id="sa-ev-preview-text">Neue Nutzer erhalten nach der Registrierung eine Bestätigungs-E-Mail und müssen diese bestätigen bevor sie sich einloggen können.</span>
                            </div>
                            <div style="display:flex;align-items:center;gap:8px;margin-top:14px">
                                <i class="fa-solid fa-users" style="font-size:11px;color:rgba(255,255,255,.3)"></i>
                                <span style="font-size:11px;color:rgba(255,255,255,.3)">Gilt nur für <strong style="color:rgba(255,255,255,.5)">neu registrierte</strong> Nutzer – bestehende Accounts sind nicht betroffen.</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Login-Historie -->
                <div>
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
                        <div class="sa-section-title" style="margin:0;flex:1"><i class="fa-solid fa-clock-rotate-left" style="color:#a78bfa"></i> SA-Login-Historie</div>
                        <button onclick="secLoadLoginHistory()" style="padding:6px 14px;border-radius:9px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.5);font-size:11px;cursor:pointer"><i class="fa-solid fa-rotate"></i></button>
                    </div>
                    <div id="sec-login-history" style="display:flex;flex-direction:column;gap:6px;margin-top:12px;max-height:340px;overflow-y:auto">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px;text-align:center"><i class="fa-solid fa-spinner fa-spin" style="margin-right:6px"></i>Lade Login-Historie...</div>
                    </div>
                </div>

                <button onclick="saSaveSecuritySettings()" style="margin-top:16px;padding:12px 28px;border-radius:14px;border:none;cursor:pointer;background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;font-weight:700;font-size:13px">
                    <i class="fa-solid fa-floppy-disk"></i> &nbsp;Sicherheitseinstellungen speichern
                </button>
            </div>

            <!-- PANEL: SESSION MONITOR -->
            <div class="sa-inner-panel" id="sa-panel-sessions">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:4px">
                    <div class="sa-section-title" style="margin:0;flex:1"><i class="fa-solid fa-eye" style="color:#34d399"></i> Session Monitor</div>
                    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                        <div id="sa-sess-counts" style="font-size:12px;color:rgba(255,255,255,.3)"></div>
                        <label style="display:flex;align-items:center;gap:6px;font-size:11px;color:rgba(255,255,255,.4);cursor:pointer">
                            <input type="checkbox" id="sess-autorefresh" onchange="sessToggleAutorefresh(this)" style="accent-color:#67e8f9"> Auto-Refresh (30s)
                        </label>
                        <button onclick="saLoadSessions()" style="padding:8px 16px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);color:rgba(255,255,255,.6);font-size:12px;cursor:pointer"><i class="fa-solid fa-rotate"></i> Aktualisieren</button>
                        <button onclick="sessKillAllGuests()" style="padding:8px 16px;border-radius:10px;border:1px solid rgba(248,113,113,.25);background:rgba(248,113,113,.07);color:#f87171;font-size:12px;font-weight:600;cursor:pointer"><i class="fa-solid fa-user-slash"></i> Alle Gäste entfernen</button>
                    </div>
                </div>
                <!-- KPI Strip -->
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px" id="sess-kpi-strip">
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Live aktiv</div><div class="sa-kpi-value" id="sess-kpi-live" style="font-size:22px;color:#34d399">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Gesamt (2h)</div><div class="sa-kpi-value" id="sess-kpi-total" style="font-size:22px">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Eingeloggt</div><div class="sa-kpi-value" id="sess-kpi-users" style="font-size:22px;color:#67e8f9">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Gäste</div><div class="sa-kpi-value" id="sess-kpi-guests" style="font-size:22px;color:rgba(255,255,255,.4)">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Mit Warenkorb</div><div class="sa-kpi-value" id="sess-kpi-cart" style="font-size:22px;color:#fbbf24">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Admins online</div><div class="sa-kpi-value" id="sess-kpi-admins" style="font-size:22px;color:#fbbf24">—</div></div>
                </div>
                <!-- Filter Tabs -->
                <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <button class="sa-inner-tab active" id="sess-tab-all"    onclick="saSessionFilter('all',this)"    style="padding:5px 14px;font-size:11px">Alle</button>
                    <button class="sa-inner-tab"        id="sess-tab-admins" onclick="saSessionFilter('admins',this)" style="padding:5px 14px;font-size:11px;color:rgba(251,191,36,.7)">👑 Admins</button>
                    <button class="sa-inner-tab"        id="sess-tab-guests" onclick="saSessionFilter('guests',this)" style="padding:5px 14px;font-size:11px">Gäste</button>
                    <button class="sa-inner-tab"        id="sess-tab-users"  onclick="saSessionFilter('users',this)"  style="padding:5px 14px;font-size:11px">Eingeloggte User</button>
                    <button class="sa-inner-tab"        id="sess-tab-cart"   onclick="saSessionFilter('cart',this)"   style="padding:5px 14px;font-size:11px;color:rgba(103,232,249,.7)">🛒 Mit Warenkorb</button>
                    <button class="sa-inner-tab"        id="sess-tab-live"   onclick="saSessionFilter('live',this)"   style="padding:5px 14px;font-size:11px;color:rgba(52,211,153,.8)">🟢 Live</button>
                </div>

                <!-- Session-Geo-Übersicht -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
                    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:18px 20px">
                        <div style="font-size:12px;font-weight:700;color:rgba(255,255,255,.5);margin-bottom:12px;text-transform:uppercase;letter-spacing:.07em"><i class="fa-solid fa-map-location-dot" style="margin-right:6px;color:#67e8f9"></i>Top-Seiten (aktive Sessions)</div>
                        <div id="sess-top-pages" style="display:flex;flex-direction:column;gap:6px">
                            <div style="color:rgba(255,255,255,.2);font-size:11px;text-align:center;padding:8px">—</div>
                        </div>
                    </div>
                    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:18px 20px">
                        <div style="font-size:12px;font-weight:700;color:rgba(255,255,255,.5);margin-bottom:12px;text-transform:uppercase;letter-spacing:.07em"><i class="fa-solid fa-chart-pie" style="margin-right:6px;color:#a78bfa"></i>Session-Typen</div>
                        <div id="sess-type-breakdown" style="display:flex;flex-direction:column;gap:8px">
                            <div style="color:rgba(255,255,255,.2);font-size:11px;text-align:center;padding:8px">—</div>
                        </div>
                    </div>
                </div>
                <div class="sa-sess-list" id="sa-sess-list" style="max-height:480px;overflow-y:auto">
                    <div style="color:rgba(255,255,255,.2);font-size:13px;padding:16px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Sessions...</div>
                </div>
                <div style="background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.05);border-radius:16px;padding:14px">
                    <div style="font-size:11px;color:rgba(255,255,255,.25);line-height:1.7"><i class="fa-solid fa-circle-info" style="margin-right:6px;color:rgba(103,232,249,.4)"></i>Grüner Punkt = aktiv in letzten 90 Sek. · „Session beenden" löscht den Presence-Eintrag aus Firestore. · Alle Presence-Daten kommen aus Firestore.</div>
                </div>
            </div>

            <!-- PANEL: BACKUP & EXPORT -->
            <div class="sa-inner-panel" id="sa-panel-backup">

                <!-- ── Auto-Backup Status Card ── -->
                <div id="bkp-status-card" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;padding:20px 24px;border-radius:20px;background:linear-gradient(135deg,rgba(103,232,249,.06),rgba(103,232,249,.02));border:1px solid rgba(103,232,249,.18);margin-bottom:4px">
                    <div style="display:flex;align-items:center;gap:14px">
                        <div style="width:46px;height:46px;border-radius:14px;background:rgba(103,232,249,.1);border:1px solid rgba(103,232,249,.2);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0">🔄</div>
                        <div>
                            <div style="font-size:14px;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px">
                                Auto-Backup
                                <span id="bkp-auto-badge" style="font-size:10px;padding:2px 9px;border-radius:99px;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.3);font-weight:700">DEAKTIVIERT</span>
                            </div>
                            <div style="font-size:11px;color:rgba(255,255,255,.35);margin-top:3px" id="bkp-next-label">Nächster Backup: —</div>
                        </div>
                    </div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
                        <div style="text-align:right">
                            <div style="font-size:10px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.06em">Letzter Backup</div>
                            <div style="font-size:13px;font-weight:700;color:#67e8f9;font-family:'JetBrains Mono',monospace" id="bkp-last-label">—</div>
                        </div>
                        <button onclick="bkpRunNow()" id="bkp-run-btn" style="display:flex;align-items:center;gap:8px;padding:10px 18px;border-radius:13px;background:rgba(103,232,249,.1);border:1px solid rgba(103,232,249,.25);color:#67e8f9;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(103,232,249,.2)'" onmouseout="this.style.background='rgba(103,232,249,.1)'">
                            <i class="fa-solid fa-play"></i> Jetzt sichern
                        </button>
                    </div>
                </div>

                <!-- ── KPI Strip ── -->
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px">
                    <div class="sa-kpi" style="padding:14px 18px">
                        <div class="sa-kpi-icon" style="font-size:18px;margin-bottom:6px">🗄️</div>
                        <div class="sa-kpi-label">Backups gespeichert</div>
                        <div class="sa-kpi-value" id="bkp-kpi-count" style="font-size:22px">—</div>
                        <div class="sa-kpi-sub" id="bkp-kpi-sub">in Firestore</div>
                    </div>
                    <div class="sa-kpi" style="padding:14px 18px">
                        <div class="sa-kpi-icon" style="font-size:18px;margin-bottom:6px">⚖️</div>
                        <div class="sa-kpi-label">Gesamtgröße</div>
                        <div class="sa-kpi-value" id="bkp-kpi-size" style="font-size:22px">—</div>
                        <div class="sa-kpi-sub">aller Backups</div>
                    </div>
                    <div class="sa-kpi" style="padding:14px 18px">
                        <div class="sa-kpi-icon" style="font-size:18px;margin-bottom:6px">✅</div>
                        <div class="sa-kpi-label">Erfolgreiche</div>
                        <div class="sa-kpi-value" id="bkp-kpi-ok" style="font-size:22px;color:#34d399">—</div>
                        <div class="sa-kpi-sub">letzte 30 Tage</div>
                    </div>
                    <div class="sa-kpi" style="padding:14px 18px">
                        <div class="sa-kpi-icon" style="font-size:18px;margin-bottom:6px">🔁</div>
                        <div class="sa-kpi-label">Intervall</div>
                        <div class="sa-kpi-value" id="bkp-kpi-interval" style="font-size:22px;color:#fbbf24">—h</div>
                        <div class="sa-kpi-sub" id="bkp-kpi-retention-lbl">Aufbewahrung: —</div>
                    </div>
                </div>

                <!-- ── Configuration ── -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-sliders" style="color:#fbbf24"></i> Auto-Backup Konfiguration</div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">

                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-power-off" style="color:#34d399"></i> Auto-Backup aktivieren</div>
                            <div class="sa-sec-card-desc">Automatisch täglich alle Firestore-Collections sichern und in der Datenbank speichern.</div>
                            <div class="sa-sec-row">
                                <span class="sa-sec-label">Auto-Backup</span>
                                <label class="sa-switch"><input type="checkbox" id="bkp-cfg-enabled" onchange="bkpSaveConfig()"><span class="sa-switch-sl"></span></label>
                            </div>
                        </div>

                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-clock" style="color:#67e8f9"></i> Backup-Intervall</div>
                            <div class="sa-sec-card-desc">Wie oft soll automatisch gesichert werden?</div>
                            <div class="sa-sec-row">
                                <span class="sa-sec-label">Alle (Stunden)</span>
                                <input type="number" class="sa-sec-input" id="bkp-cfg-interval" value="24" min="1" max="168" onchange="bkpSaveConfig()">
                            </div>
                        </div>

                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-trash-clock" style="color:#a78bfa"></i> Aufbewahrungsdauer</div>
                            <div class="sa-sec-card-desc">Alte Backups werden automatisch nach X Tagen gelöscht.</div>
                            <div class="sa-sec-row">
                                <span class="sa-sec-label">Behalten (Tage)</span>
                                <input type="number" class="sa-sec-input" id="bkp-cfg-retention" value="30" min="1" max="365" onchange="bkpSaveConfig()">
                            </div>
                        </div>

                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-layer-group" style="color:#f87171"></i> Max. Backups</div>
                            <div class="sa-sec-card-desc">Maximale Anzahl gespeicherter Backups (älteste werden automatisch gelöscht).</div>
                            <div class="sa-sec-row">
                                <span class="sa-sec-label">Max. Anzahl</span>
                                <input type="number" class="sa-sec-input" id="bkp-cfg-maxcount" value="10" min="1" max="50" onchange="bkpSaveConfig()">
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ── Collections Selector ── -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-table-list" style="color:#67e8f9"></i> Gesicherte Collections</div>
                    <div id="bkp-collections-grid" style="display:flex;flex-wrap:wrap;gap:8px">
                        <!-- rendered by JS -->
                    </div>
                </div>

                <!-- ── Backup-History ── -->
                <div>
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
                        <div class="sa-section-title" style="margin:0;flex:1"><i class="fa-solid fa-clock-rotate-left" style="color:#a78bfa"></i> Backup-Verlauf</div>
                        <div style="display:flex;gap:8px">
                            <button onclick="bkpInit()" style="padding:7px 14px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.5);font-size:11px;cursor:pointer;font-weight:600"><i class="fa-solid fa-rotate"></i> Aktualisieren</button>
                            <button onclick="bkpPurgeOld()" style="padding:7px 14px;border-radius:10px;border:1px solid rgba(248,113,113,.2);background:rgba(248,113,113,.06);color:#f87171;font-size:11px;cursor:pointer;font-weight:600"><i class="fa-solid fa-broom"></i> Alte löschen</button>
                        </div>
                    </div>
                    <div id="bkp-history-list" style="display:flex;flex-direction:column;gap:8px;margin-top:12px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:20px;text-align:center"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Backup-Verlauf...</div>
                    </div>
                </div>

                <!-- ── Manueller Export ── -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-download" style="color:#67e8f9"></i> Einzelne Collections exportieren</div>
                    <div class="sa-export-grid">
                        <div class="sa-export-card">
                            <div class="sa-export-icon">📦</div><div class="sa-export-title">Bestellungen</div>
                            <div class="sa-export-desc">Alle Bestellungen mit Kundendaten, Produkten und Status.</div>
                            <button class="sa-export-btn" onclick="saExport('orders','json')"><i class="fa-solid fa-file-code"></i> JSON</button>
                            <button class="sa-export-btn" onclick="saExport('orders','csv')" style="background:rgba(167,139,250,.1);color:#a78bfa"><i class="fa-solid fa-file-csv"></i> CSV</button>
                        </div>
                        <div class="sa-export-card">
                            <div class="sa-export-icon">👤</div><div class="sa-export-title">Benutzer</div>
                            <div class="sa-export-desc">E-Mail, Punkte, Rolle und Registrierungsdatum.</div>
                            <button class="sa-export-btn" onclick="saExport('users','json')"><i class="fa-solid fa-file-code"></i> JSON</button>
                            <button class="sa-export-btn" onclick="saExport('users','csv')" style="background:rgba(167,139,250,.1);color:#a78bfa"><i class="fa-solid fa-file-csv"></i> CSV</button>
                        </div>
                        <div class="sa-export-card">
                            <div class="sa-export-icon">🛍️</div><div class="sa-export-title">Produkte</div>
                            <div class="sa-export-desc">Produktkatalog mit Preisen, Lagerbestand, Kategorien.</div>
                            <button class="sa-export-btn" onclick="saExport('products','json')"><i class="fa-solid fa-file-code"></i> JSON</button>
                            <button class="sa-export-btn" onclick="saExport('products','csv')" style="background:rgba(167,139,250,.1);color:#a78bfa"><i class="fa-solid fa-file-csv"></i> CSV</button>
                        </div>
                        <div class="sa-export-card">
                            <div class="sa-export-icon">📋</div><div class="sa-export-title">Admin-Logs</div>
                            <div class="sa-export-desc">Alle Admin-Aktionen für Audits und Compliance.</div>
                            <button class="sa-export-btn" onclick="saExport('admin_logs','json')"><i class="fa-solid fa-file-code"></i> JSON</button>
                            <button class="sa-export-btn" onclick="saExport('admin_logs','csv')" style="background:rgba(167,139,250,.1);color:#a78bfa"><i class="fa-solid fa-file-csv"></i> CSV</button>
                        </div>
                        <div class="sa-export-card" style="border-color:rgba(251,191,36,.2)">
                            <div class="sa-export-icon">💾</div><div class="sa-export-title">Vollbackup (Download)</div>
                            <div class="sa-export-desc">Alle Collections in einer JSON-Datei — lokal speichern.</div>
                            <button class="sa-export-btn" onclick="saExportFull()" style="background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.2)"><i class="fa-solid fa-download"></i> Vollbackup herunterladen</button>
                        </div>
                        <div class="sa-export-card">
                            <div class="sa-export-icon">⭐</div><div class="sa-export-title">Bewertungen</div>
                            <div class="sa-export-desc">Alle Bewertungen mit Status und Zeitstempeln.</div>
                            <button class="sa-export-btn" onclick="saExport('reviews','json')"><i class="fa-solid fa-file-code"></i> JSON</button>
                            <button class="sa-export-btn" onclick="saExport('reviews','csv')" style="background:rgba(167,139,250,.1);color:#a78bfa"><i class="fa-solid fa-file-csv"></i> CSV</button>
                        </div>
                    </div>
                </div>

                <!-- Restore Modal -->
                <div id="bkp-restore-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);backdrop-filter:blur(12px);z-index:99999;align-items:center;justify-content:center">
                    <div style="background:linear-gradient(160deg,#0f0f1a,#1a1a2e);border:1px solid rgba(248,113,113,.25);border-radius:28px;padding:36px;width:100%;max-width:460px;animation:modalPop .3s cubic-bezier(0.34,1.56,0.64,1)">
                        <div style="width:56px;height:56px;border-radius:16px;background:rgba(248,113,113,.12);border:1px solid rgba(248,113,113,.3);display:flex;align-items:center;justify-content:center;font-size:24px;margin:0 auto 20px">⚠️</div>
                        <div style="font-family:'Orbitron',sans-serif;font-size:16px;font-weight:700;color:#f87171;text-align:center;margin-bottom:8px">Backup wiederherstellen</div>
                        <div style="font-size:11px;color:rgba(255,255,255,.35);text-align:center;line-height:1.6;margin-bottom:24px" id="bkp-restore-desc">—</div>
                        <div style="background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.2);border-radius:12px;padding:12px 14px;margin-bottom:20px;font-size:11px;color:rgba(248,113,113,.8);line-height:1.6">
                            <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px"></i><strong>Achtung:</strong> Aktuelle Daten werden bei Bestätigung durch den Backup-Stand ersetzt. Diese Aktion kann nicht rückgängig gemacht werden.
                        </div>
                        <div style="display:flex;gap:10px">
                            <button onclick="document.getElementById('bkp-restore-modal').style.display='none'" style="flex:1;padding:12px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);color:rgba(255,255,255,.6);font-size:13px;font-weight:600;cursor:pointer">Abbrechen</button>
                            <button onclick="bkpConfirmRestore()" style="flex:1;padding:12px;border-radius:12px;border:none;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-size:13px;font-weight:700;cursor:pointer" id="bkp-restore-confirm-btn"><i class="fa-solid fa-rotate-left"></i> Wiederherstellen</button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- PANEL: ADMIN LOGS (aus Tab 6 hierher verschoben) -->
            <!-- PANEL: IP-SICHERHEIT & BANN -->
            <div class="sa-inner-panel" id="sa-panel-ipsec">
                <!-- Header mit Refresh + manuellem Ban -->
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:20px">
                    <div class="sa-section-title" style="margin:0">
                        <i class="fa-solid fa-ban" style="color:#f87171"></i> IP-Sicherheit &amp; Bann
                    </div>
                    <button class="lg-btn lg-btn-ghost" onclick="loadUnauthorizedLogs();loadBannedIPs()">
                        <i class="fa-solid fa-rotate-right"></i> Refresh
                    </button>
                </div>

                <!-- Manueller Bann -->
                <div class="sa-add-panel" style="margin-bottom:20px;background:rgba(239,68,68,.05);border-color:rgba(239,68,68,.2)">
                    <div class="sa-section-title" style="color:#f87171"><i class="fa-solid fa-ban"></i> IP manuell bannen</div>
                    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                        <input class="sa-add-input" id="sa-manual-ban-ip" placeholder="IP-Adresse (z.B. 1.2.3.4)"
                            style="font-family:'JetBrains Mono',monospace;flex:1;min-width:180px"
                            onkeydown="if(event.key==='Enter')document.getElementById('sa-manual-ban-open').click()">
                        <button id="sa-manual-ban-open"
                            style="padding:11px 20px;border-radius:12px;border:none;cursor:pointer;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-weight:700;font-size:13px;white-space:nowrap"
                            onclick="(function(){
                                const ip = document.getElementById('sa-manual-ban-ip').value.trim();
                                if (!ip) { showToast('⚠️ Bitte eine IP eingeben', 'error'); return; }
                                openBanIPModal(ip);
                            })()">
                            <i class="fa-solid fa-ban"></i> Bannen
                        </button>
                    </div>
                </div>

                <!-- Zweispaltiges Layout: Zugriffsversuche + Gebannte IPs -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">

                    <!-- Zugriffsversuche -->
                    <div class="lg-section" style="border-color:rgba(248,113,113,.15)">
                        <div class="lg-section-hdr" style="border-color:rgba(248,113,113,.1)">
                            <div class="lg-section-title" style="color:var(--lg-red)">
                                <i class="fa-solid fa-shield-halved"></i> Zugriffsversuche
                            </div>
                            <div style="display:flex;gap:8px;align-items:center">
                                <span class="lg-counter-badge" id="lg-threat-badge" style="background:rgba(248,113,113,.08);color:var(--lg-red)">—</span>
                                <button class="lg-btn lg-btn-red" onclick="clearUnauthorizedLogs()"><i class="fa-solid fa-trash"></i> Leeren</button>
                            </div>
                        </div>
                        <div class="lg-section-body" id="unauthorized-logs-container">
                            <div class="lg-empty"><span class="lg-spinner"></span> Lade...</div>
                        </div>
                    </div>

                    <!-- Gebannte IPs -->
                    <div class="lg-section" style="border-color:rgba(248,113,113,.12)">
                        <div class="lg-section-hdr" style="border-color:rgba(248,113,113,.08)">
                            <div class="lg-section-title" style="color:var(--lg-red)">
                                <i class="fa-solid fa-ban"></i> Gebannte IPs
                            </div>
                            <div style="display:flex;gap:8px;align-items:center">
                                <span class="lg-counter-badge" id="lg-ban-badge" style="background:rgba(248,113,113,.08);color:var(--lg-red)">—</span>
                                <button class="lg-btn lg-btn-ghost" onclick="loadBannedIPs()"><i class="fa-solid fa-rotate-right"></i></button>
                            </div>
                        </div>
                        <div class="lg-section-body" id="banned-ips-container">
                            <div class="lg-empty"><span class="lg-spinner"></span> Lade...</div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- PANEL: ADMIN LOGS — ENTFERNT (jetzt in Tab 17 für alle Admins) -->

            <div class="sa-inner-panel" id="sa-panel-actlog">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:4px">
                    <div class="sa-section-title" style="margin:0;flex:1"><i class="fa-solid fa-scroll" style="color:#a78bfa"></i> Superadmin-Aktivitätslog</div>
                    <div style="display:flex;gap:8px">
                        <button onclick="saLoadActivityLog()" style="padding:8px 14px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);color:rgba(255,255,255,.6);font-size:12px;cursor:pointer"><i class="fa-solid fa-rotate"></i></button>
                        <button onclick="saExport('admin_logs','csv')" style="padding:8px 14px;border-radius:10px;border:1px solid rgba(167,139,250,.2);background:rgba(167,139,250,.07);color:#a78bfa;font-size:12px;cursor:pointer"><i class="fa-solid fa-download"></i> Export</button>
                    </div>
                </div>

                <!-- Stats-Header -->
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-bottom:4px" id="actlog-stats">
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Gesamt (200)</div><div class="sa-kpi-value" id="actlog-total" style="font-size:22px">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Heute</div><div class="sa-kpi-value" id="actlog-today" style="font-size:22px;color:#67e8f9">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px;cursor:pointer" onclick="saFilterLog('danger',document.querySelector('#sa-panel-actlog button[onclick*=danger]'))" title="Auf Danger filtern"><div class="sa-kpi-label">Danger</div><div class="sa-kpi-value" id="actlog-danger" style="font-size:22px;color:#f87171">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Exports</div><div class="sa-kpi-value" id="actlog-exports" style="font-size:22px;color:#a78bfa">—</div></div>
                    <div class="sa-kpi" style="padding:12px 16px"><div class="sa-kpi-label">Letzter Zugriff</div><div class="sa-kpi-value" id="actlog-lastaccess" style="font-size:13px;color:#fbbf24;font-family:'JetBrains Mono',monospace">—</div></div>
                </div>

                <!-- Filter + View Toggle -->
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                    <div style="display:flex;gap:6px;flex-wrap:wrap;flex:1">
                        <button class="sa-inner-tab active" onclick="saFilterLog('all',this)" style="padding:5px 12px;font-size:11px">Alle</button>
                        <button class="sa-inner-tab" onclick="saFilterLog('access',this)" style="padding:5px 12px;font-size:11px;color:rgba(52,211,153,.6)">Zugriffe</button>
                        <button class="sa-inner-tab" onclick="saFilterLog('admin',this)" style="padding:5px 12px;font-size:11px;color:rgba(103,232,249,.6)">Admin-Änderungen</button>
                        <button class="sa-inner-tab" onclick="saFilterLog('export',this)" style="padding:5px 12px;font-size:11px;color:rgba(167,139,250,.6)">Exports</button>
                        <button class="sa-inner-tab" onclick="saFilterLog('danger',this)" style="padding:5px 12px;font-size:11px;color:rgba(248,113,113,.6)">Danger</button>
                    </div>
                    <!-- Zeitraum-Filter -->
                    <select id="actlog-period-filter" onchange="saFilterLogPeriod(this.value)" style="background:#1a1a2e;border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:7px 12px;color:#fff;font-size:11px;outline:none;cursor:pointer">
                        <option value="0">Alle Zeit</option>
                        <option value="1">24 Stunden</option>
                        <option value="7" selected>7 Tage</option>
                        <option value="30">30 Tage</option>
                    </select>
                    <!-- View Toggle -->
                    <div style="display:flex;gap:4px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:4px">
                        <button id="actlog-view-list" onclick="actlogSetView('list',this)" style="padding:5px 10px;border-radius:7px;border:none;cursor:pointer;background:rgba(255,255,255,.08);color:#fff;font-size:11px;transition:all .15s"><i class="fa-solid fa-list"></i></button>
                        <button id="actlog-view-timeline" onclick="actlogSetView('timeline',this)" style="padding:5px 10px;border-radius:7px;border:none;cursor:pointer;background:transparent;color:rgba(255,255,255,.4);font-size:11px;transition:all .15s"><i class="fa-solid fa-timeline"></i></button>
                    </div>
                </div>

                <!-- List View -->
                <div id="actlog-view-list-panel">
                    <div class="sa-log-list" id="sa-act-log" style="max-height:400px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Log...</div>
                    </div>
                </div>

                <!-- Timeline View (hidden by default) -->
                <div id="actlog-view-timeline-panel" style="display:none">
                    <div id="actlog-timeline-view" style="position:relative;padding-left:28px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:12px">Wechsle in Timeline-Ansicht um Einträge zu sehen.</div>
                    </div>
                </div>
            </div>

            <!-- PANEL: DANGER ZONE -->
            <div class="sa-inner-panel" id="sa-panel-danger">
                <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.2);border-radius:16px;margin-bottom:4px">
                    <i class="fa-solid fa-triangle-exclamation" style="font-size:22px;color:#f87171;flex-shrink:0"></i>
                    <div>
                        <div style="font-size:13px;font-weight:700;color:#f87171">Danger Zone – Irreversible Aktionen</div>
                        <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:3px;line-height:1.5">Diese Aktionen können nicht rückgängig gemacht werden. Alle Änderungen werden protokolliert.</div>
                    </div>
                </div>

                <div class="sa-section-title"><i class="fa-solid fa-bolt" style="color:#f87171"></i> Shop-Steuerung</div>
                <div class="sa-danger-grid">
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-power-off"></i> Shop sofort schließen</div>
                        <div class="sa-danger-desc">Schließt den Shop sofort für alle Kunden. Admins haben weiterhin Zugriff.</div>
                        <button class="sa-danger-btn" onclick="saDangerShopClose()"><i class="fa-solid fa-power-off"></i> Shop schließen</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-door-open"></i> Shop sofort öffnen</div>
                        <div class="sa-danger-desc">Öffnet den Shop sofort wieder für alle Kunden.</div>
                        <button class="sa-danger-btn" onclick="saDangerShopOpen()" style="border-color:rgba(52,211,153,.3);background:rgba(52,211,153,.08);color:#34d399"><i class="fa-solid fa-door-open"></i> Shop öffnen</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-ticket"></i> Alle Gutscheine deaktivieren</div>
                        <div class="sa-danger-desc">Setzt alle aktiven Gutscheine auf inaktiv. Nützlich bei Missbrauch oder Fehlern.</div>
                        <button class="sa-danger-btn" onclick="saDangerDisableAllCoupons()" style="border-color:rgba(251,191,36,.3);background:rgba(251,191,36,.07);color:#fbbf24"><i class="fa-solid fa-ticket"></i> Alle deaktivieren</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-box-open"></i> Alle Produkte deaktivieren</div>
                        <div class="sa-danger-desc">Setzt alle Produkte auf "nicht verfügbar". Kunden können nichts kaufen. Reversibel.</div>
                        <button class="sa-danger-btn" onclick="saDangerDeactivateAllProducts()" style="border-color:rgba(251,191,36,.3);background:rgba(251,191,36,.07);color:#fbbf24"><i class="fa-solid fa-box-open"></i> Alle deaktivieren</button>
                    </div>
                </div>

                <div class="sa-section-title" style="margin-top:8px"><i class="fa-solid fa-broom" style="color:#f87171"></i> Daten zurücksetzen</div>
                <div class="sa-danger-grid">
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-shield-halved"></i> Alle IP-Sperren aufheben</div>
                        <div class="sa-danger-desc">Entfernt alle gesperrten IP-Adressen. Nützlich wenn du dich selbst ausgesperrt hast.</div>
                        <button class="sa-danger-btn" onclick="saDangerClearBannedIPs()"><i class="fa-solid fa-trash-can"></i> IP-Sperren aufheben</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-star-half-stroke"></i> Alle ausstehenden Reviews ablehnen</div>
                        <div class="sa-danger-desc">Lehnt alle ungeprüften Bewertungen auf einen Schlag ab. Freigegebene bleiben unberührt.</div>
                        <button class="sa-danger-btn" onclick="saDangerRejectAllReviews()"><i class="fa-solid fa-xmark"></i> Alle ablehnen</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-scroll"></i> Alte Admin-Logs löschen</div>
                        <div class="sa-danger-desc">Löscht alle Admin-Log-Einträge älter als 90 Tage. Aktuelle Logs bleiben erhalten.</div>
                        <button class="sa-danger-btn" onclick="saDangerPurgeLogs()"><i class="fa-solid fa-trash-can"></i> Alte Logs löschen</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-rotate-left"></i> Loyalty-Punkte zurücksetzen</div>
                        <div class="sa-danger-desc">Setzt die Loyalty-Punkte ALLER Benutzer auf 0 zurück. Konten bleiben erhalten.</div>
                        <button class="sa-danger-btn" onclick="saDangerResetLoyalty()"><i class="fa-solid fa-rotate-left"></i> Alle Punkte zurücksetzen</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-wifi"></i> Presence-Daten leeren</div>
                        <div class="sa-danger-desc">Löscht alle Online-Presence-Einträge. Behebt "Geister-User" die online erscheinen aber weg sind.</div>
                        <button class="sa-danger-btn" onclick="saDangerClearPresence()"><i class="fa-solid fa-trash-can"></i> Presence leeren</button>
                    </div>
                    <div class="sa-danger-card">
                        <div class="sa-danger-title"><i class="fa-solid fa-flag"></i> Alle Zugriffsversuche löschen</div>
                        <div class="sa-danger-desc">Löscht alle Einträge in der unauthorized_access Collection. Zähler werden zurückgesetzt.</div>
                        <button class="sa-danger-btn" onclick="saDangerClearUnauthorized()"><i class="fa-solid fa-trash-can"></i> Logs löschen</button>
                    </div>
                </div>

                <div class="sa-section-title" style="margin-top:8px"><i class="fa-solid fa-skull-crossbones" style="color:#f87171"></i> Nuklear</div>
                <div class="sa-danger-grid">
                    <div class="sa-danger-card" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.07)">
                        <div class="sa-danger-title" style="font-size:15px"><i class="fa-solid fa-trash"></i> ALLE Bestellungen löschen</div>
                        <div class="sa-danger-desc">Löscht <strong style="color:#f87171">alle</strong> Bestellungen permanent aus der Datenbank. Absolut irreversibel.</div>
                        <button class="sa-danger-btn" style="border-color:rgba(239,68,68,.6);background:rgba(239,68,68,.18)" onclick="saDangerDeleteAllOrders()"><i class="fa-solid fa-triangle-exclamation"></i> ALLE Bestellungen löschen</button>
                    </div>
                    <div class="sa-danger-card" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.07)">
                        <div class="sa-danger-title" style="font-size:15px"><i class="fa-solid fa-users-slash"></i> ALLE User löschen</div>
                        <div class="sa-danger-desc">Löscht <strong style="color:#f87171">alle</strong> User-Dokumente aus Firestore (nicht Firebase Auth). Absolut irreversibel.</div>
                        <button class="sa-danger-btn" style="border-color:rgba(239,68,68,.6);background:rgba(239,68,68,.18)" onclick="saDangerDeleteAllUsers()"><i class="fa-solid fa-triangle-exclamation"></i> ALLE User löschen</button>
                    </div>
                    <div class="sa-danger-card" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.07)">
                        <div class="sa-danger-title" style="font-size:15px"><i class="fa-solid fa-lock"></i> Security Lockdown</div>
                        <div class="sa-danger-desc">Sperrt sofort alle Nicht-Superadmin-Logins, schließt den Shop und protokolliert alle aktiven Sessions. Für Notfälle.</div>
                        <button class="sa-danger-btn" style="border-color:rgba(239,68,68,.6);background:rgba(239,68,68,.18)" onclick="saDangerSecurityLockdown()"><i class="fa-solid fa-lock"></i> Lockdown aktivieren</button>
                    </div>
                    <div class="sa-danger-card" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.07)">
                        <div class="sa-danger-title" style="font-size:15px"><i class="fa-solid fa-ban"></i> Alle Admin-Tokens revoken</div>
                        <div class="sa-danger-desc">Setzt das <code style="font-family:JetBrains Mono,monospace;color:#f87171">adminTokenVersion</code>-Feld aller Admins hoch — erzwingt Re-Login bei allen Admins außer dir.</div>
                        <button class="sa-danger-btn" style="border-color:rgba(239,68,68,.6);background:rgba(239,68,68,.18)" onclick="saDangerRevokeAdminTokens()"><i class="fa-solid fa-ban"></i> Tokens revoken</button>
                    </div>
                    <div class="sa-danger-card" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.07)">
                        <div class="sa-danger-title" style="font-size:15px"><i class="fa-solid fa-broom"></i> Alle Click-Events löschen</div>
                        <div class="sa-danger-desc">Löscht alle Einträge in der <code style="font-family:JetBrains Mono,monospace;color:#f87171">click_events</code>-Collection. Analyse-Daten gehen verloren.</div>
                        <button class="sa-danger-btn" style="border-color:rgba(239,68,68,.6);background:rgba(239,68,68,.18)" onclick="saDangerClearClickEvents()"><i class="fa-solid fa-broom"></i> Alle Events löschen</button>
                    </div>
                    <div class="sa-danger-card" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.07)">
                        <div class="sa-danger-title" style="font-size:15px"><i class="fa-solid fa-database"></i> Alle Backups löschen</div>
                        <div class="sa-danger-desc">Entfernt alle gespeicherten Backups aus Firestore. Die Konfiguration bleibt erhalten.</div>
                        <button class="sa-danger-btn" style="border-color:rgba(239,68,68,.6);background:rgba(239,68,68,.18)" onclick="saDangerDeleteAllBackups()"><i class="fa-solid fa-trash"></i> Alle Backups löschen</button>
                    </div>
                </div>
            </div>

            <!-- ══════════════════════════════════════════════════════════
                 PANEL: SHOP-KONFIGURATION
            ══════════════════════════════════════════════════════════ -->
            <div class="sa-inner-panel" id="sa-panel-shopconfig">

                <!-- Feature-Toggles -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-toggle-on" style="color:#67e8f9"></i> Feature-Toggles</div>
                    <div class="sa-sec-grid">
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-gift" style="color:#34d399"></i> 4-für-3-Aktion</div>
                            <div class="sa-sec-card-desc">Kunden erhalten beim Kauf von 4 Produkten das günstigste gratis.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Aktiv</span><label class="sa-switch"><input type="checkbox" id="cfg-4for3"><span class="sa-switch-sl"></span></label></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-box-open" style="color:#a78bfa"></i> Mystery Vape</div>
                            <div class="sa-sec-card-desc">Mystery-Vape wird bei Bestellungen ab dem konfigurierten Schwellenwert gratis hinzugefügt.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Aktiv</span><label class="sa-switch"><input type="checkbox" id="cfg-mystery"><span class="sa-switch-sl"></span></label></div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Ab (€)</span><input type="number" class="sa-sec-input" id="cfg-mystery-threshold" value="100" min="0" step="5"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-truck" style="color:#fbbf24"></i> Gratisversand</div>
                            <div class="sa-sec-card-desc">Versandkostenfrei ab einem bestimmten Bestellwert.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Aktiv</span><label class="sa-switch"><input type="checkbox" id="cfg-freeship"><span class="sa-switch-sl"></span></label></div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Ab (€)</span><input type="number" class="sa-sec-input" id="cfg-freeship-threshold" value="100" min="0" step="5"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-star" style="color:#fbbf24"></i> Loyalty-Programm</div>
                            <div class="sa-sec-card-desc">Punkte sammeln und einlösen. Deaktivieren verhindert neue Punkte-Vergabe.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Aktiv</span><label class="sa-switch"><input type="checkbox" id="cfg-loyalty"><span class="sa-switch-sl"></span></label></div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Punkte / € </span><input type="number" class="sa-sec-input" id="cfg-loyalty-rate" value="10" min="1" max="100"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-user-plus" style="color:#67e8f9"></i> Registrierung</div>
                            <div class="sa-sec-card-desc">Neue Nutzerregistrierungen zulassen oder sperren (Wartungsmodus).</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Offen</span><label class="sa-switch"><input type="checkbox" id="cfg-registration" checked><span class="sa-switch-sl"></span></label></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-star-half-stroke" style="color:#fbbf24"></i> Bewertungs-Moderation</div>
                            <div class="sa-sec-card-desc">Bewertungen müssen vom Admin freigegeben werden, bevor sie sichtbar sind.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Pflicht-Review</span><label class="sa-switch"><input type="checkbox" id="cfg-review-mod" checked><span class="sa-switch-sl"></span></label></div>
                        </div>
                    </div>
                </div>

                <!-- Banner & Ankündigungen -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-rectangle-ad" style="color:#fbbf24"></i> Banner &amp; Ankündigungen</div>
                    <div style="display:flex;flex-direction:column;gap:12px">
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-bullhorn" style="color:#fbbf24"></i> Aktions-Banner</div>
                            <div class="sa-sec-card-desc">Wird als farbiger Streifen oben im Shop angezeigt.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Anzeigen</span><label class="sa-switch"><input type="checkbox" id="cfg-banner-active"><span class="sa-switch-sl"></span></label></div>
                            <input type="text" id="cfg-banner-text" placeholder="z.B. 🔥 Sommeraktion: 20% auf alle Liquids!" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 14px;color:#fff;font-size:13px;outline:none;box-sizing:border-box;margin-top:10px;transition:border-color .2s" onfocus="this.style.borderColor='rgba(251,191,36,.4)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                            <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap">
                                <label style="font-size:11px;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:6px"><input type="radio" name="cfg-banner-color" value="amber" style="accent-color:#fbbf24"> <span style="color:#fbbf24">Gelb</span></label>
                                <label style="font-size:11px;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:6px"><input type="radio" name="cfg-banner-color" value="cyan" style="accent-color:#67e8f9"> <span style="color:#67e8f9">Cyan</span></label>
                                <label style="font-size:11px;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:6px"><input type="radio" name="cfg-banner-color" value="red" style="accent-color:#f87171"> <span style="color:#f87171">Rot</span></label>
                                <label style="font-size:11px;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:6px"><input type="radio" name="cfg-banner-color" value="green" style="accent-color:#34d399"> <span style="color:#34d399">Grün</span></label>
                            </div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-circle-info" style="color:#67e8f9"></i> Wartungs-Nachricht</div>
                            <div class="sa-sec-card-desc">Diese Nachricht sehen Kunden wenn der Shop geschlossen ist.</div>
                            <textarea id="cfg-maintenance-msg" rows="3" placeholder="Wir sind gleich wieder für euch da! 🛠️" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 14px;color:#fff;font-size:13px;outline:none;box-sizing:border-box;margin-top:8px;resize:vertical;transition:border-color .2s" onfocus="this.style.borderColor='rgba(103,232,249,.4)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Rabatt-Konfiguration -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-percent" style="color:#34d399"></i> Globale Rabatt-Einstellungen</div>
                    <div class="sa-sec-grid">
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-tags" style="color:#34d399"></i> Globaler Rabatt</div>
                            <div class="sa-sec-card-desc">Temporärer prozentualer Rabatt auf alle Produkte. 0 = deaktiviert.</div>
                            <div class="sa-sec-row"><span class="sa-sec-label">Aktiv</span><label class="sa-switch"><input type="checkbox" id="cfg-global-discount-active"><span class="sa-switch-sl"></span></label></div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Rabatt (%)</span><input type="number" class="sa-sec-input" id="cfg-global-discount-pct" value="0" min="0" max="90"></div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Ablauf</span><input type="date" class="sa-sec-input" id="cfg-global-discount-expiry" style="width:auto;text-align:left;padding:7px 10px"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-coins" style="color:#fbbf24"></i> Mindestbestellwert</div>
                            <div class="sa-sec-card-desc">Bestellungen unter diesem Wert werden abgelehnt. 0 = kein Minimum.</div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Min. (€)</span><input type="number" class="sa-sec-input" id="cfg-min-order" value="0" min="0" step="5"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-truck-fast" style="color:#a78bfa"></i> Versandkosten</div>
                            <div class="sa-sec-card-desc">Standard-Versandkosten wenn Gratisversand nicht greift.</div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Kosten (€)</span><input type="number" class="sa-sec-input" id="cfg-shipping-cost" value="4.99" min="0" step="0.5"></div>
                        </div>
                        <div class="sa-sec-card">
                            <div class="sa-sec-card-title"><i class="fa-solid fa-rotate" style="color:#67e8f9"></i> Max. Retouren (Tage)</div>
                            <div class="sa-sec-card-desc">Wie viele Tage nach Lieferung eine Retoure möglich ist.</div>
                            <div class="sa-sec-row" style="margin-top:6px"><span class="sa-sec-label">Tage</span><input type="number" class="sa-sec-input" id="cfg-return-days" value="14" min="0" max="90"></div>
                        </div>
                    </div>
                </div>

                <!-- Kontakt-Daten -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-address-card" style="color:#67e8f9"></i> Kontakt &amp; Impressum</div>
                    <div class="sa-sec-card">
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                            <div><label style="font-size:11px;color:rgba(255,255,255,.35);display:block;margin-bottom:5px">Support E-Mail</label><input type="email" id="cfg-contact-email" placeholder="support@wavevapes.de" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px;color:#fff;font-size:13px;outline:none;box-sizing:border-box"></div>
                            <div><label style="font-size:11px;color:rgba(255,255,255,.35);display:block;margin-bottom:5px">Instagram-URL</label><input type="text" id="cfg-instagram" placeholder="https://instagram.com/..." style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px;color:#fff;font-size:13px;outline:none;box-sizing:border-box"></div>
                            <div><label style="font-size:11px;color:rgba(255,255,255,.35);display:block;margin-bottom:5px">Shop-Name (Display)</label><input type="text" id="cfg-shop-name" placeholder="WaveVapes" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px;color:#fff;font-size:13px;outline:none;box-sizing:border-box"></div>
                            <div><label style="font-size:11px;color:rgba(255,255,255,.35);display:block;margin-bottom:5px">Altersverifikation (Jahre)</label><input type="number" id="cfg-age-gate" value="18" min="18" max="21" style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px;color:#fff;font-size:13px;outline:none;box-sizing:border-box"></div>
                        </div>
                    </div>
                </div>

                <button onclick="cfgSaveAll()" style="display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:15px;background:linear-gradient(135deg,#fbbf24,#f59e0b);border:none;border-radius:15px;font-size:14px;font-weight:700;color:#000;cursor:pointer;transition:opacity .2s" onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
                    <i class="fa-solid fa-floppy-disk"></i> Alle Einstellungen speichern
                </button>
            </div>

            <!-- ══════════════════════════════════════════════════════════
                 PANEL: SYSTEM-HEALTH MONITOR
            ══════════════════════════════════════════════════════════ -->
            <div class="sa-inner-panel" id="sa-panel-health">

                <!-- Live Status Bar -->
                <div id="health-status-bar" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;padding:18px 22px;border-radius:20px;background:linear-gradient(135deg,rgba(52,211,153,.06),rgba(52,211,153,.02));border:1px solid rgba(52,211,153,.2)">
                    <div style="display:flex;align-items:center;gap:12px">
                        <div id="health-overall-dot" style="width:14px;height:14px;border-radius:50%;background:#34d399;box-shadow:0 0 12px #34d399;flex-shrink:0"></div>
                        <div>
                            <div id="health-overall-text" style="font-size:14px;font-weight:700;color:#34d399">System betriebsbereit</div>
                            <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:2px" id="health-last-check">Letzter Check: —</div>
                        </div>
                    </div>
                    <button onclick="healthRunCheck()" id="health-check-btn" style="display:flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);color:#34d399;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(52,211,153,.2)'" onmouseout="this.style.background='rgba(52,211,153,.1)'">
                        <i class="fa-solid fa-rotate"></i> Health-Check starten
                    </button>
                </div>

                <!-- KPI Metrics -->
                <div class="sa-kpi-grid" id="health-kpi-grid">
                    <div class="sa-kpi"><div class="sa-kpi-icon">🗄️</div><div class="sa-kpi-label">Firestore Reads (heute)</div><div class="sa-kpi-value" id="h-reads">—</div><div class="sa-kpi-sub">Limit: ~50.000/Tag</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">✏️</div><div class="sa-kpi-label">Firestore Writes (heute)</div><div class="sa-kpi-value" id="h-writes">—</div><div class="sa-kpi-sub">Limit: ~20.000/Tag</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">💾</div><div class="sa-kpi-label">Dokumente gesamt</div><div class="sa-kpi-value" id="h-docs">—</div><div class="sa-kpi-sub">Über alle Collections</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">⚡</div><div class="sa-kpi-label">Aktive Listener</div><div class="sa-kpi-value" id="h-listeners">—</div><div class="sa-kpi-sub">onSnapshot-Verbindungen</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">🌐</div><div class="sa-kpi-label">Online-Nutzer</div><div class="sa-kpi-value" id="h-online">—</div><div class="sa-kpi-sub">Aktiv (letzte 90 Sek.)</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">⏱️</div><div class="sa-kpi-label">Ø Response-Zeit</div><div class="sa-kpi-value" id="h-latency">—</div><div class="sa-kpi-sub">Firestore Ping</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">🚫</div><div class="sa-kpi-label">Gesperrte IPs</div><div class="sa-kpi-value" id="h-banned-ips">—</div><div class="sa-kpi-sub">In banned_ips</div></div>
                    <div class="sa-kpi"><div class="sa-kpi-icon">⚠️</div><div class="sa-kpi-label">Fehlerrate (24h)</div><div class="sa-kpi-value" id="h-errors">—</div><div class="sa-kpi-sub">Unauthorized-Einträge</div></div>
                </div>

                <!-- Collection Sizes -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-table-list" style="color:#67e8f9"></i> Collection-Größen</div>
                    <div id="health-collections-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:16px;text-align:center;grid-column:1/-1"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade...</div>
                    </div>
                </div>

                <!-- Performance Timeline -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-chart-area" style="color:#a78bfa"></i> Latenz-Messungen (letzte Checks)</div>
                    <div id="health-latency-chart" style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:18px 20px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;text-align:center;padding:20px">Noch keine Messungen — starte einen Health-Check</div>
                    </div>
                </div>

                <!-- Checklist -->
                <div>
                    <div class="sa-section-title"><i class="fa-solid fa-clipboard-check" style="color:#34d399"></i> Integritäts-Checkliste</div>
                    <div id="health-checklist" style="display:flex;flex-direction:column;gap:8px">
                        <div style="color:rgba(255,255,255,.2);font-size:12px;padding:16px;text-align:center"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Warte auf Check...</div>
                    </div>
                </div>
            </div>

            <!-- ══════════════════════════════════════════════════════════
                 PANEL: AUDIT-TRAIL (erweiterter Activity-Log mit Filter)
            ══════════════════════════════════════════════════════════ -->
            <div class="sa-inner-panel" id="sa-panel-audittrail">

                <!-- Header -->
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;padding:18px 22px;border-radius:20px;background:linear-gradient(135deg,rgba(167,139,250,.06),rgba(167,139,250,.02));border:1px solid rgba(167,139,250,.2)">
                    <div>
                        <div style="font-family:'Orbitron',sans-serif;font-size:16px;font-weight:700;color:#a78bfa;display:flex;align-items:center;gap:10px;text-shadow:0 0 14px rgba(167,139,250,.4)"><i class="fa-solid fa-shield-check"></i> Vollständiger Audit-Trail</div>
                        <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:3px">Alle Admin-Aktionen — unveränderlich protokolliert</div>
                    </div>
                    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                        <div id="audit-total-badge" style="font-family:'JetBrains Mono',monospace;font-size:11px;padding:4px 12px;border-radius:99px;background:rgba(167,139,250,.1);color:#a78bfa;border:1px solid rgba(167,139,250,.2)">— Einträge</div>
                        <button onclick="auditExportCSV()" style="display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:10px;background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.25);color:#a78bfa;font-size:11px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(167,139,250,.2)'" onmouseout="this.style.background='rgba(167,139,250,.1)'"><i class="fa-solid fa-file-csv"></i> Export CSV</button>
                        <button onclick="auditLoad()" style="display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:11px;font-weight:700;cursor:pointer;transition:all .2s" onmouseover="this.style.background='rgba(255,255,255,.1)'" onmouseout="this.style.background='rgba(255,255,255,.05)'"><i class="fa-solid fa-rotate"></i> Aktualisieren</button>
                    </div>
                </div>

                <!-- Filter Bar -->
                <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
                    <input type="text" id="audit-search" placeholder="Admin, Aktion oder Ziel suchen..." oninput="auditApplyFilter()" style="flex:1;min-width:200px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:9px 14px;color:#fff;font-size:12px;outline:none;transition:border-color .2s" onfocus="this.style.borderColor='rgba(167,139,250,.4)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                    <select id="audit-filter-type" onchange="auditApplyFilter()" style="background:#1a1a2e;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:9px 14px;color:#fff;font-size:12px;outline:none;cursor:pointer">
                        <option value="">Alle Typen</option>
                        <option value="danger">⚡ Danger-Aktionen</option>
                        <option value="access">🔓 Zugriffe</option>
                        <option value="admin">👑 Admin-Verwaltung</option>
                        <option value="export">💾 Exporte</option>
                        <option value="order">📦 Bestellungen</option>
                        <option value="product">🛍️ Produkte</option>
                        <option value="security">🔒 Sicherheit</option>
                        <option value="config">⚙️ Konfiguration</option>
                    </select>
                    <select id="audit-filter-admin" onchange="auditApplyFilter()" style="background:#1a1a2e;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:9px 14px;color:#fff;font-size:12px;outline:none;cursor:pointer">
                        <option value="">Alle Admins</option>
                    </select>
                    <select id="audit-filter-period" onchange="auditApplyFilter()" style="background:#1a1a2e;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:9px 14px;color:#fff;font-size:12px;outline:none;cursor:pointer">
                        <option value="0">Alle Zeit</option>
                        <option value="1">Letzte 24h</option>
                        <option value="7" selected>Letzte 7 Tage</option>
                        <option value="30">Letzte 30 Tage</option>
                    </select>
                </div>

                <!-- Stats Row -->
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px" id="audit-stats-row">
                    <div class="sa-kpi" style="padding:14px 18px"><div class="sa-kpi-label">Gefilterte Einträge</div><div class="sa-kpi-value" id="audit-filtered-count" style="font-size:22px">—</div></div>
                    <div class="sa-kpi" style="padding:14px 18px"><div class="sa-kpi-label">Danger-Aktionen</div><div class="sa-kpi-value" id="audit-danger-count" style="font-size:22px;color:#f87171">—</div></div>
                    <div class="sa-kpi" style="padding:14px 18px"><div class="sa-kpi-label">Unique Admins</div><div class="sa-kpi-value" id="audit-admin-count" style="font-size:22px;color:#a78bfa">—</div></div>
                    <div class="sa-kpi" style="padding:14px 18px"><div class="sa-kpi-label">Heute</div><div class="sa-kpi-value" id="audit-today-count" style="font-size:22px;color:#67e8f9">—</div></div>
                </div>

                <!-- Log Table -->
                <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,.07);border-radius:20px;overflow:hidden">
                    <div style="overflow-x:auto">
                        <table style="width:100%;border-collapse:collapse">
                            <thead>
                                <tr style="border-bottom:1px solid rgba(255,255,255,.07)">
                                    <th style="padding:11px 16px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Zeit</th>
                                    <th style="padding:11px 16px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Admin</th>
                                    <th style="padding:11px 16px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Aktion</th>
                                    <th style="padding:11px 16px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:left">Ziel / Details</th>
                                    <th style="padding:11px 16px;font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.3);text-align:center">Typ</th>
                                </tr>
                            </thead>
                            <tbody id="audit-tbody">
                                <tr><td colspan="5" style="padding:40px;text-align:center;color:rgba(255,255,255,.2);font-size:13px"><i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>Lade Audit-Trail...</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div id="audit-footer" style="padding:10px 16px;border-top:1px solid rgba(255,255,255,.05);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
                        <span id="audit-footer-label" style="font-size:11px;color:rgba(255,255,255,.2)">—</span>
                        <div style="display:flex;gap:8px">
                            <button id="audit-prev" onclick="auditPagePrev()" disabled style="padding:5px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.4);font-size:11px;cursor:pointer">← Zurück</button>
                            <button id="audit-next" onclick="auditPageNext()" style="padding:5px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.4);font-size:11px;cursor:pointer">Weiter →</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        </div>

        <!-- TAB 16: BUNDLES -->
        <div id="tab-content-16" class="hidden">
            <div id="bundle-shell"></div>
        </div>

        <!-- TAB 17: ADMIN LOGS (für normale Admins sichtbar) -->
        <div id="tab-content-17" class="hidden">
            <div class="lg-page-hdr">
                <div class="lg-page-title">
                    <i class="fa-solid fa-list-check"></i> Admin Logs
                </div>
                <div style="display:flex;gap:8px;align-items:center">
                    <button class="lg-btn lg-btn-ghost" onclick="loadAdminLogs();showToast('🔄 Logs aktualisiert')">
                        <i class="fa-solid fa-rotate-right"></i> Refresh
                    </button>
                </div>
            </div>
            <div class="lg-section">
                <div class="lg-section-body" id="admin-logs-container-tab17">
                    <div class="lg-empty"><span class="lg-spinner"></span> Lade...</div>
                </div>
            </div>
        </div>


        <!-- TAB 18: FAKE REVIEW GENERATOR -->
        <div id="tab-content-18" class="hidden">
        <div id="frv-root">

            <!-- Header -->
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:22px">
                <div style="font-family:'Orbitron',sans-serif;font-size:19px;font-weight:700;color:#a78bfa;text-shadow:0 0 18px rgba(167,139,250,.4);display:flex;align-items:center;gap:10px">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> Review Generator
                </div>
                <div style="display:flex;gap:8px;flex-wrap:wrap">
                    <button id="frv-btn-gen"
                        style="display:flex;align-items:center;gap:8px;padding:10px 20px;border-radius:12px;background:linear-gradient(135deg,#a78bfa,#7c3aed);color:#fff;font-size:13px;font-weight:700;border:none;cursor:pointer">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> Generieren
                    </button>
                    <button id="frv-btn-pub"
                        style="display:flex;align-items:center;gap:8px;padding:10px 20px;border-radius:12px;background:rgba(52,211,153,.12);border:1px solid rgba(52,211,153,.3);color:#34d399;font-size:13px;font-weight:700;cursor:pointer">
                        <i class="fa-solid fa-upload"></i> Veröffentlichen
                    </button>
                    <button id="frv-btn-del"
                        style="display:flex;align-items:center;gap:8px;padding:10px 16px;border-radius:12px;background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);color:#f87171;font-size:13px;font-weight:700;cursor:pointer">
                        <i class="fa-solid fa-trash-can"></i> Alle Fake löschen
                    </button>
                </div>
            </div>

            <!-- Config -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">

                <div style="background:#13131f;border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:20px;display:flex;flex-direction:column;gap:14px">

                    <div>
                        <div style="font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:8px">Ziel</div>
                        <div style="display:flex;gap:8px">
                            <button id="frv-mode-all" style="flex:1;padding:9px;border-radius:10px;background:rgba(167,139,250,.2);border:1px solid rgba(167,139,250,.5);color:#a78bfa;font-size:12px;font-weight:700;cursor:pointer">🌐 Alle Produkte</button>
                            <button id="frv-mode-one" style="flex:1;padding:9px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.4);font-size:12px;font-weight:700;cursor:pointer">📦 Ein Produkt</button>
                        </div>
                    </div>

                    <select id="frv-product-select" style="width:100%;background:#1a1a2e;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 12px;color:#fff;font-size:13px;outline:none;color-scheme:dark;display:none">
                        <option value="">— Produkt wählen —</option>
                    </select>

                    <div id="frv-info-banner" style="font-size:11px;color:#67e8f9;background:rgba(103,232,249,.06);border:1px solid rgba(103,232,249,.15);border-radius:8px;padding:8px 12px;display:none"></div>

                    <div>
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:8px">Reviews pro Produkt <span style="color:rgba(167,139,250,.6);font-size:9px;font-weight:600">(SPANNE)</span></div>
                        <div style="display:flex;align-items:center;gap:8px">
                            <div style="flex:1">
                                <div style="font-size:9px;color:rgba(255,255,255,.25);margin-bottom:4px;text-align:center">MIN</div>
                                <input id="frv-count-min" type="number" min="1" max="20" value="2"
                                    style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 8px;color:#fff;font-size:14px;font-weight:700;outline:none;box-sizing:border-box;text-align:center">
                            </div>
                            <div style="color:rgba(255,255,255,.2);font-size:16px;font-weight:300;padding-top:14px">—</div>
                            <div style="flex:1">
                                <div style="font-size:9px;color:rgba(255,255,255,.25);margin-bottom:4px;text-align:center">MAX</div>
                                <input id="frv-count-max" type="number" min="1" max="20" value="5"
                                    style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 8px;color:#fff;font-size:14px;font-weight:700;outline:none;box-sizing:border-box;text-align:center">
                            </div>
                            <div style="flex:1.2">
                                <div style="font-size:9px;color:rgba(255,255,255,.25);margin-bottom:4px;text-align:center">SPRACHE</div>
                                <select id="frv-lang" style="width:100%;background:#1a1a2e;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 8px;color:#fff;font-size:11px;outline:none;color-scheme:dark">
                                    <option value="de">🇩🇪 DE</option>
                                    <option value="en">🇬🇧 EN</option>
                                </select>
                            </div>
                        </div>
                        <div id="frv-range-hint" style="margin-top:6px;font-size:10px;color:rgba(103,232,249,.5);text-align:center">Jedes Produkt bekommt zufällig 2–5 Reviews</div>
                    </div>

                    <div>
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:8px">Sternverteilung</div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap" id="frv-star-dist">
                            <label style="display:flex;align-items:center;gap:5px;font-size:12px;color:rgba(255,255,255,.6);cursor:pointer"><input type="checkbox" value="5" checked style="accent-color:#a78bfa"> ★★★★★</label>
                            <label style="display:flex;align-items:center;gap:5px;font-size:12px;color:rgba(255,255,255,.6);cursor:pointer"><input type="checkbox" value="4" checked style="accent-color:#a78bfa"> ★★★★</label>
                            <label style="display:flex;align-items:center;gap:5px;font-size:12px;color:rgba(255,255,255,.6);cursor:pointer"><input type="checkbox" value="3" style="accent-color:#a78bfa"> ★★★</label>
                            <label style="display:flex;align-items:center;gap:5px;font-size:12px;color:rgba(255,255,255,.6);cursor:pointer"><input type="checkbox" value="2" style="accent-color:#a78bfa"> ★★</label>
                            <label style="display:flex;align-items:center;gap:5px;font-size:12px;color:rgba(255,255,255,.6);cursor:pointer"><input type="checkbox" value="1" style="accent-color:#a78bfa"> ★</label>
                        </div>
                    </div>

                    <div style="display:flex;align-items:center;gap:12px">
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.28)">Datumsstreuung</div>
                        <input id="frv-date-spread" type="number" min="1" max="365" value="90" style="width:70px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 10px;color:#fff;font-size:12px;outline:none;text-align:center">
                        <span style="font-size:12px;color:rgba(255,255,255,.4)">Tage</span>
                    </div>
                </div>

                <div style="background:#13131f;border:1px solid rgba(167,139,250,.15);border-radius:18px;padding:20px;display:flex;flex-direction:column;gap:14px">
                    <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#a78bfa;display:flex;align-items:center;gap:8px">
                        <i class="fa-solid fa-robot"></i> KI-Einstellungen
                    </div>

                    <div>
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:6px">Stil / Ton</div>
                        <select id="frv-tone" style="width:100%;background:#1a1a2e;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px;color:#fff;font-size:12px;outline:none;color-scheme:dark">
                            <option value="begeistert">😍 Begeistert & emotional</option>
                            <option value="kurz">⚡ Kurz & prägnant</option>
                            <option value="detailliert">📝 Detailliert & glaubwürdig</option>
                            <option value="casual">💬 Casual / Umgangssprache</option>
                            <option value="gemischt" selected>🎲 Gemischt (zufällig)</option>
                        </select>
                    </div>

                    <div>
                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:6px">Namen-Stil</div>
                        <select id="frv-name-style" style="width:100%;background:#1a1a2e;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px;color:#fff;font-size:12px;outline:none;color-scheme:dark">
                            <option value="de">🇩🇪 Deutsche Namen</option>
                            <option value="mixed" selected>🌍 Gemischt</option>
                            <option value="anonym">🕵️ Anonymisiert</option>
                        </select>
                    </div>

                    <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 12px;border-radius:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07)">
                        <input type="checkbox" id="frv-auto-approve" checked style="accent-color:#a78bfa;width:16px;height:16px">
                        <div>
                            <div style="font-size:12px;font-weight:600;color:rgba(255,255,255,.8)">Direkt genehmigen</div>
                            <div style="font-size:10px;color:rgba(255,255,255,.3);margin-top:1px">Sofort sichtbar im Shop</div>
                        </div>
                    </label>

                    <div id="frv-fake-count-info" style="font-size:11px;color:rgba(248,113,113,.7);background:rgba(248,113,113,.06);border:1px solid rgba(248,113,113,.15);border-radius:8px;padding:8px 12px;display:none"></div>
                </div>
            </div>

            <!-- Status bar -->
            <div id="frv-status" style="display:none;background:#13131f;border:1px solid rgba(103,232,249,.2);border-radius:12px;padding:12px 18px;margin-bottom:16px;font-size:12px;color:#67e8f9;align-items:center;gap:10px">
                <i class="fa-solid fa-spinner fa-spin"></i>
                <span id="frv-status-text">Bitte warten…</span>
                <div id="frv-progress-bar" style="flex:1;height:4px;background:rgba(255,255,255,.08);border-radius:99px;overflow:hidden;margin-left:8px">
                    <div id="frv-progress-fill" style="height:100%;background:#67e8f9;border-radius:99px;width:0%;transition:width .3s"></div>
                </div>
            </div>

            <!-- Preview list -->
            <div style="background:#13131f;border:1px solid rgba(255,255,255,.07);border-radius:18px;overflow:hidden">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid rgba(255,255,255,.06)">
                    <div style="font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.4)">
                        Vorschau <span id="frv-preview-count" style="color:#a78bfa;font-family:'JetBrains Mono',monospace"></span>
                    </div>
                    <div style="display:flex;gap:8px">
                        <button id="frv-btn-selall"  style="font-size:11px;padding:5px 12px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);cursor:pointer">Alle auswählen</button>
                        <button id="frv-btn-desel"   style="font-size:11px;padding:5px 12px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);cursor:pointer">Alle abwählen</button>
                        <button id="frv-btn-delsel"  style="font-size:11px;padding:5px 12px;border-radius:8px;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);color:#f87171;cursor:pointer">Ausgewählte löschen</button>
                    </div>
                </div>
                <div id="frv-preview-grid" style="padding:16px 20px;display:flex;flex-direction:column;gap:10px;min-height:100px">
                    <div style="text-align:center;padding:40px 20px;color:rgba(255,255,255,.2);font-size:13px">
                        <i class="fa-solid fa-wand-magic-sparkles" style="font-size:28px;display:block;margin-bottom:10px;opacity:.3"></i>
                        Einstellungen wählen und auf „Generieren" klicken
                    </div>
                </div>
            </div>

        </div>
        </div>


        <!-- TAB 10: ERWEITERTE BENUTZERVERWALTUNG v3 -->
        <div id="tab-content-10" class="hidden">

            <!-- KPI Strip -->
            <div class="eu-kpi-grid">
                <div class="eu-kpi" style="--eu-kpi-color:var(--eu-cyan);--eu-kpi-glow:rgba(103,232,249,.06)">
                    <div class="eu-kpi-icon"><i class="fa-solid fa-users"></i></div>
                    <div class="eu-kpi-label">Gesamt User</div>
                    <div class="eu-kpi-value" id="eu-kpi-total">—</div>
                    <div class="eu-kpi-sub" id="eu-kpi-total-sub"></div>
                </div>
                <div class="eu-kpi" style="--eu-kpi-color:var(--eu-green);--eu-kpi-glow:rgba(52,211,153,.06)">
                    <div class="eu-kpi-icon"><i class="fa-solid fa-circle-check"></i></div>
                    <div class="eu-kpi-label">Aktive User</div>
                    <div class="eu-kpi-value" id="eu-kpi-active">—</div>
                    <div class="eu-kpi-sub" id="eu-kpi-active-sub"></div>
                </div>
                <div class="eu-kpi" style="--eu-kpi-color:var(--eu-red);--eu-kpi-glow:rgba(248,113,113,.06)">
                    <div class="eu-kpi-icon"><i class="fa-solid fa-ban"></i></div>
                    <div class="eu-kpi-label">Gesperrt</div>
                    <div class="eu-kpi-value" id="eu-kpi-disabled">—</div>
                </div>
                <div class="eu-kpi" style="--eu-kpi-color:var(--eu-amber);--eu-kpi-glow:rgba(251,191,36,.06)">
                    <div class="eu-kpi-icon"><i class="fa-solid fa-star"></i></div>
                    <div class="eu-kpi-label">Ø Punkte</div>
                    <div class="eu-kpi-value" id="eu-kpi-avgpts">—</div>
                </div>
                <div class="eu-kpi" style="--eu-kpi-color:var(--eu-purple);--eu-kpi-glow:rgba(167,139,250,.06)">
                    <div class="eu-kpi-icon"><i class="fa-solid fa-crown"></i></div>
                    <div class="eu-kpi-label">Admins</div>
                    <div class="eu-kpi-value" id="eu-kpi-admins">—</div>
                </div>
                <div class="eu-kpi" style="--eu-kpi-color:var(--eu-pink);--eu-kpi-glow:rgba(244,114,182,.06)">
                    <div class="eu-kpi-icon"><i class="fa-solid fa-share-nodes"></i></div>
                    <div class="eu-kpi-label">Ø Referrals</div>
                    <div class="eu-kpi-value" id="eu-kpi-avgrefs">—</div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="eu-toolbar">
                <div class="eu-search-wrap">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input class="eu-search" id="eu-search" placeholder="E-Mail, Username, Referral-Code..." oninput="euFilter()">
                </div>
                <select class="eu-fsel" id="eu-filter-status" onchange="euFilter()">
                    <option value="">Alle User</option>
                    <option value="active">Nur aktive</option>
                    <option value="disabled">Nur gesperrte</option>
                    <option value="admin">Nur Admins</option>
                    <option value="vip">VIP (Punkte ≥ 1000)</option>
                    <option value="freeship">Gratisversand</option>
                </select>
                <select class="eu-fsel" id="eu-filter-sort" onchange="euFilter()">
                    <option value="email">Sortierung: E-Mail A-Z</option>
                    <option value="points_desc">Sortierung: Punkte ↓</option>
                    <option value="refs_desc">Sortierung: Referrals ↓</option>
                    <option value="orders_desc">Sortierung: Bestellungen ↓</option>
                    <option value="spent_desc">Sortierung: Umsatz ↓</option>
                </select>
                <button class="eu-btn eu-btn-cyan" onclick="euExportCSV()"><i class="fa-solid fa-file-csv"></i> Export</button>
                <button class="eu-btn eu-btn-amber" onclick="euOpenBroadcast()"><i class="fa-solid fa-bullhorn"></i> Broadcast</button>
                <button class="eu-btn eu-btn-purple" onclick="euShowTopCustomers()"><i class="fa-solid fa-trophy"></i> Top Kunden</button>
            </div>

            <!-- Bulk Action Bar -->
            <div class="eu-bulk-bar" id="eu-bulk-bar">
                <span class="eu-bulk-label" id="eu-bulk-label">0 ausgewählt</span>
                <button class="eu-btn eu-btn-red"    onclick="euBulkAction('disable')"><i class="fa-solid fa-lock"></i> Sperren</button>
                <button class="eu-btn eu-btn-green"  onclick="euBulkAction('enable')"><i class="fa-solid fa-unlock"></i> Entsperren</button>
                <button class="eu-btn eu-btn-purple" onclick="euBulkAction('addpoints')"><i class="fa-solid fa-plus"></i> +Punkte</button>
                <button class="eu-btn eu-btn-amber"  onclick="euBulkAction('freeship')"><i class="fa-solid fa-truck"></i> Gratisversand</button>
                <button class="eu-btn eu-btn-red"    onclick="euBulkAction('delete')" style="margin-left:auto"><i class="fa-solid fa-trash"></i> Löschen</button>
                <button class="eu-btn" style="background:rgba(255,255,255,.04);color:var(--eu-muted);border-color:var(--eu-border)" onclick="euClearSelection()">✕</button>
            </div>

            <!-- Table -->
            <div class="eu-table-wrap">
                <div class="eu-table-scroll">
                    <table class="eu-table">
                        <thead>
                            <tr>
                                <th style="width:44px;text-align:center"><input type="checkbox" id="eu-select-all" onclick="euToggleSelectAll(this)" class="accent-cyan-400 w-4 h-4"></th>
                                <th onclick="euSortBy('email')">Benutzer</th>
                                <th onclick="euSortBy('referralCode')">Referral</th>
                                <th onclick="euSortBy('points')" style="text-align:center">Punkte</th>
                                <th onclick="euSortBy('refs')" style="text-align:center">Geworbene</th>
                                <th onclick="euSortBy('orders')" style="text-align:center">Bestellungen</th>
                                <th onclick="euSortBy('spent')" style="text-align:right">Umsatz</th>
                                <th style="text-align:center">Status</th>
                                <th style="text-align:center">Extras</th>
                                <th style="text-align:center;width:48px"></th>
                            </tr>
                        </thead>
                        <tbody id="eu-tbody">
                            <tr><td colspan="10"><div class="eu-empty"><span class="eu-spinner"></span><br><br>Lade Benutzer...</div></td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="eu-pagination">
                    <div id="eu-page-info">Lade...</div>
                    <div class="eu-page-btns" id="eu-page-btns"></div>
                </div>
            </div>
        </div>

    </div><!-- /main -->
</div><!-- /flex -->

<!-- STANDARD MODALS -->
<div id="edit-modal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-[9999]"></div>
<div id="order-modal-container"></div>
<div id="toast-container" role="status" aria-live="polite" aria-atomic="false" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[99999] flex flex-col gap-3"></div>

<!-- EU DRAWER OVERLAY + PANEL -->
<div class="eu-overlay" id="eu-overlay" onclick="euCloseDrawer()"></div>
<div class="eu-drawer" id="eu-drawer">
    <div class="eu-drawer-hdr">
        <div style="display:flex;align-items:center;gap:12px">
            <div class="eu-avatar" id="eu-d-avatar" style="width:44px;height:44px;font-size:15px;background:rgba(103,232,249,.15);color:var(--eu-cyan)">?</div>
            <div>
                <div style="font-size:15px;font-weight:700;color:var(--eu-text)" id="eu-d-name">—</div>
                <div style="font-size:11px;color:var(--eu-muted);margin-top:1px" id="eu-d-email-lbl">—</div>
            </div>
        </div>
        <button onclick="euCloseDrawer()" style="background:rgba(255,255,255,.05);border:1px solid var(--eu-border);border-radius:11px;width:34px;height:34px;color:var(--eu-muted);font-size:17px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--eu-muted)'">✕</button>
    </div>
    <div class="eu-drawer-body">
        <!-- Mini KPIs -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:22px">
            <div style="background:var(--eu-card);border:1px solid var(--eu-border);border-radius:13px;padding:13px;text-align:center">
                <div style="font-size:9px;color:var(--eu-muted);margin-bottom:3px;text-transform:uppercase;letter-spacing:.06em;font-weight:600">Punkte</div>
                <div style="font-size:20px;font-weight:700;color:var(--eu-amber);font-family:'JetBrains Mono',monospace" id="eu-d-pts-kpi">—</div>
            </div>
            <div style="background:var(--eu-card);border:1px solid var(--eu-border);border-radius:13px;padding:13px;text-align:center">
                <div style="font-size:9px;color:var(--eu-muted);margin-bottom:3px;text-transform:uppercase;letter-spacing:.06em;font-weight:600">Bestellungen</div>
                <div style="font-size:20px;font-weight:700;color:var(--eu-cyan);font-family:'JetBrains Mono',monospace" id="eu-d-ord-kpi">—</div>
            </div>
            <div style="background:var(--eu-card);border:1px solid var(--eu-border);border-radius:13px;padding:13px;text-align:center">
                <div style="font-size:9px;color:var(--eu-muted);margin-bottom:3px;text-transform:uppercase;letter-spacing:.06em;font-weight:600">Umsatz</div>
                <div style="font-size:20px;font-weight:700;color:var(--eu-green);font-family:'JetBrains Mono',monospace" id="eu-d-spent-kpi">—</div>
            </div>
        </div>
        <!-- Stammdaten -->
        <div class="eu-section">
            <div class="eu-section-title"><i class="fa-solid fa-id-card" style="margin-right:6px;color:var(--eu-cyan)"></i>Stammdaten</div>
            <div class="eu-grid2">
                <div class="eu-field"><label>Username</label><input class="eu-input" id="eu-d-username" placeholder="Username"></div>
                <div class="eu-field"><label>Referral Code</label><input class="eu-input" id="eu-d-refcode" placeholder="WAVE-XXXXX"></div>
                <div class="eu-field"><label>Loyalty Punkte</label><input class="eu-input" id="eu-d-pts" type="number" placeholder="0"></div>
                <div class="eu-field"><label>Mitglied seit</label><input class="eu-input" id="eu-d-created" disabled style="opacity:.5"></div>
            </div>
        </div>
        <!-- Berechtigungen -->
        <div class="eu-section">
            <div class="eu-section-title"><i class="fa-solid fa-shield-halved" style="margin-right:6px;color:var(--eu-purple)"></i>Berechtigungen & Status</div>

            <!-- Sperren / Entsperren – sofortige Aktion mit IP-Ban -->
            <div id="eu-d-lock-row" style="display:flex;align-items:center;justify-content:space-between;padding:13px 15px;border-radius:13px;margin-bottom:8px;border:1px solid rgba(248,113,113,.22);background:rgba(248,113,113,.06)">
                <div>
                    <div style="font-size:13px;font-weight:700;color:var(--eu-red)" id="eu-d-lock-label">Account gesperrt</div>
                    <div style="font-size:10px;color:var(--eu-muted);margin-top:2px" id="eu-d-lock-sub">Login blockiert · IPs werden gebannt</div>
                </div>
                <button id="eu-d-lock-btn" onclick="euDrawerToggleLock()" style="display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border-radius:40px;font-size:12px;font-weight:700;cursor:pointer;border:1px solid rgba(248,113,113,.35);background:rgba(248,113,113,.12);color:var(--eu-red);transition:all .2s">
                    <i class="fa-solid fa-unlock"></i> Entsperren
                </button>
            </div>
            <!-- hidden checkbox used by euSaveDrawer -->
            <input type="checkbox" id="eu-d-active" style="display:none">

            <div class="eu-toggle-row">
                <div><div class="eu-toggle-lbl">Gratisversand</div><div class="eu-toggle-sub">Versandkosten dauerhaft 0 €</div></div>
                <label class="eu-switch"><input type="checkbox" id="eu-d-freeship"><span class="eu-switch-sl"></span></label>
            </div>
            <div class="eu-toggle-row">
                <div><div class="eu-toggle-lbl">Admin-Rolle</div><div class="eu-toggle-sub">Zugriff auf dieses Panel</div></div>
                <label class="eu-switch"><input type="checkbox" id="eu-d-admin"><span class="eu-switch-sl"></span></label>
            </div>
            <div class="eu-toggle-row">
                <div><div class="eu-toggle-lbl">VIP-Status</div><div class="eu-toggle-sub">Manueller Premium-Badge</div></div>
                <label class="eu-switch"><input type="checkbox" id="eu-d-vip"><span class="eu-switch-sl"></span></label>
            </div>
        </div>
        <!-- Notizen -->
        <div class="eu-section">
            <div class="eu-section-title"><i class="fa-solid fa-note-sticky" style="margin-right:6px;color:var(--eu-amber)"></i>Interne Notizen</div>
            <textarea class="eu-input eu-textarea" id="eu-d-notes" placeholder="Nur für Admins sichtbar..."></textarea>
        </div>
        <!-- Letzte Bestellungen -->
        <div class="eu-section">
            <div class="eu-section-title"><i class="fa-solid fa-receipt" style="margin-right:6px;color:var(--eu-green)"></i>Letzte Bestellungen</div>
            <div id="eu-d-orders-list"></div>
        </div>
        <!-- Danger Zone -->
        <div class="eu-section">
            <div class="eu-section-title" style="color:var(--eu-red)"><i class="fa-solid fa-triangle-exclamation" style="margin-right:6px"></i>Danger Zone</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                <button class="eu-btn eu-btn-amber" onclick="euDrawerDanger('resetpoints')" style="justify-content:center"><i class="fa-solid fa-rotate-left"></i> Punkte resetten</button>
                <button class="eu-btn eu-btn-amber" onclick="euDrawerDanger('resetpw')" style="justify-content:center"><i class="fa-solid fa-key"></i> PW-Reset senden</button>
                <button class="eu-btn eu-btn-red" onclick="euDrawerDanger('delete')" style="justify-content:center;grid-column:span 2"><i class="fa-solid fa-trash"></i> Account permanent löschen</button>
            </div>
        </div>
        <!-- Save -->
        <button onclick="euSaveDrawer()" style="width:100%;padding:15px;background:linear-gradient(135deg,var(--eu-cyan),var(--eu-purple));border:none;border-radius:15px;font-size:14px;font-weight:700;color:#000;cursor:pointer;transition:opacity .2s;margin-top:6px" onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
            <i class="fa-solid fa-floppy-disk"></i> &nbsp;Änderungen speichern
        </button>
    </div>
</div>

<!-- BROADCAST MODAL -->
<div id="eu-bc-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:99999;align-items:center;justify-content:center;padding:16px">
    <div style="background:#13131f;border:1px solid rgba(103,232,249,.15);border-radius:22px;padding:28px;max-width:580px;width:100%;max-height:90vh;overflow-y:auto;animation:modalPop .3s cubic-bezier(.34,1.56,.64,1)">

        <!-- Header -->
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
            <h3 style="font-size:18px;font-weight:700;color:var(--eu-amber)"><i class="fa-solid fa-bullhorn" style="margin-right:8px"></i>Broadcast-Nachricht</h3>
            <button onclick="euCloseBroadcast()" style="background:none;border:none;color:var(--eu-muted);font-size:20px;cursor:pointer">✕</button>
        </div>

        <!-- Empfänger-Modus Toggle -->
        <div style="margin-bottom:16px">
            <label style="font-size:10px;color:var(--eu-muted);font-weight:600;letter-spacing:.05em;text-transform:uppercase;margin-bottom:8px;display:block">Empfänger</label>
            <div style="display:flex;gap:8px;margin-bottom:12px">
                <button id="bc-mode-all" onclick="bcSetMode('all')"
                    style="flex:1;padding:10px;border-radius:12px;font-size:13px;font-weight:600;cursor:pointer;border:1px solid rgba(103,232,249,.5);background:rgba(103,232,249,.12);color:#67e8f9;transition:all .15s">
                    <i class="fa-solid fa-users"></i> Alle Nutzer
                </button>
                <button id="bc-mode-select" onclick="bcSetMode('select')"
                    style="flex:1;padding:10px;border-radius:12px;font-size:13px;font-weight:600;cursor:pointer;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.5);transition:all .15s">
                    <i class="fa-solid fa-user-check"></i> Ausgewählte
                </button>
            </div>

            <!-- Alle-Modus Info -->
            <div id="bc-all-info" style="background:rgba(103,232,249,.06);border:1px solid rgba(103,232,249,.15);border-radius:12px;padding:10px 14px;font-size:12px;color:rgba(255,255,255,.5)">
                <i class="fa-solid fa-circle-info" style="color:#67e8f9;margin-right:6px"></i>
                Nachricht wird an <strong id="eu-bc-count" style="color:#67e8f9">alle</strong> aktiven Nutzer gesendet.
            </div>

            <!-- Auswahl-Modus -->
            <div id="bc-select-panel" style="display:none">
                <div style="position:relative;margin-bottom:8px">
                    <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:rgba(255,255,255,.3);font-size:12px"></i>
                    <input id="bc-search" type="text" placeholder="Nutzer suchen..." oninput="bcFilterList()"
                        style="width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:9px 12px 9px 34px;color:#fff;font-size:13px;outline:none;box-sizing:border-box"
                        onfocus="this.style.borderColor='rgba(103,232,249,.4)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;padding:0 2px">
                    <span id="bc-selected-count" style="font-size:11px;color:rgba(255,255,255,.4)">0 ausgewählt</span>
                    <div style="display:flex;gap:10px">
                        <button onclick="bcSelectAll()" style="font-size:11px;color:#67e8f9;background:none;border:none;cursor:pointer">Alle wählen</button>
                        <button onclick="bcDeselectAll()" style="font-size:11px;color:rgba(255,255,255,.4);background:none;border:none;cursor:pointer">Keine</button>
                    </div>
                </div>
                <div id="bc-user-list" style="max-height:200px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;scrollbar-width:thin;scrollbar-color:rgba(103,232,249,.3) transparent">
                </div>
            </div>
        </div>

        <!-- Betreff -->
        <div style="margin-bottom:12px">
            <label style="font-size:10px;color:var(--eu-muted);font-weight:600;letter-spacing:.05em;text-transform:uppercase;margin-bottom:5px;display:block">Betreff</label>
            <input class="eu-input" id="eu-bc-subject" placeholder="Betreff der Nachricht">
        </div>

        <!-- Nachricht -->
        <div style="margin-bottom:18px">
            <label style="font-size:10px;color:var(--eu-muted);font-weight:600;letter-spacing:.05em;text-transform:uppercase;margin-bottom:5px;display:block">Nachricht</label>
            <textarea class="eu-input eu-textarea" id="eu-bc-body" rows="4" placeholder="Deine Nachricht..."></textarea>
        </div>

        <!-- Buttons -->
        <div style="display:flex;gap:10px">
            <button id="bc-send-btn" onclick="euExecuteBroadcast()" style="flex:1;padding:13px;background:linear-gradient(135deg,var(--eu-amber),#f97316);border:none;border-radius:13px;font-weight:700;font-size:13px;color:#000;cursor:pointer">
                <i class="fa-solid fa-paper-plane"></i> <span id="bc-send-label">Jetzt senden</span>
            </button>
            <button onclick="euCloseBroadcast()" style="padding:13px 18px;background:rgba(255,255,255,.04);border:1px solid var(--eu-border);border-radius:13px;color:var(--eu-muted);cursor:pointer">Abbrechen</button>
        </div>
    </div>
</div>


<script src="admin-main.js"></script>
<!-- ═══════════════════════════════════════════
     SUPERADMIN RE-AUTH MODAL
═══════════════════════════════════════════ -->
<div id="sa-reauth-modal" style="display:none" class="sa-modal-overlay">
    <div class="sa-modal">
        <div class="sa-modal-icon">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <div class="sa-modal-title">Superadmin Zone</div>
        <div class="sa-modal-sub">
            Gesicherter Bereich. Bestätige deine Identität<br>und stelle sicher, dass du in der IP-Whitelist bist.
        </div>
        <div style="text-align:center;margin-bottom:20px">
            <div class="sa-ip-badge">
                <i class="fa-solid fa-location-dot" style="color:#34d399"></i>
                <span id="sa-ip-display">Ermittle IP...</span>
            </div>
            <div id="sa-ip-status" style="font-size:11px;margin-top:6px;color:rgba(255,255,255,.3)"></div>
        </div>
        <input class="sa-input" type="password" id="sa-reauth-password" placeholder="Passwort zur Bestätigung eingeben"
               onkeydown="if(event.key==='Enter')saSubmitReauth()">
        <button class="sa-btn-primary" id="sa-reauth-btn" onclick="saSubmitReauth()">
            <i class="fa-solid fa-unlock"></i> &nbsp;Zugang bestätigen
        </button>
        <div class="sa-error" id="sa-reauth-error"></div>
        <button onclick="saCloseReauthModal()" style="width:100%;margin-top:14px;padding:10px;background:transparent;border:none;color:rgba(255,255,255,.25);font-size:12px;cursor:pointer;transition:color .15s" onmouseover="this.style.color='rgba(255,255,255,.5)'" onmouseout="this.style.color='rgba(255,255,255,.25)'">
            Abbrechen
        </button>
    </div>
</div>

<script src="admin-superadmin.js"></script>
