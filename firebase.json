{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "functions_index.js",
      "push.bat",
      "push.sh",
      "download",
      "**/*.bat",
      "**/*.exe",
      "**/*.sh",
      "vercel.json",
      "_redirects",
      "**/*.py",
      "**/*.bak",
      "**/*.tawk_bak",
      "*-schema-snippet.json",
      "serviceAccount*.json",
      "*firebase-adminsdk*.json",
      "firestore-backup.json",
      "firestore-export.js",
      "firestore-import.js",
      "auth-migrate.js",
      "migrate.js",
      "import-products-csv.js",
      "generate-og-image.py",
      "install_favicons.py",
      "_verify.py",
      "SECURITY.md",
      "*.orders_fix_backup",
      "workers/**"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin.html"
      },
      {
        "source": "/admin/**",
        "destination": "/admin.html"
      },
      {
        "source": "/account",
        "destination": "/account.html"
      },
      {
        "source": "/faq",
        "destination": "/faq.html"
      },
      {
        "source": "/disposable-vapes-kaufen",
        "destination": "/disposable-vapes-kaufen.html"
      },
      {
        "source": "/tornado-30000-vape-kaufen",
        "destination": "/tornado-30000-vape-kaufen.html"
      },
      {
        "source": "/elfliq-liquid-20mg",
        "destination": "/elfliq-liquid-20mg.html"
      },
      {
        "source": "/einweg-vape-30000-zuege",
        "destination": "/einweg-vape-30000-zuege.html"
      },
      {
        "source": "/4-fuer-3-aktion",
        "destination": "/4-fuer-3-aktion.html"
      },
      {
        "source": "/vape-shop-deutschland",
        "destination": "/vape-shop-deutschland.html"
      },
      {
        "source": "/nic-salt-liquid-kaufen",
        "destination": "/nic-salt-liquid-kaufen.html"
      },
      {
        "source": "/vape-angebote",
        "destination": "/vape-angebote.html"
      },
      {
        "source": "/mystery-vape-box",
        "destination": "/mystery-vape-box.html"
      },
      {
        "source": "/vape-deutschland",
        "destination": "/vape-deutschland.html"
      },
      {
        "source": "/beste-einweg-vapes",
        "destination": "/beste-einweg-vapes.html"
      },
      {
        "source": "/impressum",
        "destination": "/impressum.html"
      },
      {
        "source": "/datenschutz",
        "destination": "/datenschutz.html"
      },
      {
        "source": "/vape-4-fuer-3",
        "destination": "/4-fuer-3-aktion.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=63072000; includeSubDomains; preload"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.gstatic.com https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://embed.tawk.to https://*.tawk.to; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://*.tawk.to; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://*.tawk.to https://va.tawk.to; img-src 'self' data: blob: https:; media-src 'self' https://*.tawk.to; connect-src 'self' https://firestore.googleapis.com https://firebase.googleapis.com https://www.googleapis.com https://identitytoolkit.googleapis.com https://fcm.googleapis.com https://securetoken.googleapis.com https://api.emailjs.com https://www.google-analytics.com https://region1.google-analytics.com https://*.tawk.to wss://*.tawk.to wss://*.firebaseio.com https://www.cloudflare.com https://api.ipify.org https://www.gstatic.com; worker-src 'self' blob:; frame-src https://embed.tawk.to https://*.tawk.to; frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
          },
          {
            "key": "X-DNS-Prefetch-Control",
            "value": "on"
          },
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          }
        ]
      },
      {
        "source": "/admin.html",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://embed.tawk.to https://*.tawk.to; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://*.tawk.to; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://*.tawk.to; img-src 'self' data: blob: https:; media-src 'self' https://*.tawk.to; connect-src 'self' https://firestore.googleapis.com https://firebase.googleapis.com https://www.googleapis.com https://identitytoolkit.googleapis.com https://fcm.googleapis.com https://securetoken.googleapis.com https://api.emailjs.com https://*.tawk.to wss://*.tawk.to wss://*.firebaseio.com https://www.gstatic.com https://wavevapes.clever-selling-station.workers.dev; worker-src 'self' blob:; frame-src https://embed.tawk.to https://*.tawk.to; frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|woff2|woff|ttf)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "logo.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000, stale-while-revalidate=86400"
          }
        ]
      },
      {
        "source": "*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          },
          {
            "key": "Link",
            "value": "<https://www.gstatic.com>; rel=preconnect, <https://fonts.gstatic.com>; rel=preconnect, <https://cdn.tailwindcss.com>; rel=preconnect"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      },
      {
        "source": "firebase-messaging-sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": ["*"]
  }
}
