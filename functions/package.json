{
  "name": "wavevapes-functions",
  "version": "1.0.0",
  "description": "WaveVapes Firebase Cloud Functions",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint index.js"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-undef": "error",
      "no-console": "off"
    }
  },
  "private": true
}
