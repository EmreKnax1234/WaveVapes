  "redirects": [
    { "source": "/vape-4-fuer-3",               "destination": "/4-fuer-3-aktion",              "permanent": true },
    { "source": "/einwegzigarette-kaufen",       "destination": "/einweg-e-zigarette-kaufen",    "permanent": true },
    { "source": "/einweg-zigarette-kaufen",      "destination": "/einweg-e-zigarette-kaufen",    "permanent": true },
    { "source": "/e-zigarette-kaufen",           "destination": "/einweg-e-zigarette-kaufen",    "permanent": true },
    { "source": "/einwegezigarette",             "destination": "/einweg-e-zigarette-kaufen",    "permanent": true },
    { "source": "/einwegezigarette-kaufen",      "destination": "/einweg-e-zigarette-kaufen",    "permanent": true },
    { "source": "/disposable-vape-kaufen",       "destination": "/disposable-vapes-kaufen",      "permanent": true },
    { "source": "/disposable-vape",             "destination": "/disposable-vapes-kaufen",      "permanent": true },
    { "source": "/einwegvape",                  "destination": "/disposable-vapes-kaufen",      "permanent": true },
    { "source": "/einweg-vape",                 "destination": "/disposable-vapes-kaufen",      "permanent": true },
    { "source": "/tornado-30000",               "destination": "/tornado-30000-vape-kaufen",    "permanent": true },
    { "source": "/tornado30000",                "destination": "/tornado-30000-vape-kaufen",    "permanent": true },
    { "source": "/tornado-vape",                "destination": "/tornado-30000-vape-kaufen",    "permanent": true },
    { "source": "/elfliq",                      "destination": "/elfliq-liquid-20mg",           "permanent": true },
    { "source": "/elfliq-kaufen",               "destination": "/elfliq-liquid-20mg",           "permanent": true },
    { "source": "/elfliq-liquid",               "destination": "/elfliq-liquid-20mg",           "permanent": true },
    { "source": "/elfliq-liquids",              "destination": "/elfliq-liquid-20mg",           "permanent": true },
    { "source": "/nic-salt",                    "destination": "/nic-salt-liquid-kaufen",       "permanent": true },
    { "source": "/nicsalt",                     "destination": "/nic-salt-liquid-kaufen",       "permanent": true },
    { "source": "/nikotinsalz-liquid",          "destination": "/nic-salt-liquid-kaufen",       "permanent": true },
    { "source": "/mystery-box",                 "destination": "/mystery-vape-box",             "permanent": true },
    { "source": "/mystery",                     "destination": "/mystery-vape-box",             "permanent": true },
    { "source": "/4-fuer-3",                    "destination": "/4-fuer-3-aktion",              "permanent": true },
    { "source": "/angebote",                    "destination": "/vape-angebote",               "permanent": true },
    { "source": "/deals",                       "destination": "/vape-angebote",               "permanent": true },
    { "source": "/shop",                        "destination": "/",                             "permanent": false },
    { "source": "/produkte",                    "destination": "/",                             "permanent": false },
    { "source": "/404",                         "destination": "/",                             "permanent": false },
    { "source": "/og-image.jpg",               "destination": "/og-image.svg",                 "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",     "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.gstatic.com https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://embed.tawk.to https://*.tawk.to; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://*.tawk.to; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://*.tawk.to; img-src 'self' data: blob: https:; media-src 'self' https://*.tawk.to; connect-src 'self' https://firestore.googleapis.com https://firebase.googleapis.com https://identitytoolkit.googleapis.com https://fcm.googleapis.com https://securetoken.googleapis.com https://api.emailjs.com https://www.google-analytics.com https://region1.google-analytics.com https://*.tawk.to wss://*.tawk.to; worker-src 'self' blob:; frame-src https://embed.tawk.to https://*.tawk.to; frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
        },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-DNS-Prefetch-Control",    "value": "on" },
        { "key": "Cross-Origin-Opener-Policy","value": "same-origin-allow-popups" }
      ]
    },
    {
      "source": "/(admin|account)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control",  "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Robots-Tag",   "value": "noindex" }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*\\.(png|jpg|jpeg|gif|svg|ico|webp))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*\\.(js|css))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",           "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed",  "value": "/" }
      ]
    },
    {
      "source": "/firebase-messaging-sw.js",
      "headers": [
        { "key": "Cache-Control",           "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed",  "value": "/" }
      ]
    },
    {
      "source": "/logo.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control",    "value": "public, max-age=3600, stale-while-revalidate=3600" },
        { "key": "Content-Type",     "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
