    { "source": "/tornado-30000-vape-kaufen",    "destination": "/tornado-30000-vape-kaufen.html" },
    { "source": "/elfliq-liquid-20mg",           "destination": "/elfliq-liquid-20mg.html" },
    { "source": "/einweg-vape-30000-zuege",      "destination": "/einweg-vape-30000-zuege.html" },
    { "source": "/4-fuer-3-aktion",              "destination": "/4-fuer-3-aktion.html" },
